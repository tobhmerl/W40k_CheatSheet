@page "/admin"
@using W40k_CheatSheet.Client.Models
@using W40k_CheatSheet.Client.Services
@inject DetachmentEffectsService EffectsService

<PageTitle>Admin – Detachment Effects</PageTitle>

<div class="admin-page">
    <h1>⚙️ Detachment Effects Editor</h1>
    <p class="admin-subtitle">Define stat modifiers that detachment rules apply to units. Changes are saved to your browser and used automatically.</p>

    @if (!loaded)
    {
        <p>Loading…</p>
    }
    else
    {
        @foreach (var def in definitions)
        {
            <div class="admin-detachment-card">
                <div class="admin-detachment-header">
                    <input type="text" @bind="def.Detachment" placeholder="Detachment name (e.g. Awakened Dynasty)" class="admin-input admin-input-wide" />
                    <button class="admin-btn-danger" @onclick="() => RemoveDetachment(def)">🗑 Remove</button>
                </div>

                <table class="admin-effects-table">
                    <thead>
                        <tr>
                            <th>Stat</th>
                            <th>Modifier</th>
                            <th>Weapon Type</th>
                            <th>Condition</th>
                            <th>Show in Stats</th>
                            <th>Source Label</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var effect in def.Effects)
                        {
                            <tr>
                                <td>
                                    <select @bind="effect.Stat" class="admin-select">
                                        <option value="bs">Ballistic Skill (BS)</option>
                                        <option value="ws">Weapon Skill (WS)</option>
                                        <option value="attacks">Attacks (A)</option>
                                        <option value="strength">Strength (S)</option>
                                        <option value="ap">Armour Penetration (AP)</option>
                                        <option value="damage">Damage (D)</option>
                                        <option value="toughness">Toughness (T)</option>
                                        <option value="save">Save (SV)</option>
                                    </select>
                                </td>
                                <td>
                                    <input type="number" @bind="effect.Modifier" class="admin-input admin-input-narrow" />
                                </td>
                                <td>
                                    <select @bind="effect.WeaponType" class="admin-select">
                                        <option value="all">All Weapons</option>
                                        <option value="melee">Melee Only</option>
                                        <option value="ranged">Ranged Only</option>
                                    </select>
                                </td>
                                <td>
                                    <select @bind="effect.Condition" class="admin-select">
                                        <option value="always">Always Active</option>
                                        <option value="has_leader_character">Unit has Character Leader</option>
                                        <option value="charged">Unit Charged this Turn</option>
                                        <option value="battle_shocked_and_charged">Battle-shocked &amp; Charged</option>
                                    </select>
                                </td>
                                <td>
                                    <input type="checkbox" @bind="effect.ReflectedInStats" />
                                </td>
                                <td>
                                    <input type="text" @bind="effect.SourceLabel" placeholder="e.g. Maddened Ferocity" class="admin-input" />
                                </td>
                                <td>
                                    <button class="admin-btn-small-danger" @onclick="() => RemoveEffect(def, effect)">✕</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <button class="admin-btn" @onclick="() => AddEffect(def)">+ Add Effect</button>
            </div>
        }

        <div class="admin-actions">
            <button class="admin-btn" @onclick="AddDetachment">+ Add Detachment</button>
            <button class="admin-btn-primary" @onclick="Save">💾 Save All</button>
        </div>

        @if (saved)
        {
            <div class="admin-saved-msg">✅ Saved successfully!</div>
        }
    }
</div>

@code {
    private List<DetachmentEffectDefinition> definitions = [];
    private bool loaded;
    private bool saved;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            definitions = await EffectsService.GetAllAsync();
            // Deep-copy so edits don't affect the cached version until save
            definitions = definitions.Select(d => new DetachmentEffectDefinition
            {
                Detachment = d.Detachment,
                Effects = d.Effects.Select(e => new DetachmentEffect
                {
                    Stat = e.Stat,
                    Modifier = e.Modifier,
                    WeaponType = e.WeaponType,
                    Condition = e.Condition,
                    ReflectedInStats = e.ReflectedInStats,
                    SourceLabel = e.SourceLabel
                }).ToList()
            }).ToList();
            loaded = true;
            StateHasChanged();
        }
    }

    private void AddDetachment()
    {
        definitions.Add(new DetachmentEffectDefinition());
    }

    private void RemoveDetachment(DetachmentEffectDefinition def)
    {
        definitions.Remove(def);
    }

    private void AddEffect(DetachmentEffectDefinition def)
    {
        def.Effects.Add(new DetachmentEffect());
    }

    private void RemoveEffect(DetachmentEffectDefinition def, DetachmentEffect effect)
    {
        def.Effects.Remove(effect);
    }

    private async Task Save()
    {
        await EffectsService.SaveAsync(definitions);
        EffectsService.InvalidateCache();
        saved = true;
        StateHasChanged();
        await Task.Delay(2000);
        saved = false;
        StateHasChanged();
    }
}
