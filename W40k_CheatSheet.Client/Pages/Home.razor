    private static List<string> GetAllKeywords(UnitEntry unit) =>
        unit.Keywords
            .Concat(unit.AttachedLeaders.SelectMany(l => l.Keywords))
            .Distinct().ToList();

    private static readonly System.Text.RegularExpressions.Regex KeywordHighlightRegex = new(
        string.Join("|", [
            // Phase with optional timing & turn context: "at the start of your opponent's Shooting phase"
            @"(?:at the (?:start|end) of )?(?:your )?(?:opponent'?s? )?(?:Command|Movement|Shooting|Charge|Fight) phase",
            // Dice rolls with prefix: "roll 2 D6"
            @"\broll \d+\s*D\d+",
            // Standalone dice: "D3", "2D6", "D6+1"
            @"\b\d*D\d+(?:\+\d+)?\b",
            // Distances: "within 12""
            @"within \d+[""\u2033]",
            // Attack keywords
            @"\b(?:Critical (?:Wound|Hit)s?|Devastating Wounds?|Lethal Hits?|Sustained Hits?)\b",
            // Thresholds: "on a 6", "on a 2-5", "on a 4+"
            @"on a \d+(?:-\d+|\+)?",
            // Unit type references
            @"\b(?:Necrons?|Character) (?:unit|model)s?\b",
            // Timing
            @"\b(?:once per (?:turn|battle)|each time)\b",
            // Re-roll
            @"\bre-rolls?(?:ed|ing)?\b",
        ]),
        System.Text.RegularExpressions.RegexOptions.IgnoreCase | System.Text.RegularExpressions.RegexOptions.Compiled);

    private static MarkupString HighlightKeywords(string text)
    {
        if (string.IsNullOrEmpty(text)) return new MarkupString("");
        var matches = KeywordHighlightRegex.Matches(text);
        if (matches.Count == 0)
            return new MarkupString(System.Net.WebUtility.HtmlEncode(text));
        var sb = new System.Text.StringBuilder();
        int last = 0;
        foreach (System.Text.RegularExpressions.Match m in matches)
        {
            if (m.Index < last) continue;
            if (m.Index > last)
                sb.Append(System.Net.WebUtility.HtmlEncode(text[last..m.Index]));
            sb.Append("<span class=\"kw-hl\">");
            sb.Append(System.Net.WebUtility.HtmlEncode(m.Value));
            sb.Append("</span>");
            last = m.Index + m.Length;
        }
        if (last < text.Length)
            sb.Append(System.Net.WebUtility.HtmlEncode(text[last..]));
        return new MarkupString(sb.ToString());
    }

    private static int GetTotalPoints(UnitEntry unit) =>
        unit.Points + unit.AttachedLeaders.Sum(l => l.Points);

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        errorMessage = null;
        selectedLeader = null;
        draggedUnit = null;
        dragOverUnit = null;
        expandedUnits.Clear();
        try
        {
            var file = e.File;
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var reader = new StreamReader(stream);
            rawJson = await reader.ReadToEndAsync();
            army = parser.Parse(rawJson);
            abilityConfigs.Clear();
            stratagemConfigs.Clear();
            InitAbilityConfigs();
            InitStratagemConfigs();
            setupConfirmed = true;
            stratagemSetupConfirmed = true;
            abilitiesPanelOpen = true;
            stratagemsPanelOpen = true;
            armyIsSaved = false;
            await SaveToStorage();
            await SaveAbilityConfigs();
            await SaveStratagemConfigs();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error importing file: {ex.Message}";
            army = null;
        }
    }

    private async Task ClearRoster()
    {
        army = null;
        rawJson = null;
        errorMessage = null;
        selectedLeader = null;
        expandedUnits.Clear();
        abilityConfigs.Clear();
        stratagemConfigs.Clear();
        setupConfirmed = false;
        stratagemSetupConfirmed = false;
        armyIsSaved = false;
        saveToast = null;
        await JS.InvokeVoidAsync("localStorage.removeItem", "roster-json");
        await JS.InvokeVoidAsync("localStorage.removeItem", "roster-state");
        await JS.InvokeVoidAsync("localStorage.removeItem", "ability-configs");
        await JS.InvokeVoidAsync("localStorage.removeItem", "stratagem-configs");
    }

    private async Task SaveToStorage()
    {
        if (army is null || rawJson is null) return;
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "roster-json", rawJson);

            var state = new RosterState
            {
                UnitOrder = army.Units.Select(u => u.Name).ToList(),
                Attachments = army.Units
                    .SelectMany(u => u.AttachedLeaders.Select(l => new AttachmentInfo { Leader = l.Name, Host = u.Name }))
                    .ToList()
            };
            await JS.InvokeVoidAsync("localStorage.setItem", "roster-state",
                JsonSerializer.Serialize(state));
        }
        catch { /* localStorage quota or unavailable */ }
    }

    private async Task LoadFromStorage()
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", "roster-json");
            if (string.IsNullOrEmpty(json)) return;

            rawJson = json;
            army = parser.Parse(json);

            var stateJson = await JS.InvokeAsync<string?>("localStorage.getItem", "roster-state");
            if (!string.IsNullOrEmpty(stateJson))
            {
                var state = JsonSerializer.Deserialize<RosterState>(stateJson);
                if (state is not null)
                    ApplyState(state);
            }

            var configJson = await JS.InvokeAsync<string?>("localStorage.getItem", "ability-configs");
            if (!string.IsNullOrEmpty(configJson))
            {
                var saved = JsonSerializer.Deserialize<Dictionary<string, AbilitySetupEntry>>(configJson);
                if (saved is not null)
                {
                    foreach (var (k, v) in saved)
                        abilityConfigs[k] = v;
                    setupConfirmed = true;
                }
            }

            var stratConfigJson = await JS.InvokeAsync<string?>("localStorage.getItem", "stratagem-configs");
            if (!string.IsNullOrEmpty(stratConfigJson))
            {
                var savedStrats = JsonSerializer.Deserialize<Dictionary<string, StratagemSetupEntry>>(stratConfigJson);
                if (savedStrats is not null)
                {
                    foreach (var (k, v) in savedStrats)
                        stratagemConfigs[k] = v;
                    stratagemSetupConfirmed = true;
                }
            }
            else
            {
                stratagemSetupConfirmed = setupConfirmed;
            }
            InitStratagemConfigs();
            InitAbilityConfigs();
            armyIsSaved = army is not null && savedArmies.Any(s => s.Name == army.Name);
        }
        catch { /* corrupt data or storage unavailable */ }
    }

    private void ApplyState(RosterState state)
    {
        if (army is null) return;

        if (state.UnitOrder.Count > 0)
        {
            var remaining = new List<UnitEntry>(army.Units);
            var ordered = new List<UnitEntry>();

            foreach (var name in state.UnitOrder)
            {
                var match = remaining.FirstOrDefault(u => u.Name == name);
                if (match is not null)
                {
                    ordered.Add(match);
                    remaining.Remove(match);
                }
            }

            ordered.AddRange(remaining);
            army.Units = ordered;
        }

        foreach (var att in state.Attachments)
        {
            var leader = army.Units.FirstOrDefault(u => u.Name == att.Leader && u.IsLeader);
            var host = army.Units.FirstOrDefault(u => u.Name == att.Host && u != leader);
            if (leader is not null && host is not null && !host.AttachedLeaders.Contains(leader))
                host.AttachedLeaders.Add(leader);
        }
    }

