    private List<Stratagem> FilteredStratagems
    {
        get
        {
            var detachment = army?.Detachment ?? "";
            var available = CoreStratagems.All
                .Where(s => string.IsNullOrEmpty(s.Detachment) ||
                            s.Detachment.Equals(detachment, StringComparison.OrdinalIgnoreCase))
                .Where(s => !IsDisabledStratagem(s));

            if (!showAllStratagems)
            {
                if (activeTurn is not null)
                    available = available.Where(s => IsStratConfiguredForTurn(s, activeTurn.Value));

                if (activePhase is not null)
                    available = available.Where(s => IsStratConfiguredForPhase(s, activePhase.Value));
            }

            return available
                .OrderBy(s => LowestPhaseOrder(s))
                .ThenBy(s => TurnColorOrder(s.TurnColor))
                .ThenBy(s => string.IsNullOrEmpty(s.Detachment) ? 0 : 1)
                .ThenBy(s => s.Name)
                .ToList();
        }
    }

    private static int LowestPhaseOrder(Stratagem s)
    {
        var phases = s.Phases;
        if (phases.HasFlag(GamePhase.Command)) return 0;
        if (phases.HasFlag(GamePhase.Move))    return 1;
        if (phases.HasFlag(GamePhase.Shoot))   return 2;
        if (phases.HasFlag(GamePhase.Charge))  return 3;
        if (phases.HasFlag(GamePhase.Fight))   return 4;
        return 5;
    }

    private static int TurnColorOrder(StratagemTurn color) => color switch
    {
        StratagemTurn.Blue    => 0,
        StratagemTurn.BlueRed => 0,
        StratagemTurn.Red     => 1,
        StratagemTurn.RedBlue => 1,
        StratagemTurn.Green   => 2,
        _                     => 2
    };

    private static string GetStratTurnClass(Stratagem strat) => strat.TurnColor switch
    {
        StratagemTurn.Blue => "turn-myturn",
        StratagemTurn.Red => "turn-enemyturn",
        StratagemTurn.BlueRed => "turn-bluered",
        StratagemTurn.RedBlue => "turn-redblue",
        _ => "turn-both"
    };

    private void ToggleStratDots(UnitEntry unit)
    {
        if (!stratHiddenUnits.Remove(unit))
            stratHiddenUnits.Add(unit);
    }

    private static string GetPhaseLabels(GamePhase phases)
    {
        if (phases == GamePhase.All) return "Any";
        var labels = new List<string>();
        if (phases.HasFlag(GamePhase.Command)) labels.Add("Cmd");
        if (phases.HasFlag(GamePhase.Move)) labels.Add("Mov");
        if (phases.HasFlag(GamePhase.Shoot)) labels.Add("Sht");
        if (phases.HasFlag(GamePhase.Charge)) labels.Add("Chg");
        if (phases.HasFlag(GamePhase.Fight)) labels.Add("Fgt");
        return string.Join(" · ", labels);
    }

    private static bool IsAbilityAvailableOnTurn(string description, TurnFilter turn)
    {
        // Explicit enemy-turn indicator: your opponent is the actor
        bool opponentActing = description.Contains("your opponent", StringComparison.OrdinalIgnoreCase);

        // Strip references where "enemy" is just the TARGET (enemy unit/model), not the actor,
        // then check if "you/your" appears — indicating it's YOUR ability
        var stripped = description
            .Replace("your opponent", "", StringComparison.OrdinalIgnoreCase)
            .Replace("enemy unit", "", StringComparison.OrdinalIgnoreCase)
            .Replace("enemy model", "", StringComparison.OrdinalIgnoreCase)
            .Replace("enemy", "", StringComparison.OrdinalIgnoreCase);

        bool youActing = stripped.Contains("your", StringComparison.OrdinalIgnoreCase) ||
                         stripped.Contains(" you ", StringComparison.OrdinalIgnoreCase) ||
                         stripped.Contains(" you,", StringComparison.OrdinalIgnoreCase) ||
                         stripped.Contains(" you.", StringComparison.OrdinalIgnoreCase);

        // No clear indicator → show for both turns
        if (!opponentActing && !youActing) return true;
        // Appears in both contexts → show for both turns
        if (opponentActing && youActing) return true;

        return turn switch
        {
            TurnFilter.MyTurn => youActing,
            TurnFilter.EnemyTurn => opponentActing,
            _ => true
        };
    }

    private static bool IsStatReflectedAbility(AbilityEntry ability, UnitEntry unit)
    {
        var name = ability.Name;
        var desc = ability.Description;

        // Skip leader auras — handled by the "add to unit" mechanism
        if (IsLeaderAuraDescription(desc))
            return false;

        bool isFnp = name.Contains("Feel No Pain", StringComparison.OrdinalIgnoreCase) ||
                     System.Text.RegularExpressions.Regex.IsMatch(desc, @"feel\s+no\s+pain\s+\d\+", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (isFnp)
            return true;

        bool isInvuln = name.Contains("Invulnerable", StringComparison.OrdinalIgnoreCase) ||
                        System.Text.RegularExpressions.Regex.IsMatch(desc, @"\d\+\s*invulnerable", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (isInvuln)
            return true;

        return false;
    }

    private static bool IsSetupOnlyAbility(AbilityEntry ability)
    {
        var name = ability.Name;
        return name.Equals("Leader", StringComparison.OrdinalIgnoreCase) ||
               name.Contains("Retinue", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsPreGameAbility(AbilityEntry ability)
    {
        var name = ability.Name;
        return name.StartsWith("Scout", StringComparison.OrdinalIgnoreCase) ||
               name.StartsWith("Infiltrator", StringComparison.OrdinalIgnoreCase) ||
               name.StartsWith("Deep Strike", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsPreGameKeyword(string kw) =>
        kw.StartsWith("Scout", StringComparison.OrdinalIgnoreCase) ||
        kw.StartsWith("Infiltrator", StringComparison.OrdinalIgnoreCase) ||
        kw.StartsWith("Deep Strike", StringComparison.OrdinalIgnoreCase);

    private List<(UnitEntry Unit, string Label, string Description)> PreGameReminders
    {
        get
        {
            if (army is null) return [];
            var results = new List<(UnitEntry, string, string)>();
            var seen = new HashSet<(string, string)>();
            foreach (var unit in AliveUnits)
            {
                foreach (var a in GetAllAbilities(unit).Where(IsPreGameAbility))
                {
                    if (seen.Add((unit.Name, a.Name)))
                        results.Add((unit, a.Name, a.Description));
                }
                foreach (var kw in GetAllKeywords(unit).Where(IsPreGameKeyword))
                {
                    if (seen.Add((unit.Name, kw)))
                        results.Add((unit, kw, ""));
                }
            }
            return results;
        }
    }

