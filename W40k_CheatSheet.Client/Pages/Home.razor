@page "/"
@using W40k_CheatSheet.Client.Models
@using W40k_CheatSheet.Client.Services
@using System.Text.Json
@inject IJSRuntime JS
@inject CloudRosterService Cloud
@inject DetachmentEffectsService DetachmentEffects
@inject RosterStateService RosterState
@inject EffectResolverService Resolver

<PageTitle>Segmentum Ultima</PageTitle>

<div class="roster-app @FactionClass">
    @* ── Top-left login corner ── *@
    <LoginCorner OnAuthChanged="OnAuthChanged" />

    @if (!loaded)
    {
        <LoadingScreen />
    }
    else if (army is null)
    {
        <WelcomeHero @bind-WelcomeBg="welcomeBg"
                     ErrorMessage="@errorMessage"
                     SavedArmies="savedArmies"
                     CloudRosters="cloudRosters"
                     OnFileSelected="HandleFileSelected"
                     OnLoadSavedArmy="LoadSavedArmy"
                     OnDeleteSavedArmy="DeleteSavedArmy"
                     OnLoadCloudArmy="LoadCloudArmy"
                     OnDeleteCloudArmy="DeleteCloudArmy" />
    }
    else
    {
        @if (playMode)
        {
            <CpCounter @bind-Value="cpCounter" />
        }

        @if (!playMode)
        {
            <TopActions PlayMode="playMode"
                        SaveTick="saveTick"
                        OnTogglePlayMode="TogglePlayMode"
                        OnSaveCurrentArmy="SaveCurrentArmy"
                        OnResetAllFilters="ResetAllFilters"
                        OnClearRoster="ClearRoster" />
        }

        <RosterHeader ArmyName="@army.Name"
                      Detachment="@army.Detachment"
                      DetachmentRule="@army.DetachmentRule"
                      DetachmentReminderVisible="IsDetachmentReminderVisible"
                      MyTurnActive="activeTurn == TurnFilter.MyTurn"
                      EnemyTurnActive="activeTurn == TurnFilter.EnemyTurn"
                      ActivePhase="activePhase"
                      PlayMode="playMode"
                      DetachmentConfig="detachmentConfig"
                      OnToggleMyTurn="() => ToggleTurn(TurnFilter.MyTurn)"
                      OnToggleEnemyTurn="() => ToggleTurn(TurnFilter.EnemyTurn)"
                      OnTogglePhase="TogglePhase"
                      OnSaveDetachmentConfig="SaveDetachmentConfig" />

        @if (playMode && !preGameDismissed)
        {
            <PreGameBanner Reminders="PreGameReminders" OnDismiss="() => preGameDismissed = true" />
        }

        <UnitJumpStrip ElementId="nav-top"
                       PlayMode="playMode"
                       AliveUnits="AliveUnits"
                       VisiblePlayUnits="visiblePlayUnits"
                       OnUnitButton="HandleUnitButton"
                       OnToggleAllUnits="ToggleAllUnits"
                       OnResetAllFilters="ResetAllFilters" />

        <AttachHint SelectedLeader="selectedLeader" OnCancel="CancelSelection" />

        <MoveHint MovingUnit="movingUnit" OnCancel="() => movingUnit = null" />

        <BuffSourcePopup Label="@buffSourcePopup?.Label"
                         Source="@buffSourcePopup?.Source"
                         KeywordDescription="@buffSourcePopup?.KeywordDesc"
                         OnDismiss="() => buffSourcePopup = null" />

        <WeaponRemovePopup Popup="weaponRemovePopup"
                           GetMixedLoadoutWeapons="(u, d) => GetMixedLoadoutWeapons(u, d)"
                           OnConfirm="ConfirmWeaponModelRemoval"
                           OnCancel="() => weaponRemovePopup = null" />

        <div class="unit-grid">
            @{
                bool killedDividerInserted = false;
            }
            @foreach (var unit in DisplayUnits)
            {
                if (playMode && !IsKilled(unit) && !visiblePlayUnits.Contains(unit)) { continue; }
                var stats = GetAllStatLines(unit);
                var ranged = GetAllRangedWeapons(unit);
                var melee = GetAllMeleeWeapons(unit);
                var allAbilities = GetAllAbilities(unit);
                var enhancements = GetAllEnhancements(unit)
                    .Where(e => !allAbilities.Any(a => a.Name.Equals(e, StringComparison.OrdinalIgnoreCase) && IsAddedToUnit(a) && IsReflectableAsUnitStat(a)))
                    .Where(e => !playMode || !allAbilities.Any(a => a.Name.Equals(e, StringComparison.OrdinalIgnoreCase)))
                    .ToList();
                var keywords = GetAllKeywords(unit);
                var extraRangedKw = GetExtraWeaponKeywords(unit, false);
                var extraMeleeKw = GetExtraWeaponKeywords(unit, true);
                var extraDef = GetExtraDefensiveAuras(unit);
                var extraUnitKw = GetExtraUnitKeywords(unit);
                var unitKwBadges = playMode ? GetUnitKeywordBadges(unit) : new List<string>();
                var extraCritRanged = GetExtraCritModifier(unit, false);
                var extraCritMelee = GetExtraCritModifier(unit, true);
                var hitBonus = UnitHasDetachmentHitBonus(unit);
                var srcRangedKw = GetExtraWeaponKeywordsSource(unit, false);
                var srcMeleeKw = GetExtraWeaponKeywordsSource(unit, true);
                var srcCritRanged = GetExtraCritSource(unit, false);
                var srcCritMelee = GetExtraCritSource(unit, true);
                var srcHitBonus = GetHitBonusSource(unit);
                var srcDef = GetExtraDefensiveAuraSources(unit);
                var isWarlord = unit.IsWarlord || unit.AttachedLeaders.Any(l => l.IsWarlord);
                var abilityCount = GetCardAbilities(unit).Count;
                var alwaysActiveAbilities = playMode ? GetCardAlwaysActiveAbilities(unit) : new List<AbilityEntry>();
                var alwaysActiveStrats = playMode ? GetCardAlwaysActiveStratagems(unit) : new List<Stratagem>();
                List<Stratagem> headerStrats = playMode ? GetCardStratagems(unit) : [];
                var collapsed = IsCollapsed(unit);

                @if (playMode && !killedDividerInserted && IsKilled(unit))
                {
                    killedDividerInserted = true;
                    <KilledDivider />
                }

                <UnitCardShell Unit="unit"
                               AnchorId="@UnitAnchorId(unit.Name)"
                               CardClass="@CardClass(unit)"
                               OnDragStart="DragStart"
                               OnDragEnd="DragEnd"
                               OnDragEnter="DragEnter"
                               OnDrop="Drop">

                    <UnitCardHeader Unit="unit"
                                    Collapsed="collapsed"
                                    IsWarlord="isWarlord"
                                    HasStrats="abilityCount > 0 || headerStrats.Count > 0 || alwaysActiveAbilities.Count > 0 || alwaysActiveStrats.Count > 0"
                                    StratHidden="stratHiddenUnits.Contains(unit)"
                                    PlayMode="playMode"
                                    Targeted="targetedUnits.Contains(unit)"
                                    Charged="chargedUnits.Contains(unit)"
                                    Killed="IsKilled(unit)"
                                    HasDefensiveModifiers="playMode && GetAllDefensiveModifiers(unit).Count > 0"
                                    HasChargeEffects="playMode && GetAllChargeEffects(unit).Count > 0"
                                    KeywordBadges="playMode ? GetUnitKeywordBadgesWithSource(unit).Select(b => (b.Keyword, b.Source, b.Description)).ToList() : new List<(string, string, string)>()"
                                    OnHeaderClick="HandleHeaderClickTuple"
                                    OnHeaderPointerDown="HeaderPointerDown"
                                    OnHeaderPointerUp="HeaderPointerUp"
                                    OnToggleStratDots="ToggleStratDots"
                                    OnStartMove="StartMove"
                                    OnToggleTargeted="ToggleTargeted"
                                    OnToggleCharged="ToggleCharged"
                                    OnReviveUnit="ReviveUnit"
                                    OnShowBuffSource="ShowBuffSourceTuple" />

                    @{
                        var showDetachmentInCard = playMode && !string.IsNullOrEmpty(army?.DetachmentRule) &&
                            HasDetachmentPhasesConfigured && !IsDetachmentAlwaysActive && IsDetachmentVisibleForCurrentFilter &&
                            !IsDetachmentRuleReflectedInStats;
                        var showDetachmentAlways = playMode && !string.IsNullOrEmpty(army?.DetachmentRule) &&
                            HasDetachmentPhasesConfigured && IsDetachmentAlwaysActive && !IsDetachmentHidden &&
                            !IsDetachmentRuleReflectedInStats;
                    }
                    <UnitCardStratExpand Unit="unit"
                                         StratHidden="stratHiddenUnits.Contains(unit)"
                                         AbilityCount="abilityCount"
                                         HeaderStrats="headerStrats"
                                         CardAbilities="GetCardAbilities(unit)"
                                         AlwaysActiveAbilities="alwaysActiveAbilities"
                                         AlwaysActiveStrats="alwaysActiveStrats"
                                         ShowDetachmentInCard="showDetachmentInCard"
                                         ShowDetachmentAlways="showDetachmentAlways"
                                         Detachment="@army?.Detachment"
                                         DetachmentRule="@army?.DetachmentRule"
                                         UsedAbilities="usedAbilities"
                                         UsedStratagems="usedStratagems"
                                         FocusedAbility="focusedAbility"
                                         FocusedStratagem="focusedStratagem"
                                         FocusedStratagemUnit="focusedStratagemUnit"
                                         @bind-FocusedDetachmentRule="focusedDetachmentRule"
                                         OnToggleFocusAbility="ToggleFocusAbility"
                                         OnToggleCardStratagem="ToggleCardStratagemTuple"
                                         OnceAbilityPointerDown="OnceAbilityPointerDown"
                                         OnceStratagemPointerDown="OnceStratagemPointerDown"
                                         OncePointerUp="OncePointerUp"
                                         ParseCpCost="ParseCpCost" />

                    @if (!playMode && unit.AttachedLeaders.Count > 0)
                    {
                        <AttachedLeadersStrip Leaders="unit.AttachedLeaders"
                                              OnDetach="leader => DetachLeader(unit, leader)" />
                    }

                    @if (!collapsed)
                    {
                        <div class="unit-body">
                            <UnitEnhancements Enhancements="enhancements"
                                              AllAbilities="allAbilities"
                                              FocusedAbility="focusedAbility"
                                              OnToggleFocusAbility="ToggleFocusAbility" />

                            @if (stats.Count > 0)
                            {
                                <StatsTable Unit="unit"
                                            Stats="stats"
                                            ExtraInvuln="@extraDef.ExtraInvuln"
                                            ExtraFnp="@extraDef.ExtraFnp"
                                            InvulnSource="@srcDef.InvulnSource"
                                            FnpSource="@srcDef.FnpSource"
                                            PlayMode="playMode"
                                            FocusedStatOwner="focusedStatOwner"
                                            FocusedWeapon="focusedWeapon"
                                            Targeted="targetedUnits.Contains(unit)"
                                            Charged="chargedUnits.Contains(unit)"
                                            DefensiveModifiers="GetAllDefensiveModifiers(unit)"
                                            ChargeEffects="GetAllChargeEffects(unit)"
                                            OnToggleFocusStatOwner="ToggleFocusStatOwnerTuple"
                                            OnAdjustModelCount="AdjustModelCountTuple"
                                            OnShowBuffSource="ShowBuffSourceTuple"
                                            BetterFnp="BetterFnp"
                                            ShortStatName="ShortStatName"
                                            GetModelCount="GetModelCount" />
                            }

                            @if (ranged.Count > 0)
                            {
                                var rangedExpanded = IsRangedExpanded(unit);
                                var hideRangedSection = focusedCard == unit && focusedStatOwner is not null && !ranged.Any(w => IsWeaponOwnedByFocused(w) && IsWeaponPhaseRelevant(true));
                                <WeaponsTable Title="⊕ RANGED"
                                              SkillLabel="BS"
                                              Weapons="ranged"
                                              Expanded="rangedExpanded"
                                              HideSection="hideRangedSection"
                                              PlayMode="playMode"
                                              CardFocused="focusedCard == unit"
                                              StatOwnerFocused="focusedStatOwner is not null"
                                              WeaponPhaseRelevant="IsWeaponPhaseRelevant(true)"
                                              FocusedWeapon="focusedWeapon"
                                              HitBonus="hitBonus"
                                              HitBonusSource="@srcHitBonus"
                                              ExtraCrit="@extraCritRanged"
                                              ExtraCritSource="@srcCritRanged"
                                              ExtraKw="@extraRangedKw"
                                              ExtraKwSource="@srcRangedKw.Source"
                                              ExtraKwDescription="@srcRangedKw.KeywordDesc"
                                              OnToggleSection="() => ToggleRangedSection(unit)"
                                              OnToggleFocusWeapon="ToggleFocusWeapon"
                                              OnShowBuffSource="ShowBuffSourceTuple"
                                              IsWeaponOwnedByFocused="IsWeaponOwnedByFocused"
                                              GetWeaponEffectiveModels="w => GetWeaponEffectiveModels(unit, w)"
                                              ImproveSkill="ImproveSkill"
                                              ShortRange="ShortRange"
                                              FormatTotalAttacks="FormatTotalAttacks"
                                              CombineKeywords="CombineKeywords" />
                            }

                            @if (melee.Count > 0)
                            {
                                var meleeExpanded = IsMeleeExpanded(unit);
                                var hideMeleeSection = focusedCard == unit && focusedStatOwner is not null && !melee.Any(w => IsWeaponOwnedByFocused(w) && IsWeaponPhaseRelevant(false));
                                <WeaponsTable Title="⚔ MELEE"
                                              SkillLabel="WS"
                                              Weapons="melee"
                                              Expanded="meleeExpanded"
                                              HideSection="hideMeleeSection"
                                              PlayMode="playMode"
                                              CardFocused="focusedCard == unit"
                                              StatOwnerFocused="focusedStatOwner is not null"
                                              WeaponPhaseRelevant="IsWeaponPhaseRelevant(false)"
                                              FocusedWeapon="focusedWeapon"
                                              HitBonus="hitBonus"
                                              HitBonusSource="@srcHitBonus"
                                              ExtraCrit="@extraCritMelee"
                                              ExtraCritSource="@srcCritMelee"
                                              ExtraKw="@extraMeleeKw"
                                              ExtraKwSource="@srcMeleeKw.Source"
                                              ExtraKwDescription="@srcMeleeKw.KeywordDesc"
                                              OnToggleSection="() => ToggleMeleeSection(unit)"
                                              OnToggleFocusWeapon="ToggleFocusWeapon"
                                              OnShowBuffSource="ShowBuffSourceTuple"
                                              IsWeaponOwnedByFocused="IsWeaponOwnedByFocused"
                                              GetWeaponEffectiveModels="w => GetWeaponEffectiveModels(unit, w)"
                                              ImproveSkill="ImproveSkill"
                                              ShortRange="ShortRange"
                                              FormatTotalAttacks="FormatTotalAttacks"
                                              CombineKeywords="CombineKeywords" />
                            }

                            @if (keywords.Count > 0)
                            {
                                <UnitKeywords Keywords="keywords" />
                            }

                            @if (focusedWeapon is not null && (ranged.Contains(focusedWeapon) || melee.Contains(focusedWeapon)))
                            {
                                <WeaponKeywordsPanel FocusedWeapon="focusedWeapon"
                                                     IsKnownWeapon="true"
                                                     Entries="GetWeaponKeywordEntries(focusedWeapon)" />
                            }

                            <AttachLeaderButton UnitIsLeader="unit.IsLeader"
                                                HasAttached="unit.AttachedLeaders.Count > 0"
                                                OnStartAttach="() => StartAttach(unit)" />

                            <UnitExtraKeywords ExtraUnitKw="@extraUnitKw"
                                               Expanded="extraKwExpandedUnit == unit"
                                               Abilities="GetExtraUnitAbilities(unit)"
                                               OnToggle="() => { extraKwExpandedUnit = extraKwExpandedUnit == unit ? null : unit; }" />

                            @if (!playMode)
                            {
                                var cardAbilities = GetAllAbilities(unit).Where(a => !IsSetupOnlyAbility(a)).ToList();
                                <UnitCardSetupAbilities CardAbilities="cardAbilities"
                                                        FocusedAbility="focusedAbility"
                                                        GetAbilityConfig="GetOrCreateConfig"
                                                        OnToggleFocusAbility="ToggleFocusAbility"
                                                        OnSaveAbilityConfigs="SaveAbilityConfigs"
                                                        OnApplyToStatsChanged="OnApplyToStatsChanged" />
                            }

                            <UnitCardFooter ShowKeywords="!playMode" Keywords="keywords" OnScrollTo="ScrollToAsync" />
                        </div>
                    }
                </UnitCardShell>
            }
        </div>

        <StratagemsPanel PlayMode="playMode"
                         @bind-IsOpen="stratagemsPanelOpen"
                         AllSetupStratagems="SetupStratagems"
                         GetStratConfig="GetOrCreateStratConfig"
                         OnSaveStratagemConfigs="SaveStratagemConfigs"
                         OnWipeAllStratagemConfigs="WipeAllStratagemConfigs"
                         OverviewStratagems="AllOverviewStratagems"
                         UsedStratagems="usedStratagems"
                         FocusedStratagem="focusedStratagem"
                         OnToggleFocusStratagem="ToggleFocusStratagem"
                         @bind-StratDetailsZoomed="stratDetailsZoomed"
                         OnceStratagemPointerDown="OnceStratagemPointerDown"
                         OncePointerUp="OncePointerUp"
                         GetStratTurnClass="GetStratTurnClass"
                         ParseCpCost="ParseCpCost" />

        <AbilitiesPanel PlayMode="playMode"
                        @bind-IsOpen="abilitiesPanelOpen"
                        Army="army"
                        DetachmentConfig="detachmentConfig"
                        OnSaveDetachmentConfig="SaveDetachmentConfig"
                        ActiveDetachmentEffects="activeDetachmentEffects"
                        GetDetachmentEffectConfig="GetOrCreateDetachmentEffectConfig"
                        OnSaveDetachmentEffectConfigs="SaveDetachmentEffectConfigs"
                        DescribeDetachmentEffect="DescribeDetachmentEffect"
                        GetArmyRuleConfig="GetOrCreateArmyRuleConfig"
                        OnSaveArmyRuleConfigs="SaveArmyRuleConfigs"
                        FocusedArmyRules="focusedArmyRules"
                        OnToggleArmyRuleFocus="ToggleArmyRuleFocus"
                        GetAbilityConfig="GetOrCreateConfig"
                        OnSaveAbilityConfigs="SaveAbilityConfigs"
                        OnWipeAllAbilityConfigs="WipeAllAbilityConfigs"
                        OnApplyToStatsChanged="OnApplyToStatsChanged"
                        IsSetupOnlyAbility="IsSetupOnlyAbility"
                        FocusedAbility="focusedAbility"
                        OnToggleFocusAbility="ToggleFocusAbility"
                        @bind-FocusedDetachmentRule="focusedDetachmentRule"
                        HasDetachmentPhasesConfigured="HasDetachmentPhasesConfigured"
                        PanelUnits="AbilitiesPanelItems"
                        UsedAbilities="usedAbilities"
                        OnceAbilityPointerDown="OnceAbilityPointerDown"
                        OncePointerUp="OncePointerUp" />

        <UnitJumpStrip ElementId="nav-bottom"
                       PlayMode="playMode"
                       AliveUnits="AliveUnits"
                       VisiblePlayUnits="visiblePlayUnits"
                       OnUnitButton="HandleUnitButton"
                       OnToggleAllUnits="ToggleAllUnits"
                       OnResetAllFilters="ResetAllFilters" />

        @if (playMode)
        {
            <ScoreTracker @bind-DefenderPrimary="defenderPrimary"
                          @bind-AggressorPrimary="aggressorPrimary"
                          @bind-DefenderSecondary="defenderSecondary"
                          @bind-AggressorSecondary="aggressorSecondary" />
        }

        <RosterFooter Faction="@army.Faction"
                      Detachment="@army.Detachment"
                      TotalPoints="army.TotalPoints"
                      PointLimit="army.PointLimit" />
    }
    @if (playMode)
    {
        <button class="play-footer-btn @(footerVisible ? "visible" : "")" @onclick="TogglePlayMode">☰</button>
    }
    else
    {
        <TopActions WrapperClass="footer-actions"
                    PlayMode="playMode"
                    SaveTick="saveTick"
                    OnTogglePlayMode="TogglePlayMode"
                    OnSaveCurrentArmy="SaveCurrentArmy"
                    OnResetAllFilters="ResetAllFilters"
                    OnClearRoster="ClearRoster" />
    }
    <div class="version-tag" @onclick="() => showChangelog = true">v2.6</div>

    <ChangelogModal @bind-Visible="showChangelog" />
</div>
