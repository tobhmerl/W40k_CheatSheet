    private void InitStratagemConfigs()
    {
        var detachment = army?.Detachment ?? "";
        foreach (var s in CoreStratagems.All)
        {
            if (!string.IsNullOrEmpty(s.Detachment) &&
                !s.Detachment.Equals(detachment, StringComparison.OrdinalIgnoreCase))
                continue;
            if (!stratagemConfigs.ContainsKey(s.Name))
                stratagemConfigs[s.Name] = BuildDefaultStratConfig(s);
