        var unitKeywords = focusedUnit is not null
            ? GetAllKeywords(focusedUnit)
            : focusedCard is not null
                ? GetAllKeywords(focusedCard)
                : focusedStatOwner!.Keywords;

        return strat.RequiredKeywords.Any(rk =>
            unitKeywords.Any(uk => uk.Contains(rk, StringComparison.OrdinalIgnoreCase)));
    }

