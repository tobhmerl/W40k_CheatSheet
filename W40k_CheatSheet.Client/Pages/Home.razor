    private sealed class StratagemSetupEntry
    {
        public bool MyTurn    { get; set; }
        public bool EnemyTurn { get; set; }
        public bool Command   { get; set; }
        public bool Move      { get; set; }
        public bool Shoot     { get; set; }
        public bool Charge    { get; set; }
        public bool Fight     { get; set; }
        public bool Disabled  { get; set; }
    }

    private StratagemSetupEntry GetOrCreateStratConfig(Stratagem s)
    {
        if (!stratagemConfigs.TryGetValue(s.Name, out var cfg))
        {
            cfg = BuildDefaultStratConfig(s);
            stratagemConfigs[s.Name] = cfg;
        }
        return cfg;
    }

    private static StratagemSetupEntry BuildDefaultStratConfig(Stratagem s)
    {
        bool myTurn = s.TurnColor is StratagemTurn.Green or StratagemTurn.Blue;
        bool enemyTurn = s.TurnColor is StratagemTurn.Green or StratagemTurn.Red;
        return new StratagemSetupEntry
        {
            MyTurn    = myTurn,
            EnemyTurn = enemyTurn,
            Command   = s.Phases.HasFlag(GamePhase.Command),
            Move      = s.Phases.HasFlag(GamePhase.Move),
            Shoot     = s.Phases.HasFlag(GamePhase.Shoot),
            Charge    = s.Phases.HasFlag(GamePhase.Charge),
            Fight     = s.Phases.HasFlag(GamePhase.Fight),
            Disabled  = false
        };
    }

    private void InitStratagemConfigs()
    {
        var detachment = army?.Detachment ?? "";
        foreach (var s in CoreStratagems.All)
        {
            if (!string.IsNullOrEmpty(s.Detachment) &&
                !s.Detachment.Equals(detachment, StringComparison.OrdinalIgnoreCase))
                continue;
            if (!stratagemConfigs.ContainsKey(s.Name))
                stratagemConfigs[s.Name] = BuildDefaultStratConfig(s);
        }
    }

    private bool IsDisabledStratagem(Stratagem s) =>
        stratagemConfigs.TryGetValue(s.Name, out var c) && c.Disabled;

    private bool IsStratConfiguredForTurn(Stratagem s, TurnFilter turn)
    {
        if (!stratagemConfigs.TryGetValue(s.Name, out var c))
            return true;
        return turn == TurnFilter.MyTurn ? c.MyTurn : c.EnemyTurn;
    }

    private bool IsStratConfiguredForPhase(Stratagem s, GamePhase phase)
    {
        if (!stratagemConfigs.TryGetValue(s.Name, out var c))
            return true;
        return phase switch
        {
            GamePhase.Command => c.Command,
            GamePhase.Move    => c.Move,
            GamePhase.Shoot   => c.Shoot,
            GamePhase.Charge  => c.Charge,
            GamePhase.Fight   => c.Fight,
            _                 => true
        };
    }

    private static string GetStratDotClass(Stratagem strat) => strat.TurnColor switch
    {
        StratagemTurn.Blue => "dot-blue",
        StratagemTurn.Red  => "dot-red",
        _                  => "dot-green"
    };

