    private async Task CloudLogin()
    {
        if (string.IsNullOrWhiteSpace(cloudEmail) || string.IsNullOrWhiteSpace(cloudPassword)) return;
        cloudBusy = true;
        StateHasChanged();
        var ok = await Cloud.LoginAsync(cloudEmail, cloudPassword);
        if (ok)
        {
            cloudPassword = "";
            loginExpanded = false;
            await RefreshCloudRosters();
        }
        cloudBusy = false;
    }

    private async Task CloudRegister()
    {
        if (string.IsNullOrWhiteSpace(cloudEmail) || string.IsNullOrWhiteSpace(cloudPassword)) return;
        cloudBusy = true;
        StateHasChanged();
        var ok = await Cloud.RegisterAsync(cloudEmail, cloudPassword);
        if (ok)
        {
            cloudPassword = "";
            loginExpanded = false;
            await RefreshCloudRosters();
        }
        cloudBusy = false;
    }

    private async Task CloudLogout()
    {
        await Cloud.LogoutAsync();
        cloudRosters.Clear();
        cloudEmail = "";
        cloudPassword = "";
        loginExpanded = false;
    }

    private async Task RefreshCloudRosters()
    {
        cloudRosters = await Cloud.ListRostersAsync();
    }

    private async Task LoadCloudArmy(Guid id)
    {
        try
        {
            var dataJson = await Cloud.LoadRosterDataAsync(id);
            if (string.IsNullOrEmpty(dataJson)) { errorMessage = "Failed to load cloud army."; return; }

            var data = JsonSerializer.Deserialize<SavedArmyData>(dataJson);
            if (data is null) return;

            rawJson = data.RawJson;
            army = parser.Parse(rawJson);

            if (data.State is not null)
                ApplyState(data.State);

            abilityConfigs.Clear();
            foreach (var (k, v) in data.AbilityConfigs)
                abilityConfigs[k] = v;

            stratagemConfigs.Clear();
            foreach (var (k, v) in data.StratagemConfigs)
                stratagemConfigs[k] = v;

            InitAbilityConfigs();
            InitStratagemConfigs();

            setupConfirmed = true;
            stratagemSetupConfirmed = true;
            expandedUnits.Clear();
            stratHiddenUnits.Clear();
            killedUnits.Clear();
            playMode = false;
            errorMessage = null;
            armyIsSaved = true;

            await SaveToStorage();
            await SaveAbilityConfigs();
            await SaveStratagemConfigs();
        }
        catch { errorMessage = "Failed to load cloud army."; }
    }

    private async Task DeleteCloudArmy(Guid id)
    {
        await Cloud.DeleteRosterAsync(id);
        await RefreshCloudRosters();
    }

    private async Task SaveToCloud()
    {
        if (army is null || rawJson is null || !Cloud.IsLoggedIn) return;
        var state = new RosterState
        {
            UnitOrder = army.Units.Select(u => u.Name).ToList(),
            Attachments = army.Units
                .SelectMany(u => u.AttachedLeaders.Select(l => new AttachmentInfo { Leader = l.Name, Host = u.Name }))
                .ToList()
        };
        var data = new SavedArmyData
        {
            RawJson = rawJson,
            State = state,
            AbilityConfigs = new Dictionary<string, AbilitySetupEntry>(abilityConfigs),
            StratagemConfigs = new Dictionary<string, StratagemSetupEntry>(stratagemConfigs)
        };
        var dataJson = JsonSerializer.Serialize(data);
        await Cloud.SaveRosterAsync(army.Name, army.Faction ?? "", army.Detachment ?? "", army.TotalPoints, dataJson);
    }
}
