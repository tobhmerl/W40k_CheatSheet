    // Does the detachment rule have any turn/phase checkboxes configured (for abilities panel display)?
    private bool HasDetachmentPhasesConfigured =>
        detachmentConfig.Command || detachmentConfig.Move || detachmentConfig.Shoot ||
        detachmentConfig.Charge || detachmentConfig.Fight;

    private bool IsDetachmentAlwaysActive
    {
        get
        {
            if (!detachmentConfig.MyTurn || !detachmentConfig.EnemyTurn) return false;
            int count = (detachmentConfig.Command ? 1 : 0) + (detachmentConfig.Move ? 1 : 0) +
                        (detachmentConfig.Shoot ? 1 : 0) + (detachmentConfig.Charge ? 1 : 0) +
                        (detachmentConfig.Fight ? 1 : 0);
            return count >= 5;
        }
    }

    private bool IsDetachmentHidden => !detachmentConfig.MyTurn && !detachmentConfig.EnemyTurn;

    private bool IsDetachmentVisibleForCurrentFilter
    {
        get
        {
            if (IsDetachmentHidden) return false;
            if (!HasDetachmentPhasesConfigured) return false;

            if (activeTurn is not null)
            {
                bool match = activeTurn == TurnFilter.MyTurn ? detachmentConfig.MyTurn : detachmentConfig.EnemyTurn;
                if (!match) return false;
            }

            if (activePhase is not null && !IsDetachmentAlwaysActive)
            {
                var d = detachmentConfig;
                bool enabled = activePhase.Value switch
                {
                    GamePhase.Command => d.Command,
                    GamePhase.Move    => d.Move,
                    GamePhase.Shoot   => d.Shoot,
                    GamePhase.Charge  => d.Charge,
                    GamePhase.Fight   => d.Fight,
                    _                 => true
                };
                if (!enabled) return false;

                // If My Turn is active and this phase is marked enemy-only, hide it
                if (activeTurn == TurnFilter.MyTurn)
                {
                    bool enemyOnly = activePhase.Value switch
                    {
                        GamePhase.Command => d.EnemyCommand,
                        GamePhase.Move    => d.EnemyMove,
                        GamePhase.Shoot   => d.EnemyShoot,
                        GamePhase.Charge  => d.EnemyCharge,
                        GamePhase.Fight   => d.EnemyFight,
                        _                 => false
                    };
                    if (enemyOnly) return false;
                }

                // If Enemy Turn is active and this phase is marked my-turn-only, hide it
                if (activeTurn == TurnFilter.EnemyTurn)
                {
                    bool myOnly = activePhase.Value switch
                    {
                        GamePhase.Command => d.MyCommand,
                        GamePhase.Move    => d.MyMove,
                        GamePhase.Shoot   => d.MyShooting,
                        GamePhase.Charge  => d.MyCharge,
                        GamePhase.Fight   => d.MyFight,
                        _                 => false
                    };
                    if (myOnly) return false;
                }
            }
            return true;
        }
    }

