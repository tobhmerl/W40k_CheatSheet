    private class SavedArmyMeta
    {
        public string Name { get; set; } = "";
        public string Faction { get; set; } = "";
        public string Detachment { get; set; } = "";
        public int Points { get; set; }
    }

    private class SavedArmyData
    {
        public string RawJson { get; set; } = "";
        public RosterState? State { get; set; }
        public Dictionary<string, AbilitySetupEntry> AbilityConfigs { get; set; } = new();
        public Dictionary<string, StratagemSetupEntry> StratagemConfigs { get; set; } = new();
    }

    private async Task LoadSavedArmiesIndex()
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", "saved-armies-index");
            if (!string.IsNullOrEmpty(json))
                savedArmies = JsonSerializer.Deserialize<List<SavedArmyMeta>>(json) ?? [];
        }
        catch { savedArmies = []; }
    }

    private async Task SaveCurrentArmy()
    {
        if (army is null || rawJson is null) return;

        bool wasAlreadySaved = armyIsSaved;
        var name = army.Name;
        var state = new RosterState
        {
            UnitOrder = army.Units.Select(u => u.Name).ToList(),
            Attachments = army.Units
                .SelectMany(u => u.AttachedLeaders.Select(l => new AttachmentInfo { Leader = l.Name, Host = u.Name }))
                .ToList()
        };

        var data = new SavedArmyData
        {
            RawJson = rawJson,
            State = state,
            AbilityConfigs = new Dictionary<string, AbilitySetupEntry>(abilityConfigs),
            StratagemConfigs = new Dictionary<string, StratagemSetupEntry>(stratagemConfigs)
        };

        if (Cloud.IsLoggedIn)
        {
            await SaveToCloud();
            await RefreshCloudRosters();
            armyIsSaved = true;
        }
        else
        {
            await JS.InvokeVoidAsync("localStorage.setItem", $"saved-army:{name}", JsonSerializer.Serialize(data));

            savedArmies.RemoveAll(a => a.Name == name);
            savedArmies.Insert(0, new SavedArmyMeta
            {
                Name = name,
                Faction = army.Faction ?? "",
                Detachment = army.Detachment ?? "",
                Points = army.TotalPoints
            });
            await JS.InvokeVoidAsync("localStorage.setItem", "saved-armies-index", JsonSerializer.Serialize(savedArmies));
            armyIsSaved = true;
        }

        // Show checkmark on save button for 1.5s
        saveTick = true;
        StateHasChanged();
        saveTickCts?.Cancel();
        saveTickCts = new CancellationTokenSource();
        _ = DismissSaveTickAsync(saveTickCts.Token);
    }

    private async Task DismissSaveTickAsync(CancellationToken ct)
    {
        try
        {
            await Task.Delay(1500, ct);
            saveTick = false;
            StateHasChanged();
        }
        catch (TaskCanceledException) { }
    }

    private async Task LoadSavedArmy(string name)
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", $"saved-army:{name}");
            if (string.IsNullOrEmpty(json)) return;

            var data = JsonSerializer.Deserialize<SavedArmyData>(json);
            if (data is null) return;

            rawJson = data.RawJson;
            army = parser.Parse(rawJson);

            if (data.State is not null)
                ApplyState(data.State);

            abilityConfigs.Clear();
            foreach (var (k, v) in data.AbilityConfigs)
                abilityConfigs[k] = v;

            stratagemConfigs.Clear();
            foreach (var (k, v) in data.StratagemConfigs)
                stratagemConfigs[k] = v;

            InitAbilityConfigs();
            InitStratagemConfigs();

            setupConfirmed = true;
            stratagemSetupConfirmed = true;
            expandedUnits.Clear();
            stratHiddenUnits.Clear();
            killedUnits.Clear();
            playMode = false;
            errorMessage = null;
            armyIsSaved = true;

            await SaveToStorage();
            await SaveAbilityConfigs();
            await SaveStratagemConfigs();
        }
        catch { errorMessage = "Failed to load saved army."; }
    }

    private async Task DeleteSavedArmy(string name)
    {
        savedArmies.RemoveAll(a => a.Name == name);
        await JS.InvokeVoidAsync("localStorage.removeItem", $"saved-army:{name}");
        await JS.InvokeVoidAsync("localStorage.setItem", "saved-armies-index", JsonSerializer.Serialize(savedArmies));
    }

