    private string CardClass(UnitEntry unit)
    {
        var css = "";
        if (unit.IsLeader && unit.AttachedLeaders.Count == 0)
            css += " leader-card";
        if (unit.AttachedLeaders.Count > 0)
            css += " combined-card";
        if (IsCollapsed(unit))
            css += " collapsed";
        if (draggedUnit == unit)
            css += " dragging";
        if (dragOverUnit == unit && draggedUnit is not null && draggedUnit != unit)
            css += " drag-over";
        if (selectedLeader == unit)
            css += " selected";
        if (selectedLeader is not null && !unit.IsLeader && unit != selectedLeader)
            css += " attach-target";
        if (focusedUnit == unit)
            css += " focused-unit";
        if (movingUnit == unit)
            css += " moving";
        if (movingUnit is not null && movingUnit != unit)
            css += " move-target";
        if (IsKilled(unit))
            css += " killed";
        return css.TrimStart();
    }

