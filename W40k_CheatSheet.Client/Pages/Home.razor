@page "/"
@using W40k_CheatSheet.Client.Models
@using W40k_CheatSheet.Client.Services
@using System.Text.Json
@inject IJSRuntime JS
@inject CloudRosterService Cloud

<PageTitle>Segmentum Ultima</PageTitle>

<div class="roster-app @FactionClass">
    @* ── Top-left login toggle ── *@
    <div class="login-corner">
        @if (!Cloud.IsLoggedIn)
        {
            <span class="login-toggle" @onclick="() => loginExpanded = !loginExpanded">@(loginExpanded ? "✕" : "Login")</span>
            @if (loginExpanded)
            {
                <div class="login-dropdown">
                    <input type="email" placeholder="Email" @bind="cloudEmail" class="cloud-input" />
                    <input type="password" placeholder="Password" @bind="cloudPassword" class="cloud-input" />
                    <div class="cloud-auth-buttons">
                        <button class="cloud-btn login" @onclick="CloudLogin" disabled="@cloudBusy">Login</button>
                        <button class="cloud-btn register" @onclick="CloudRegister" disabled="@cloudBusy">Register</button>
                    </div>
                    @if (!string.IsNullOrEmpty(Cloud.ErrorMessage))
                    {
                        <div class="cloud-error">@Cloud.ErrorMessage</div>
                    }
                </div>
            }
        }
        else
        {
            <span class="login-toggle logged-in" @onclick="() => loginExpanded = !loginExpanded">@Cloud.Username</span>
            @if (loginExpanded)
            {
                <div class="login-dropdown">
                    <button class="cloud-btn logout" @onclick="CloudLogout">Logout</button>
                </div>
            }
        }
    </div>

    @if (!loaded)
    {
        <div class="import-section">
            <div class="welcome-card">
                <div class="welcome-overlay"></div>
                <div class="welcome-content">
                    <h1>There is only war ...</h1>
                    <p>Accessing libraries…</p>
                </div>
            </div>
        </div>
    }
    else if (army is null)
    {
        <div class="import-section">
            <div class="welcome-card">
                <div class="welcome-overlay"></div>
                <div class="welcome-content">
                    <h1>Segmentum Ultima</h1>
                    <p>Import your army roster JSON to view unit stats.</p>
                    <label class="import-btn">
                        <img src="images/import_button.PNG" alt="Import Roster (JSON)" />
                        <InputFile OnChange="HandleFileSelected" accept=".json" style="display:none" />
                    </label>
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="error-msg">@errorMessage</div>
                    }
                </div>
            </div>

            @* ── Cloud Armies (shown when logged in) ── *@
            @if (Cloud.IsLoggedIn && cloudRosters.Count > 0)
            {
                <div class="saved-armies">
                    <h3>☁️ Saved Armies</h3>
                    @foreach (var cr in cloudRosters)
                    {
                        <div class="saved-army-row">
                            <div class="saved-army-info" @onclick="() => LoadCloudArmy(cr.Id)">
                                <span class="saved-army-name">@cr.Name</span>
                                <span class="saved-army-meta">@cr.Faction · @cr.Detachment · @cr.Points pts</span>
                            </div>
                            <button class="saved-army-delete" @onclick="() => DeleteCloudArmy(cr.Id)" @onclick:stopPropagation="true">🗑</button>
                        </div>
                    }
                </div>
            }

            @* ── Local armies (only shown when NOT logged in) ── *@
            @if (!Cloud.IsLoggedIn && savedArmies.Count > 0)
            {
                <div class="saved-armies">
                    <h3>📦 Saved Armies (Local)</h3>
                    @foreach (var sa in savedArmies)
                    {
                        <div class="saved-army-row">
                            <div class="saved-army-info" @onclick="() => LoadSavedArmy(sa.Name)">
                                <span class="saved-army-name">@sa.Name</span>
                                <span class="saved-army-meta">@sa.Faction · @sa.Detachment · @sa.Points pts</span>
                            </div>
                            <button class="saved-army-delete" @onclick="() => DeleteSavedArmy(sa.Name)" @onclick:stopPropagation="true">🗑</button>
                        </div>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="corner-actions">
            <button class="corner-btn play @(playMode ? "active" : "")" @onclick="TogglePlayMode">@(playMode ? "☰" : "⚔")</button>
            @if (!playMode)
            {
                <button class="corner-btn save @(saveTick ? "tick" : "")" @onclick="SaveCurrentArmy">@(saveTick ? "✓" : "💾")</button>
            }
            <button class="corner-btn home" @onclick="ClearRoster">⌂</button>
        </div>

        <div id="roster-top" class="roster-header">
            <h1>@army.Name</h1>
            <div class="turn-buttons">
                <button class="turn-btn my-turn @(activeTurn == TurnFilter.MyTurn ? "active" : "")" @onclick="() => ToggleTurn(TurnFilter.MyTurn)">My turn</button>
                <button class="turn-btn enemy-turn @(activeTurn == TurnFilter.EnemyTurn ? "active" : "")" @onclick="() => ToggleTurn(TurnFilter.EnemyTurn)">Enemy turn</button>
            </div>
            <div class="phase-buttons">
                <button class="phase-btn @(activePhase == GamePhase.Command ? "active" : "")" @onclick="() => TogglePhase(GamePhase.Command)">Command</button>
                <button class="phase-btn @(activePhase == GamePhase.Move ? "active" : "")" @onclick="() => TogglePhase(GamePhase.Move)">Move</button>
                <button class="phase-btn @(activePhase == GamePhase.Shoot ? "active" : "")" @onclick="() => TogglePhase(GamePhase.Shoot)">Shoot</button>
                <button class="phase-btn @(activePhase == GamePhase.Charge ? "active" : "")" @onclick="() => TogglePhase(GamePhase.Charge)">Charge</button>
                <button class="phase-btn @(activePhase == GamePhase.Fight ? "active" : "")" @onclick="() => TogglePhase(GamePhase.Fight)">Fight</button>
            </div>
            @if (!string.IsNullOrEmpty(army.DetachmentRule) && !IsDetachmentRuleReflectedInStats)
            {
                <div class="detachment-rule">
                    <strong>@army.Detachment:</strong> @army.DetachmentRule
                </div>
            }
        </div>

        @if (playMode && !preGameDismissed)
        {
            var preGame = PreGameReminders;
            if (preGame.Count > 0)
            {
                <div class="pregame-banner">
                    <div class="pregame-banner-header">
                        <span>🏁 Pre-Game Reminders</span>
                        <button class="pregame-dismiss" @onclick="() => preGameDismissed = true">✓ Done</button>
                    </div>
                    @foreach (var (unit, label, desc) in preGame)
                    {
                        <div class="pregame-item">
                            <span class="pregame-unit">@unit.Name</span>
                            <span class="pregame-ability">@label</span>
                            @if (!string.IsNullOrEmpty(desc))
                            {
                                <span class="pregame-desc">@desc</span>
                            }
                        </div>
                    }
                </div>
            }
        }

        <div id="nav-top" class="unit-jump-buttons">
            @if (playMode)
            {
                <button class="unit-jump-btn toggle-all" @onclick="ToggleAllUnits">@(visiblePlayUnits.Count == AliveUnits.Count ? "⊘" : "✦")</button>
            }
            @foreach (var u in AliveUnits)
            {
                var btnUnit = u;
                <button class="unit-jump-btn @(playMode && visiblePlayUnits.Contains(btnUnit) ? "active" : "")" @onclick="() => HandleUnitButton(btnUnit)">@btnUnit.Name</button>
            }
        </div>

        @if (selectedLeader is not null)
        {
            <div class="attach-hint">
                Tap a unit to attach <strong>@selectedLeader.Name</strong> ·
                <span class="cancel-link" @onclick="CancelSelection">Cancel</span>
            </div>
        }

        @if (movingUnit is not null)
        {
            <div class="move-hint">
                Tap a unit to move <strong>@movingUnit.Name</strong> there ·
                <span class="cancel-link" @onclick="() => movingUnit = null">Cancel</span>
            </div>
        }

        @if (buffSourcePopup is var (bsLabel, bsSource, bsKwDesc) && bsLabel is not null)
        {
            <div class="buff-source-popup" @onclick="() => buffSourcePopup = null">
                <span class="buff-source-label">@bsLabel</span>
                <span class="buff-source-from">from @bsSource</span>
                @if (!string.IsNullOrEmpty(bsKwDesc))
                {
                    <div class="buff-source-kw-desc">@bsKwDesc</div>
                }
            </div>
        }

        @if (weaponRemovePopup is { } wrp)
        {
            var wrWeapons = GetMixedLoadoutWeapons(wrp.Unit, wrp.Delta);
            <div class="weapon-remove-popup" @onclick:stopPropagation="true">
                <div class="weapon-remove-title">@(wrp.Delta < 0 ? "Which model to remove?" : "Which model to restore?")</div>
                @foreach (var wrW in wrWeapons)
                {
                    var capturedW = wrW;
                    <div class="weapon-remove-option" @onclick="() => ConfirmWeaponModelRemoval(capturedW)">@capturedW.Name</div>
                }
                <div class="weapon-remove-cancel" @onclick="() => weaponRemovePopup = null">Cancel</div>
            </div>
        }

        <div class="unit-grid">
            @{
                bool killedDividerInserted = false;
            }
            @foreach (var unit in DisplayUnits)
            {
                if (playMode && !IsKilled(unit) && !visiblePlayUnits.Contains(unit)) { continue; }
                var stats = GetAllStatLines(unit);
                var ranged = GetAllRangedWeapons(unit);
                var melee = GetAllMeleeWeapons(unit);
                var allAbilities = GetAllAbilities(unit);
                var enhancements = GetAllEnhancements(unit)
                    .Where(e => !allAbilities.Any(a => a.Name.Equals(e, StringComparison.OrdinalIgnoreCase) && IsAddedToUnit(a)))
                    .ToList();
                var keywords = GetAllKeywords(unit);
                var extraRangedKw = GetExtraWeaponKeywords(unit, false);
                var extraMeleeKw = GetExtraWeaponKeywords(unit, true);
                var extraDef = GetExtraDefensiveAuras(unit);
                var extraUnitKw = GetExtraUnitKeywords(unit);
                var extraCritRanged = GetExtraCritModifier(unit, false);
                var extraCritMelee = GetExtraCritModifier(unit, true);
                var hitBonus = UnitHasDetachmentHitBonus(unit);
                var srcRangedKw = GetExtraWeaponKeywordsSource(unit, false);
                var srcMeleeKw = GetExtraWeaponKeywordsSource(unit, true);
                var srcCritRanged = GetExtraCritSource(unit, false);
                var srcCritMelee = GetExtraCritSource(unit, true);
                var srcHitBonus = GetHitBonusSource(unit);
                var srcDef = GetExtraDefensiveAuraSources(unit);
                var isWarlord = unit.IsWarlord || unit.AttachedLeaders.Any(l => l.IsWarlord);
                var abilityCount = GetCardAbilities(unit).Count;
                var alwaysActiveAbilities = playMode ? GetCardAlwaysActiveAbilities(unit) : new List<AbilityEntry>();
                var alwaysActiveStrats = playMode ? GetCardAlwaysActiveStratagems(unit) : new List<Stratagem>();
                List<Stratagem> headerStrats = playMode ? GetCardStratagems(unit) : [];
                var collapsed = IsCollapsed(unit);

                @if (playMode && !killedDividerInserted && IsKilled(unit))
                {
                    killedDividerInserted = true;
                    <div class="killed-divider">
                        <span class="killed-divider-text">☠ Destroyed</span>
                    </div>
                }

                <div id="@UnitAnchorId(unit.Name)" class="unit-card @CardClass(unit)"
                     draggable="true"
                     @ondragstart="() => DragStart(unit)"
                     @ondragend="DragEnd"
                     @ondragenter="() => DragEnter(unit)"
                     @ondragover:preventDefault
                     @ondrop="() => Drop(unit)">

                    <div class="unit-header @(collapsed ? "" : "expanded")"
                         @onclick="e => HandleHeaderClick(unit, e)"
                         @onpointerdown="() => HeaderPointerDown(unit)"
                         @onpointerup="HeaderPointerUp"
                         @onpointerleave="HeaderPointerUp"
                         @oncontextmenu:preventDefault>
                        <div class="unit-name">
                            @unit.Name
                            @if (isWarlord)
                            {
                                <span class="warlord-badge">⭐</span>
                            }
                            @{
                                var blueStrats = headerStrats.Where(s => s.TurnColor is StratagemTurn.Blue or StratagemTurn.BlueRed).ToList();
                                var redStrats = headerStrats.Where(s => s.TurnColor is StratagemTurn.Red or StratagemTurn.RedBlue).ToList();
                                var greenStrats = headerStrats.Where(s => s.TurnColor is StratagemTurn.Green).ToList();
                                var hasStrats = abilityCount > 0 || headerStrats.Count > 0 || alwaysActiveAbilities.Count > 0 || alwaysActiveStrats.Count > 0;
                            }
                            @if (hasStrats)
                            {
                                <span class="strat-toggle @(!stratHiddenUnits.Contains(unit) ? "expanded" : "")" @onclick="() => ToggleStratDots(unit)" @onclick:stopPropagation="true">@(!stratHiddenUnits.Contains(unit) ? "▾" : "▸")</span>
                            }
                        </div>
                        <div class="header-right">
                                <button class="move-handle" @onclick="() => StartMove(unit)" @onclick:stopPropagation="true">☰</button>
                            @if (!playMode)
                            {
                                <span class="collapse-icon">@(collapsed ? "▸" : "▾")</span>
                            }
                            @if (playMode && IsKilled(unit))
                            {
                                <button class="revive-btn" @onclick="() => ReviveUnit(unit)" @onclick:stopPropagation="true">↩</button>
                            }
                        </div>
                    </div>

                    @if (!stratHiddenUnits.Contains(unit) && (abilityCount > 0 || headerStrats.Count > 0 || alwaysActiveAbilities.Count > 0 || alwaysActiveStrats.Count > 0))
                    {
                        <div class="strat-expand" @onclick:stopPropagation="true">
                            <div class="strat-expand-main">
                            @if (abilityCount > 0)
                            {
                                <div class="strat-expand-list">
                                    @foreach (var a in GetCardAbilities(unit))
                                    {
                                        if (usedAbilities.Contains(a)) { continue; }
                                        <div class="strat-expand-entry @(focusedAbility == a ? "expanded" : "")">
                                            <span class="strat-expand-item strat-cell-ability" @onclick="() => ToggleFocusAbility(a)"
                                                  @onpointerdown="() => OnceAbilityPointerDown(a)"
                                                  @onpointerup="OncePointerUp" @onpointerleave="OncePointerUp"
                                                  @oncontextmenu:preventDefault>@a.Name</span>
                                            @if (focusedAbility == a)
                                            {
                                                <div class="strat-expand-desc">@a.Description</div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                            @{
                                var blueRedStrats = headerStrats.Where(s => s.TurnColor is StratagemTurn.Blue or StratagemTurn.BlueRed or StratagemTurn.Red or StratagemTurn.RedBlue).ToList();
                            }
                            @if (blueRedStrats.Count > 0)
                            {
                                @if (abilityCount > 0)
                                {
                                    <div class="strat-expand-divider"></div>
                                }
                                <div class="strat-expand-list">
                                    @foreach (var s in blueRedStrats)
                                    {
                                        if (usedStratagems.Contains(s)) { continue; }
                                        <div class="strat-expand-entry @(focusedStratagem == s && focusedStratagemUnit == unit ? (s.TurnColor is StratagemTurn.Blue or StratagemTurn.BlueRed ? "expanded-blue" : "expanded-red") : "")">
                                            <span class="strat-expand-item @(s.TurnColor is StratagemTurn.Blue or StratagemTurn.BlueRed ? "strat-cell-blue" : "strat-cell-red")" @onclick="() => ToggleCardStratagem(s, unit)"
                                                  @onpointerdown="() => OnceStratagemPointerDown(s)"
                                                  @onpointerup="OncePointerUp" @onpointerleave="OncePointerUp"
                                                  @oncontextmenu:preventDefault>@s.Name</span> <span class="strat-cost-inline">@s.Cost</span>
                                            @if (focusedStratagem == s && focusedStratagemUnit == unit)
                                            {
                                                <div class="strat-expand-desc">
                                                    <div>@s.Effect</div>
                                                    <div class="card-strat-field"><span class="card-strat-label">When:</span> @(!string.IsNullOrEmpty(s.FullWhen) ? s.FullWhen : s.When)</div>
                                                    <div class="card-strat-field"><span class="card-strat-label">Target:</span> @(!string.IsNullOrEmpty(s.FullTarget) ? s.FullTarget : s.Target)</div>
                                                    <div class="card-strat-field"><span class="card-strat-label">Effect:</span> @(!string.IsNullOrEmpty(s.FullEffect) ? s.FullEffect : s.Effect)</div>
                                                    @if (!string.IsNullOrEmpty(s.FullRestriction) || !string.IsNullOrEmpty(s.Restriction))
                                                    {
                                                        <div class="card-strat-field"><span class="card-strat-label restriction">Restriction:</span> @(!string.IsNullOrEmpty(s.FullRestriction) ? s.FullRestriction : s.Restriction)</div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                            @if (greenStrats.Count > 0)
                            {
                                @if (blueRedStrats.Count > 0 || abilityCount > 0)
                                {
                                    <div class="strat-expand-divider"></div>
                                }
                                <div class="strat-expand-list">
                                    @foreach (var g in greenStrats)
                                    {
                                        if (usedStratagems.Contains(g)) { continue; }
                                        <div class="strat-expand-entry @(focusedStratagem == g && focusedStratagemUnit == unit ? "expanded-green" : "")">
                                            <span class="strat-expand-item strat-cell-green" @onclick="() => ToggleCardStratagem(g, unit)"
                                                  @onpointerdown="() => OnceStratagemPointerDown(g)"
                                                  @onpointerup="OncePointerUp" @onpointerleave="OncePointerUp"
                                                  @oncontextmenu:preventDefault>@g.Name</span> <span class="strat-cost-inline">@g.Cost</span>
                                            @if (focusedStratagem == g && focusedStratagemUnit == unit)
                                            {
                                                <div class="strat-expand-desc">
                                                    <div>@g.Effect</div>
                                                    <div class="card-strat-field"><span class="card-strat-label">When:</span> @(!string.IsNullOrEmpty(g.FullWhen) ? g.FullWhen : g.When)</div>
                                                    <div class="card-strat-field"><span class="card-strat-label">Target:</span> @(!string.IsNullOrEmpty(g.FullTarget) ? g.FullTarget : g.Target)</div>
                                                    <div class="card-strat-field"><span class="card-strat-label">Effect:</span> @(!string.IsNullOrEmpty(g.FullEffect) ? g.FullEffect : g.Effect)</div>
                                                    @if (!string.IsNullOrEmpty(g.FullRestriction) || !string.IsNullOrEmpty(g.Restriction))
                                                    {
                                                        <div class="card-strat-field"><span class="card-strat-label restriction">Restriction:</span> @(!string.IsNullOrEmpty(g.FullRestriction) ? g.FullRestriction : g.Restriction)</div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                            </div>
                            @{
                                var hasRightContent = alwaysActiveAbilities.Count > 0 || alwaysActiveStrats.Count > 0;
                            }
                            @if (hasRightContent)
                            {
                                <div class="strat-expand-always">
                                    <div class="strat-expand-list">
                                        @foreach (var s in alwaysActiveStrats)
                                        {
                                            if (usedStratagems.Contains(s)) { continue; }
                                            var sColor = s.TurnColor is StratagemTurn.Blue or StratagemTurn.BlueRed ? "strat-cell-blue"
                                                       : s.TurnColor is StratagemTurn.Red or StratagemTurn.RedBlue ? "strat-cell-red"
                                                       : "strat-cell-green";
                                            var sExpCss = focusedStratagem == s && focusedStratagemUnit == unit
                                                ? (s.TurnColor is StratagemTurn.Blue or StratagemTurn.BlueRed ? "expanded-blue"
                                                   : s.TurnColor is StratagemTurn.Red or StratagemTurn.RedBlue ? "expanded-red"
                                                   : "expanded-green")
                                                : "";
                                            <div class="strat-expand-entry @sExpCss">
                                                <span class="strat-expand-item @sColor" @onclick="() => ToggleCardStratagem(s, unit)"
                                                      @onpointerdown="() => OnceStratagemPointerDown(s)"
                                                      @onpointerup="OncePointerUp" @onpointerleave="OncePointerUp"
                                                      @oncontextmenu:preventDefault>[@s.Name]</span> <span class="strat-cost-inline">@s.Cost</span>
                                                @if (focusedStratagem == s && focusedStratagemUnit == unit)
                                                {
                                                    <div class="strat-expand-desc">
                                                        <div>@s.Effect</div>
                                                        <div class="card-strat-field"><span class="card-strat-label">When:</span> @(!string.IsNullOrEmpty(s.FullWhen) ? s.FullWhen : s.When)</div>
                                                        <div class="card-strat-field"><span class="card-strat-label">Target:</span> @(!string.IsNullOrEmpty(s.FullTarget) ? s.FullTarget : s.Target)</div>
                                                        <div class="card-strat-field"><span class="card-strat-label">Effect:</span> @(!string.IsNullOrEmpty(s.FullEffect) ? s.FullEffect : s.Effect)</div>
                                                        @if (!string.IsNullOrEmpty(s.FullRestriction) || !string.IsNullOrEmpty(s.Restriction))
                                                        {
                                                            <div class="card-strat-field"><span class="card-strat-label restriction">Restriction:</span> @(!string.IsNullOrEmpty(s.FullRestriction) ? s.FullRestriction : s.Restriction)</div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                        @foreach (var aa in alwaysActiveAbilities)
                                        {
                                            if (usedAbilities.Contains(aa)) { continue; }
                                            <div class="strat-expand-entry @(focusedAbility == aa ? "expanded" : "")">
                                                <span class="strat-expand-item strat-cell-ability" @onclick="() => ToggleFocusAbility(aa)"
                                                      @onpointerdown="() => OnceAbilityPointerDown(aa)"
                                                      @onpointerup="OncePointerUp" @onpointerleave="OncePointerUp"
                                                      @oncontextmenu:preventDefault>[@aa.Name]</span>
                                                @if (focusedAbility == aa)
                                                {
                                                    <div class="strat-expand-desc">@aa.Description</div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    @foreach (var leader in unit.AttachedLeaders)
                    {
                        var leaderKeywordAbilities = leader.Abilities
                            .Where(a => IsAddedToUnit(a) && IsAddedToUnitVisible(a))
                            .Select(a => (Ability: a, Keyword: ParseLeaderUnitKeyword(a) ?? ParseBearerKeyword(a)))
                            .Where(x => x.Keyword is not null)
                            .ToList();
                        <div class="attached-leader @(IsKilled(leader) ? "killed" : "")">
                            <div class="attached-leader-info">
                                <span>+ @leader.Name @(leader.IsWarlord ? "⭐" : "")</span>
                                @if (leaderKeywordAbilities.Count > 0 && !IsKilled(leader))
                                {
                                    <div class="attached-leader-abilities" @onclick:stopPropagation="true">
                                        @foreach (var lk in leaderKeywordAbilities)
                                        {
                                            <span class="attached-leader-ability @(focusedAbility == lk.Ability ? "expanded" : "")" @onclick="() => ToggleFocusAbility(lk.Ability)">@lk.Keyword</span>
                                        }
                                    </div>
                                }
                            </div>
                            @if (playMode && !IsKilled(leader) && leader.ModelCount > 1)
                            {
                                <span class="model-counter" @onclick:stopPropagation="true">
                                    <button class="model-btn" @onclick="() => AdjustModelCount(leader, -1)">−</button>
                                    <span class="model-count @(GetModelCount(leader) < leader.ModelCount ? "model-reduced" : "")">@GetModelCount(leader)</span>
                                    <button class="model-btn" @onclick="() => AdjustModelCount(leader, 1)">+</button>
                                </span>
                            }
                            else if (playMode && !IsKilled(leader))
                            {
                                <button class="model-kill-btn" @onclick="() => AdjustModelCount(leader, -1)" @onclick:stopPropagation="true">☠</button>
                            }
                            else if (!playMode)
                            {
                                <button class="detach-btn" @onclick="() => DetachLeader(unit, leader)" @onclick:stopPropagation="true">✕</button>
                            }
                        </div>
                        @if (focusedAbility is not null && leaderKeywordAbilities.Any(lk => lk.Ability == focusedAbility))
                        {
                            <div class="attached-leader-ability-desc">@focusedAbility.Description</div>
                        }
                    }

                    @if (unit.AttachedLeaders.Count > 0)
                    {
                        <div class="attached-leader">
                            <div class="attached-leader-info">
                                <span>+ @unit.Name</span>
                            </div>
                            @if (playMode && !IsKilled(unit) && unit.ModelCount > 1)
                            {
                                <span class="model-counter" @onclick:stopPropagation="true">
                                    <button class="model-btn" @onclick="() => AdjustModelCount(unit, -1)">−</button>
                                    <span class="model-count @(GetModelCount(unit) < unit.ModelCount ? "model-reduced" : "")">@GetModelCount(unit)</span>
                                    <button class="model-btn" @onclick="() => AdjustModelCount(unit, 1)">+</button>
                                </span>
                            }
                            else if (playMode && !IsKilled(unit))
                            {
                                <button class="model-kill-btn" @onclick="() => AdjustModelCount(unit, -1)" @onclick:stopPropagation="true">☠</button>
                            }
                        </div>
                    }

                    @if (!collapsed)
                    {
                        <div class="unit-body">
                            @if (enhancements.Count > 0)
                            {
                                <div class="unit-enhancements" @onclick:stopPropagation="true">
                                    @foreach (var enh in enhancements)
                                    {
                                        var enhAbility = allAbilities.FirstOrDefault(a => a.Name.Equals(enh, StringComparison.OrdinalIgnoreCase));
                                        @if (enhAbility is not null)
                                        {
                                            <div class="enhancement-entry">
                                                <span class="enhancement clickable @(focusedAbility == enhAbility ? "expanded" : "")" @onclick="() => ToggleFocusAbility(enhAbility)">🔮 @enh</span>
                                                @if (focusedAbility == enhAbility)
                                                {
                                                    <div class="enhancement-desc">@enhAbility.Description</div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="enhancement">🔮 @enh</span>
                                        }
                                    }
                                </div>
                            }

                            @if (stats.Count > 0)
                            {
                                <div class="table-wrapper">
                                    <table class="stats-table">
                                        <thead>
                                            <tr>
                                                <th></th><th>M</th><th>T</th><th>SV</th><th>W</th><th>LD</th><th>OC</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var s in stats)
                                            {
                                                var effectiveInvuln = BetterFnp(s.InvulnSave, extraDef.ExtraInvuln);
                                                var effectiveFnp = BetterFnp(s.FeelNoPain, extraDef.ExtraFnp);
                                                var invulnIsExtra = !string.IsNullOrEmpty(extraDef.ExtraInvuln) && effectiveInvuln == extraDef.ExtraInvuln && string.IsNullOrEmpty(s.InvulnSave);
                                                var fnpIsExtra = !string.IsNullOrEmpty(extraDef.ExtraFnp) && effectiveFnp == extraDef.ExtraFnp && string.IsNullOrEmpty(s.FeelNoPain);
                                                <tr class="stat-row @(focusedStatOwner == s.Owner ? "focused" : "") @(focusedWeapon is not null ? "dimmed" : "")" @onclick="() => ToggleFocusStatOwner(s.Owner, unit)" @onclick:stopPropagation="true">
                                                    <td class="name-cell">
                                                        <span class="stat-name-text">@ShortStatName(s.Stat.Name)</span>
                                                        @if (!string.IsNullOrEmpty(effectiveInvuln) || !string.IsNullOrEmpty(effectiveFnp))
                                                        {
                                                            <span class="stat-saves">(
                                                                @if (invulnIsExtra)
                                                                {
                                                                    <span class="invuln-extra buff-source-trigger" @onclick="() => ShowBuffSource(effectiveInvuln, srcDef.InvulnSource, string.Empty)" @onclick:stopPropagation="true">@effectiveInvuln</span>
                                                                }
                                                                else if (!string.IsNullOrEmpty(effectiveInvuln))
                                                                {
                                                                    <span class="invuln">@effectiveInvuln</span>
                                                                }
                                                                @if (!string.IsNullOrEmpty(effectiveInvuln) && !string.IsNullOrEmpty(effectiveFnp))
                                                                {
                                                                    <text>, </text>
                                                                }
                                                                @if (fnpIsExtra)
                                                                {
                                                                    <span class="fnp-extra buff-source-trigger" @onclick="() => ShowBuffSource(effectiveFnp, srcDef.FnpSource, string.Empty)" @onclick:stopPropagation="true">@(effectiveFnp.Replace("+", "++"))</span>
                                                                }
                                                                else if (!string.IsNullOrEmpty(effectiveFnp))
                                                                {
                                                                    <span class="fnp">@(effectiveFnp.Replace("+", "++"))</span>
                                                                }
                                                                     )</span>
                                                                }
                                                                @if (playMode && s.Owner.ModelCount > 1)
                                                                {
                                                                    <span class="model-counter" @onclick:stopPropagation="true">
                                                                        <button class="model-btn" @onclick="() => AdjustModelCount(s.Owner, -1)">−</button>
                                                                        <span class="model-count @(GetModelCount(s.Owner) < s.Owner.ModelCount ? "model-reduced" : "")">@GetModelCount(s.Owner)</span>
                                                                        <button class="model-btn" @onclick="() => AdjustModelCount(s.Owner, 1)">+</button>
                                                                    </span>
                                                                }
                                                                else if (playMode)
                                                                {
                                                                    <button class="model-kill-btn" @onclick="() => AdjustModelCount(s.Owner, -1)" @onclick:stopPropagation="true">☠</button>
                                                                }
                                                            </td>
                                                    <td>@s.Stat.M</td><td>@s.Stat.T</td><td>@s.Stat.SV</td>
                                                    <td>@s.Stat.W</td><td>@s.Stat.LD</td><td>@s.Stat.OC</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }

                            @if (ranged.Count > 0)
                            {
                                var rangedExpanded = IsRangedExpanded(unit);
                                var hideRangedSection = focusedCard == unit && focusedStatOwner is not null && !ranged.Any(w => IsWeaponOwnedByFocused(w) && IsWeaponPhaseRelevant(true));
                                @if (!hideRangedSection)
                                {
                                <div class="table-wrapper">
                                    <table class="weapons-table">
                                        <thead class="weapon-section-header" @onclick="() => ToggleRangedSection(unit)" @onclick:stopPropagation="true">
                                            <tr><th>🎯 Ranged <span class="weapon-collapse-icon">@(rangedExpanded ? "▾" : "▸")</span></th><th>Rng</th><th>A</th><th>BS</th><th>S</th><th>AP</th><th>D</th></tr>
                                        </thead>
                                        @if (rangedExpanded)
                                        {
                                            <tbody>
                                                @foreach (var w in ranged)
                                                {
                                                    var rOwned = IsWeaponOwnedByFocused(w);
                                                    var rPhaseOk = IsWeaponPhaseRelevant(true);
                                                    var rHidden = (focusedCard == unit && focusedStatOwner is not null && !(rOwned && rPhaseOk)) || (focusedWeapon is not null && focusedWeapon != w);
                                                    if (rHidden) { continue; }
                                                    var rEffSkill = hitBonus ? ImproveSkill(w.Skill) : w.Skill;
                                                    var rSkillBoosted = hitBonus && rEffSkill != w.Skill;
                                                    var rModels = GetWeaponEffectiveModels(unit, w);
                                                    if (playMode && rModels <= 0) { continue; }
                                                    <tr class="weapon-row @(focusedWeapon == w || (focusedCard == unit && rOwned && rPhaseOk) ? "zoomed" : "")" @onclick="() => ToggleFocusWeapon(w)" @onclick:stopPropagation="true">
                                                        <td class="name-cell">@w.Name@if (playMode && rModels > 1){<span class="weapon-total-attacks @(rModels < w.ModelsEquipped ? "reduced" : "")">(@FormatTotalAttacks(rModels, w.A))</span>}</td>
                                                        <td>@ShortRange(w.Range)</td><td>@w.A</td><td>@if (rSkillBoosted){<span class="skill-improved buff-source-trigger" @onclick="() => ShowBuffSource(rEffSkill, srcHitBonus, string.Empty)" @onclick:stopPropagation="true">@rEffSkill</span>}else{@rEffSkill}@if (!string.IsNullOrEmpty(extraCritRanged)){<text> </text><span class="crit-extra buff-source-trigger" @onclick="() => ShowBuffSource(extraCritRanged, srcCritRanged, string.Empty)" @onclick:stopPropagation="true">(@extraCritRanged)</span>}</td>
                                                        <td>@w.S</td><td>@w.AP</td><td>@w.D</td>
                                                    </tr>
                                                    @if (!string.IsNullOrEmpty(CombineKeywords(w.Keywords, extraRangedKw)))
                                                    {
                                                        <tr class="weapon-kw-row @(focusedWeapon == w || (focusedCard == unit && rOwned && rPhaseOk) ? "zoomed" : "")">
                                                            <td colspan="7" class="kw-cell">@w.Keywords@if (!string.IsNullOrEmpty(w.Keywords) && !string.IsNullOrEmpty(extraRangedKw)){<text>, </text>}@if (!string.IsNullOrEmpty(extraRangedKw)){<span class="kw-extra buff-source-trigger" @onclick="() => ShowBuffSource(extraRangedKw, srcRangedKw.Source, srcRangedKw.KeywordDesc)" @onclick:stopPropagation="true">@extraRangedKw</span>}</td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                        }
                                    </table>
                                </div>
                                }
                            }

                            @if (melee.Count > 0)
                            {
                                var meleeExpanded = IsMeleeExpanded(unit);
                                var hideMeleeSection = focusedCard == unit && focusedStatOwner is not null && !melee.Any(w => IsWeaponOwnedByFocused(w) && IsWeaponPhaseRelevant(false));
                                @if (!hideMeleeSection)
                                {
                                <div class="table-wrapper">
                                    <table class="weapons-table">
                                        <thead class="weapon-section-header" @onclick="() => ToggleMeleeSection(unit)" @onclick:stopPropagation="true">
                                            <tr><th>⚔️ Melee <span class="weapon-collapse-icon">@(meleeExpanded ? "▾" : "▸")</span></th><th>Rng</th><th>A</th><th>WS</th><th>S</th><th>AP</th><th>D</th></tr>
                                        </thead>
                                        @if (meleeExpanded)
                                        {
                                            <tbody>
                                                @foreach (var w in melee)
                                                {
                                                    var mOwned = IsWeaponOwnedByFocused(w);
                                                    var mPhaseOk = IsWeaponPhaseRelevant(false);
                                                    var mHidden = (focusedCard == unit && focusedStatOwner is not null && !(mOwned && mPhaseOk)) || (focusedWeapon is not null && focusedWeapon != w);
                                                    if (mHidden) { continue; }
                                                    var mEffSkill = hitBonus ? ImproveSkill(w.Skill) : w.Skill;
                                                    var mSkillBoosted = hitBonus && mEffSkill != w.Skill;
                                                    var mModels = GetWeaponEffectiveModels(unit, w);
                                                    if (playMode && mModels <= 0) { continue; }
                                                    <tr class="weapon-row @(focusedWeapon == w || (focusedCard == unit && mOwned && mPhaseOk) ? "zoomed" : "")" @onclick="() => ToggleFocusWeapon(w)" @onclick:stopPropagation="true">
                                                        <td class="name-cell">@w.Name@if (playMode && mModels > 1){<span class="weapon-total-attacks @(mModels < w.ModelsEquipped ? "reduced" : "")">(@FormatTotalAttacks(mModels, w.A))</span>}</td>
                                                        <td>@ShortRange(w.Range)</td><td>@w.A</td><td>@if (mSkillBoosted){<span class="skill-improved buff-source-trigger" @onclick="() => ShowBuffSource(mEffSkill, srcHitBonus, string.Empty)" @onclick:stopPropagation="true">@mEffSkill</span>}else{@mEffSkill}@if (!string.IsNullOrEmpty(extraCritMelee)){<text> </text><span class="crit-extra buff-source-trigger" @onclick="() => ShowBuffSource(extraCritMelee, srcCritMelee, string.Empty)" @onclick:stopPropagation="true">(@extraCritMelee)</span>}</td>
                                                        <td>@w.S</td><td>@w.AP</td><td>@w.D</td>
                                                    </tr>
                                                    @if (!string.IsNullOrEmpty(CombineKeywords(w.Keywords, extraMeleeKw)))
                                                    {
                                                        <tr class="weapon-kw-row @(focusedWeapon == w || (focusedCard == unit && mOwned && mPhaseOk) ? "zoomed" : "")">
                                                            <td colspan="7" class="kw-cell">@w.Keywords@if (!string.IsNullOrEmpty(w.Keywords) && !string.IsNullOrEmpty(extraMeleeKw)){<text>, </text>}@if (!string.IsNullOrEmpty(extraMeleeKw)){<span class="kw-extra buff-source-trigger" @onclick="() => ShowBuffSource(extraMeleeKw, srcMeleeKw.Source, srcMeleeKw.KeywordDesc)" @onclick:stopPropagation="true">@extraMeleeKw</span>}</td>
                                                        </tr>
                                                    }
                                                }
                                            </tbody>
                                        }
                                    </table>
                                </div>
                                }
                            }

                            @if (keywords.Count > 0)
                            {
                                <div class="unit-keywords unit-keywords-inline">
                                    @foreach (var kw in keywords)
                                    {
                                        <span class="keyword">@kw</span>
                                    }
                                </div>
                            }

                            @if (focusedWeapon is not null && (ranged.Contains(focusedWeapon) || melee.Contains(focusedWeapon)))
                            {
                                var kwEntries = GetWeaponKeywordEntries(focusedWeapon);
                                if (kwEntries.Count > 0)
                                {
                                    <div class="card-abilities">
                                        @foreach (var kw in kwEntries)
                                        {
                                            <div class="card-ability-item">
                                                <span class="card-ability-name">@kw.Name</span>
                                                @if (!string.IsNullOrEmpty(kw.Description))
                                                {
                                                    <div class="card-ability-desc">@kw.Description</div>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            }

                            @if (unit.IsLeader && unit.AttachedLeaders.Count == 0)
                            {
                                <button class="attach-link" @onclick="() => StartAttach(unit)" @onclick:stopPropagation="true">
                                    🔗 Attach to unit
                                </button>
                            }

                            @if (!playMode && !string.IsNullOrEmpty(extraUnitKw))
                            {
                                var extraKwCss = "unit-extra-keywords" + (extraKwExpandedUnit == unit ? " expanded" : "");
                                <div class="@extraKwCss" @onclick="() => { extraKwExpandedUnit = extraKwExpandedUnit == unit ? null : unit; }" @onclick:stopPropagation="true">
                                    <span class="kw-extra">@extraUnitKw</span>
                                    @if (extraKwExpandedUnit == unit)
                                    {
                                        <div class="extra-kw-details">
                                            @foreach (var kwa in GetExtraUnitAbilities(unit))
                                            {
                                                <div class="extra-kw-item">
                                                    <span class="extra-kw-name">@kwa.Label</span>
                                                    <span class="extra-kw-desc">@kwa.Description</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }

                            @if (!playMode)
                            {
                                var cardAbilities = GetAllAbilities(unit).Where(a => !IsSetupOnlyAbility(a)).ToList();
                                @if (cardAbilities.Count > 0)
                                {
                                    <div class="card-abilities">
                                        @foreach (var ability in cardAbilities)
                                        {
                                            var aCfg = GetOrCreateConfig(ability);
                                            <div class="card-ability-item @(aCfg.AddToUnit == true ? "added-to-unit" : "") @(focusedAbility == ability ? "expanded" : "")"
                                                 @onclick="() => ToggleFocusAbility(ability)" @onclick:stopPropagation="true">
                                                <span class="card-ability-name">@ability.Name</span>
                                                <div class="card-ability-desc">@ability.Description</div>
                                                <div class="setup-checks" @onclick:stopPropagation="true">
                                                    <div class="setup-checks-row">
                                                        <label class="setup-lbl"><input type="checkbox" @bind="aCfg.MyTurn" @bind:after="SaveAbilityConfigs" /> My</label>
                                                        <label class="setup-lbl enemy"><input type="checkbox" @bind="aCfg.EnemyTurn" @bind:after="SaveAbilityConfigs" /> Enem</label>
                                                        <label class="setup-lbl unit-lbl"><input type="checkbox" @bind="aCfg.AddToUnit" @bind:after="() => OnAddToUnitChanged(aCfg)" /> Unit</label>
                                                    </div>
                                                    <div class="setup-checks-row">
                                                        <label class="setup-lbl"><input type="checkbox" @bind="aCfg.Command" @bind:after="SaveAbilityConfigs" /> Cmd</label>
                                                        <label class="setup-lbl"><input type="checkbox" @bind="aCfg.Move" @bind:after="SaveAbilityConfigs" /> Mov</label>
                                                        <label class="setup-lbl"><input type="checkbox" @bind="aCfg.Shoot" @bind:after="SaveAbilityConfigs" /> Sht</label>
                                                        <label class="setup-lbl"><input type="checkbox" @bind="aCfg.Charge" @bind:after="SaveAbilityConfigs" /> Chg</label>
                                                        <label class="setup-lbl"><input type="checkbox" @bind="aCfg.Fight" @bind:after="SaveAbilityConfigs" /> Fgt</label>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            }

                            <div class="card-footer-row">
                                @if (!playMode && keywords.Count > 0)
                                {
                                    <div class="unit-keywords">
                                        @foreach (var kw in keywords)
                                        {
                                            <span class="keyword">@kw</span>
                                        }
                                    </div>
                                }
                                <div class="card-nav-buttons">
                                    <button class="card-nav-btn" @onclick='() => ScrollToAsync("stratagems-panel")' @onclick:stopPropagation="true">S</button>
                                    <button class="card-nav-btn" @onclick='() => ScrollToAsync("abilities-panel")' @onclick:stopPropagation="true">A</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div id="stratagems-panel" class="stratagems-panel">
            <div class="stratagems-panel-header" @onclick="() => stratagemsPanelOpen = !stratagemsPanelOpen">
                <span>🎯 @(!playMode ? "Configure Stratagems" : "Stratagems Overview")</span>
                <span class="abilities-panel-controls">
                    @if (playMode)
                    {
                        <button class="show-all-btn @(showAllStratagems ? "active" : "")" @onclick="() => showAllStratagems = !showAllStratagems" @onclick:stopPropagation="true">@(showAllStratagems ? "Filter" : "Show all")</button>
                    }
                    <span class="collapse-icon">@(stratagemsPanelOpen ? "▾" : "▸")</span>
                </span>
            </div>
            @if (stratagemsPanelOpen)
            {
                <div class="stratagems-panel-body">
                    @if (!playMode)
                    {
                        @* ── Setup mode: all stratagems with config checkboxes ── *@
                        var sDetachment = army!.Detachment ?? "";
                        var allStrats = CoreStratagems.All
                            .Where(s => string.IsNullOrEmpty(s.Detachment) ||
                                        s.Detachment.Equals(sDetachment, StringComparison.OrdinalIgnoreCase))
                            .OrderBy(s => string.IsNullOrEmpty(s.Detachment) ? 0 : 1)
                            .ThenBy(s => s.Name)
                            .ToList();
                        @foreach (var strat in allStrats)
                        {
                            var sCfg = GetOrCreateStratConfig(strat);
                            <div class="strat-item @(sCfg.Disabled ? "strat-hidden" : "") @(focusedStratagem == strat ? "zoomed" : "")"
                                 @onclick="() => ToggleFocusStratagem(strat)" @onclick:stopPropagation="true">
                                <div class="strat-header @GetStratTurnClass(strat)">
                                    <span class="strat-name">@strat.Name <span class="strat-category-inline">@strat.Category</span></span>
                                    <span class="strat-cost">@strat.Cost</span>
                                </div>
                                @if (focusedStratagem == strat)
                                {
                                    <div class="strat-details" @onclick:stopPropagation="true">
                                        <div class="strat-field"><span class="strat-label">When:</span> @(!string.IsNullOrEmpty(strat.FullWhen) ? strat.FullWhen : strat.When)</div>
                                        <div class="strat-field"><span class="strat-label">Target:</span> @(!string.IsNullOrEmpty(strat.FullTarget) ? strat.FullTarget : strat.Target)</div>
                                        <div class="strat-field"><span class="strat-label">Effect:</span> @(!string.IsNullOrEmpty(strat.FullEffect) ? strat.FullEffect : strat.Effect)</div>
                                        @if (!string.IsNullOrEmpty(strat.FullRestriction) || !string.IsNullOrEmpty(strat.Restriction))
                                        {
                                            <div class="strat-field"><span class="strat-label restriction">Restriction:</span> @(!string.IsNullOrEmpty(strat.FullRestriction) ? strat.FullRestriction : strat.Restriction)</div>
                                        }
                                    </div>
                                }
                                <div class="setup-checks" @onclick:stopPropagation="true">
                                    <div class="setup-checks-row">
                                        <label class="setup-lbl"><input type="checkbox" @bind="sCfg.MyTurn" @bind:after="SaveStratagemConfigs" /> My</label>
                                        <label class="setup-lbl enemy"><input type="checkbox" @bind="sCfg.EnemyTurn" @bind:after="SaveStratagemConfigs" /> Enem</label>
                                        <label class="setup-lbl disable"><input type="checkbox" @bind="sCfg.Disabled" @bind:after="SaveStratagemConfigs" /> Disable</label>
                                    </div>
                                    <div class="setup-checks-row">
                                        <label class="setup-lbl"><input type="checkbox" @bind="sCfg.Command" @bind:after="SaveStratagemConfigs" /> Cmd</label>
                                        <label class="setup-lbl"><input type="checkbox" @bind="sCfg.Move" @bind:after="SaveStratagemConfigs" /> Mov</label>
                                        <label class="setup-lbl"><input type="checkbox" @bind="sCfg.Shoot" @bind:after="SaveStratagemConfigs" /> Sht</label>
                                        <label class="setup-lbl"><input type="checkbox" @bind="sCfg.Charge" @bind:after="SaveStratagemConfigs" /> Chg</label>
                                        <label class="setup-lbl"><input type="checkbox" @bind="sCfg.Fight" @bind:after="SaveStratagemConfigs" /> Fgt</label>
                                    </div>
                                    @if (sCfg.Command || sCfg.Move || sCfg.Shoot || sCfg.Charge || sCfg.Fight)
                                    {
                                        <div class="setup-checks-row">
                                            @if (sCfg.Command){<label class="setup-lbl enemy"><input type="checkbox" @bind="sCfg.EnemyCommand" @bind:after="SaveStratagemConfigs" /> eCmd</label>}
                                            @if (sCfg.Move){<label class="setup-lbl enemy"><input type="checkbox" @bind="sCfg.EnemyMove" @bind:after="SaveStratagemConfigs" /> eMov</label>}
                                            @if (sCfg.Shoot){<label class="setup-lbl enemy"><input type="checkbox" @bind="sCfg.EnemyShoot" @bind:after="SaveStratagemConfigs" /> eSht</label>}
                                            @if (sCfg.Charge){<label class="setup-lbl enemy"><input type="checkbox" @bind="sCfg.EnemyCharge" @bind:after="SaveStratagemConfigs" /> eChg</label>}
                                            @if (sCfg.Fight){<label class="setup-lbl enemy"><input type="checkbox" @bind="sCfg.EnemyFight" @bind:after="SaveStratagemConfigs" /> eFgt</label>}
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                    @foreach (var strat in FilteredStratagems)
                    {
                        var canUse = CanFocusedUnitUse(strat);
                        if (HasUnitFocus && !canUse) { continue; }
                        var stUsed = usedStratagems.Contains(strat);
                        <div class="strat-item @(focusedStratagem == strat ? "zoomed" : "") @(stUsed ? "once-used" : "")"
                             @onclick="() => ToggleFocusStratagem(strat)" @onclick:stopPropagation="true"
                             @onpointerdown="() => OnceStratagemPointerDown(strat)"
                             @onpointerup="OncePointerUp" @onpointerleave="OncePointerUp"
                             @oncontextmenu:preventDefault>
                            <div class="strat-header @GetStratTurnClass(strat)">
                                <span class="strat-name">@strat.Name <span class="strat-category-inline">@strat.Category</span></span>
                                <span class="strat-cost">@strat.Cost</span>
                            </div>
                            @if (focusedStratagem == strat)
                            {
                                <div class="strat-details @(stratDetailsZoomed ? "zoomed" : "")" @onclick="() => stratDetailsZoomed = !stratDetailsZoomed" @onclick:stopPropagation="true">
                                    <div class="strat-field"><span class="strat-label">When:</span> @(!string.IsNullOrEmpty(strat.FullWhen) ? strat.FullWhen : strat.When)</div>
                                    <div class="strat-field"><span class="strat-label">Target:</span> @(!string.IsNullOrEmpty(strat.FullTarget) ? strat.FullTarget : strat.Target)</div>
                                    <div class="strat-field"><span class="strat-label">Effect:</span> @(!string.IsNullOrEmpty(strat.FullEffect) ? strat.FullEffect : strat.Effect)</div>
                                    @if (!string.IsNullOrEmpty(strat.FullRestriction) || !string.IsNullOrEmpty(strat.Restriction))
                                    {
                                        <div class="strat-field"><span class="strat-label restriction">Restriction:</span> @(!string.IsNullOrEmpty(strat.FullRestriction) ? strat.FullRestriction : strat.Restriction)</div>
                                    }
                                </div>
                            }
                            @if (strat.RequiredKeywords.Count > 0 && focusedStratagem != strat)
                            {
                                <div class="strat-keywords">
                                    @foreach (var kw in strat.RequiredKeywords)
                                    {
                                        <span class="strat-kw-badge">@kw.ToUpperInvariant()</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                    }
                </div>
            }
        </div>

        <div id="abilities-panel" class="abilities-panel">
            <div class="abilities-panel-header" @onclick="() => abilitiesPanelOpen = !abilitiesPanelOpen">
                <span>📜 @(!playMode ? "Configure Abilities" : "Abilities Overview")</span>
                <span class="abilities-panel-controls">
                    @if (playMode)
                    {
                        <button class="show-all-btn @(showAllAbilities ? "active" : "")" @onclick="() => showAllAbilities = !showAllAbilities" @onclick:stopPropagation="true">@(showAllAbilities ? "Filter" : "Show all")</button>
                    }
                    <span class="collapse-icon">@(abilitiesPanelOpen ? "▾" : "▸")</span>
                </span>
            </div>
            @if (abilitiesPanelOpen)
            {
                <div class="abilities-panel-body">
                    @if (!playMode)
                    {
                        @* ── Setup mode: all abilities by unit with config checkboxes ── *@
                        @foreach (var sUnit in army!.Units)
                        {
                            var setupAbilities = sUnit.Abilities.Where(a => !IsSetupOnlyAbility(a)).ToList();
                            @if (setupAbilities.Count > 0)
                            {
                                <div class="abilities-panel-unit">
                                    <div class="abilities-panel-unit-name">@sUnit.Name@(sUnit.IsLeader ? " (Leader)" : "")</div>
                                    @foreach (var ability in setupAbilities)
                                    {
                                        var cfg = GetOrCreateConfig(ability);
                                        <div class="abilities-panel-item @(cfg.AddToUnit ? "added-to-unit" : "") @(focusedAbility == ability ? "expanded" : "")"
                                             @onclick="() => ToggleFocusAbility(ability)" @onclick:stopPropagation="true">
                                            <span class="ability-name">@ability.Name</span>
                                            <div class="ability-desc">@ability.Description</div>
                                            <div class="setup-checks" @onclick:stopPropagation="true">
                                                <div class="setup-checks-row">
                                                    <label class="setup-lbl"><input type="checkbox" @bind="cfg.MyTurn" @bind:after="SaveAbilityConfigs" /> My</label>
                                                    <label class="setup-lbl enemy"><input type="checkbox" @bind="cfg.EnemyTurn" @bind:after="SaveAbilityConfigs" /> Enem</label>
                                                    <label class="setup-lbl unit-lbl"><input type="checkbox" @bind="cfg.AddToUnit" @bind:after="() => OnAddToUnitChanged(cfg)" /> Unit</label>
                                                </div>
                                                <div class="setup-checks-row">
                                                    <label class="setup-lbl"><input type="checkbox" @bind="cfg.Command" @bind:after="SaveAbilityConfigs" /> Cmd</label>
                                                    <label class="setup-lbl"><input type="checkbox" @bind="cfg.Move" @bind:after="SaveAbilityConfigs" /> Mov</label>
                                                    <label class="setup-lbl"><input type="checkbox" @bind="cfg.Shoot" @bind:after="SaveAbilityConfigs" /> Sht</label>
                                                    <label class="setup-lbl"><input type="checkbox" @bind="cfg.Charge" @bind:after="SaveAbilityConfigs" /> Chg</label>
                                                    <label class="setup-lbl"><input type="checkbox" @bind="cfg.Fight" @bind:after="SaveAbilityConfigs" /> Fgt</label>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    }
                    else
                    {
                    @* ── Phase-specific abilities (1-3 phases checked) ── *@
                    @foreach (var entry in PanelUnits)
                    {
                        var isOtherFocused = (focusedStatOwner is not null && focusedCard != entry.Unit) ||
                                             (focusedUnit is not null && focusedUnit != entry.Unit);
                        if (isOtherFocused) { continue; }

                        var phaseAbilities = entry.Abilities.Where(a => HasPhasesConfigured(a) && !IsAlwaysActive(a));
                        if (!showAllAbilities)
                        {
                            phaseAbilities = phaseAbilities.Where(a => !IsHiddenAbility(a));
                            if (activePhase is not null)
                                phaseAbilities = phaseAbilities.Where(a => IsConfiguredForPhase(a, activePhase.Value));
                            if (activeTurn is not null)
                                phaseAbilities = phaseAbilities.Where(a => IsConfiguredForTurn(a, activeTurn.Value));
                        }

                        var phaseList = phaseAbilities.ToList();
                        if (phaseList.Count == 0) { continue; }

                        <div class="abilities-panel-unit">
                            <div class="abilities-panel-unit-name">@entry.Unit.Name</div>
                            @foreach (var ability in phaseList)
                            {
                                var pUsed = usedAbilities.Contains(ability);
                                <div class="abilities-panel-item @(focusedAbility == ability ? "expanded" : "") @(pUsed ? "once-used" : "")"
                                     @onclick="() => ToggleFocusAbility(ability)" @onclick:stopPropagation="true"
                                     @onpointerdown="() => OnceAbilityPointerDown(ability)"
                                     @onpointerup="OncePointerUp" @onpointerleave="OncePointerUp"
                                     @oncontextmenu:preventDefault>
                                    <span class="ability-name">@ability.Name</span>
                                    <div class="ability-desc">@ability.Description</div>
                                </div>
                            }
                        </div>
                    }

                    @* ── Always active abilities (≥ 4 phases checked — phase filter skipped) ── *@
                    bool hasAlwaysActive = PanelUnits.Any(e =>
                    {
                        if ((focusedStatOwner is not null && focusedCard != e.Unit) ||
                            (focusedUnit is not null && focusedUnit != e.Unit)) return false;
                        var aa = e.Abilities.Where(a => IsAlwaysActive(a));
                        if (!showAllAbilities)
                        {
                            aa = aa.Where(a => !IsHiddenAbility(a));
                            if (activeTurn is not null)
                                aa = aa.Where(a => IsConfiguredForTurn(a, activeTurn.Value));
                        }
                        return aa.Any();
                    });
                    @if (hasAlwaysActive)
                    {
                        <div class="abilities-panel-divider-row">
                            <span class="abilities-panel-divider-text always-active">Always active</span>
                        </div>
                        @foreach (var entry in PanelUnits)
                        {
                            var isOtherFocused3 = (focusedStatOwner is not null && focusedCard != entry.Unit) ||
                                                  (focusedUnit is not null && focusedUnit != entry.Unit);
                            if (isOtherFocused3) { continue; }

                            var aaAbilities = entry.Abilities.Where(a => IsAlwaysActive(a));
                            if (!showAllAbilities)
                            {
                                aaAbilities = aaAbilities.Where(a => !IsHiddenAbility(a));
                                if (activeTurn is not null)
                                    aaAbilities = aaAbilities.Where(a => IsConfiguredForTurn(a, activeTurn.Value));
                            }

                            var aaList = aaAbilities.ToList();
                            if (aaList.Count == 0) { continue; }

                            <div class="abilities-panel-unit">
                                <div class="abilities-panel-unit-name">@entry.Unit.Name</div>
                                @foreach (var ability in aaList)
                                {
                                    var aaUsed = usedAbilities.Contains(ability);
                                    <div class="abilities-panel-item @(focusedAbility == ability ? "expanded" : "") @(aaUsed ? "once-used" : "")"
                                         @onclick="() => ToggleFocusAbility(ability)" @onclick:stopPropagation="true"
                                         @onpointerdown="() => OnceAbilityPointerDown(ability)"
                                         @onpointerup="OncePointerUp" @onpointerleave="OncePointerUp"
                                         @oncontextmenu:preventDefault>
                                        <span class="ability-name">@ability.Name</span>
                                        <div class="ability-desc">@ability.Description</div>
                                    </div>
                                }
                            </div>
                        }
                    }

                    @* ── General abilities (no phases configured) ── *@
                    bool hasGeneral = PanelUnits.Any(e =>
                    {
                        if ((focusedStatOwner is not null && focusedCard != e.Unit) ||
                            (focusedUnit is not null && focusedUnit != e.Unit)) return false;
                        var g = e.Abilities.Where(a => !HasPhasesConfigured(a));
                        if (!showAllAbilities)
                        {
                            g = g.Where(a => !IsHiddenAbility(a));
                            if (activeTurn is not null)
                                g = g.Where(a => IsConfiguredForTurn(a, activeTurn.Value));
                        }
                        return g.Any();
                    });
                    @if (hasGeneral)
                    {
                        <div class="abilities-panel-divider-row">
                            <span class="abilities-panel-divider-text">General</span>
                        </div>
                        @foreach (var entry in PanelUnits)
                        {
                            var isOtherFocused2 = (focusedStatOwner is not null && focusedCard != entry.Unit) ||
                                                  (focusedUnit is not null && focusedUnit != entry.Unit);
                            if (isOtherFocused2) { continue; }

                            var genAbilities = entry.Abilities.Where(a => !HasPhasesConfigured(a));
                            if (!showAllAbilities)
                            {
                                genAbilities = genAbilities.Where(a => !IsHiddenAbility(a));
                                if (activeTurn is not null)
                                    genAbilities = genAbilities.Where(a => IsConfiguredForTurn(a, activeTurn.Value));
                                genAbilities = genAbilities.Where(a => !IsStatReflectedAbility(a, entry.Unit));
                            }

                            var genList = genAbilities.ToList();
                            if (genList.Count == 0) { continue; }

                            <div class="abilities-panel-unit">
                                <div class="abilities-panel-unit-name">@entry.Unit.Name</div>
                                @foreach (var ability in genList)
                                {
                                    var gUsed = usedAbilities.Contains(ability);
                                    <div class="abilities-panel-item @(focusedAbility == ability ? "expanded" : "") @(gUsed ? "once-used" : "")"
                                         @onclick="() => ToggleFocusAbility(ability)" @onclick:stopPropagation="true"
                                         @onpointerdown="() => OnceAbilityPointerDown(ability)"
                                         @onpointerup="OncePointerUp" @onpointerleave="OncePointerUp"
                                         @oncontextmenu:preventDefault>
                                        <span class="ability-name">@ability.Name</span>
                                        <div class="ability-desc">@ability.Description</div>
                                    </div>
                                }
                            </div>
                        }
                    }
                    }

                </div>
            }
        </div>

        <div id="nav-bottom" class="unit-jump-buttons">
            @if (playMode)
            {
                <button class="unit-jump-btn toggle-all" @onclick="ToggleAllUnits">@(visiblePlayUnits.Count == AliveUnits.Count ? "⊘" : "✦")</button>
            }
            @foreach (var u in AliveUnits)
            {
                var btnUnit2 = u;
                <button class="unit-jump-btn @(playMode && visiblePlayUnits.Contains(btnUnit2) ? "active" : "")" @onclick="() => HandleUnitButton(btnUnit2)">@btnUnit2.Name</button>
            }
        </div>

        @if (playMode)
        {
        <hr class="footer-divider" />

        <div class="score-tracker">
            <div class="score-total-row">
                <span class="score-total">@(defenderPrimary + defenderSecondary)</span>
                <span class="score-total-label">Total</span>
                <span class="score-total">@(aggressorPrimary + aggressorSecondary)</span>
            </div>
            <div class="score-section">
                <div class="score-section-label">Primary</div>
                <div class="score-row">
                    <div class="score-player">
                        <div class="score-label">🛡️ Defender</div>
                        <div class="score-controls">
                            <button class="score-btn" @onclick="() => defenderPrimary = Math.Max(0, defenderPrimary - 1)">−</button>
                            <span class="score-value">@defenderPrimary</span>
                            <button class="score-btn" @onclick="() => defenderPrimary++">+</button>
                        </div>
                    </div>
                    <div class="score-divider"></div>
                    <div class="score-player">
                        <div class="score-label">⚔️ Aggressor</div>
                        <div class="score-controls">
                            <button class="score-btn" @onclick="() => aggressorPrimary = Math.Max(0, aggressorPrimary - 1)">−</button>
                            <span class="score-value">@aggressorPrimary</span>
                            <button class="score-btn" @onclick="() => aggressorPrimary++">+</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="score-section">
                <div class="score-section-label">Secondary</div>
                <div class="score-row">
                    <div class="score-player">
                        <div class="score-controls">
                            <button class="score-btn" @onclick="() => defenderSecondary = Math.Max(0, defenderSecondary - 1)">−</button>
                            <span class="score-value">@defenderSecondary</span>
                            <button class="score-btn" @onclick="() => defenderSecondary++">+</button>
                        </div>
                    </div>
                    <div class="score-divider"></div>
                    <div class="score-player">
                        <div class="score-controls">
                            <button class="score-btn" @onclick="() => aggressorSecondary = Math.Max(0, aggressorSecondary - 1)">−</button>
                            <span class="score-value">@aggressorSecondary</span>
                            <button class="score-btn" @onclick="() => aggressorSecondary++">+</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        }

