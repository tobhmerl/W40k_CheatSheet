    private static List<(string Name, string Description)> GetWeaponKeywordEntries(WeaponProfile weapon)
    {
        if (string.IsNullOrWhiteSpace(weapon.Keywords))
            return [];

        var entries = new List<(string Name, string Description)>();
        foreach (var raw in weapon.Keywords.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries))
        {
            var desc = "";
            if (WeaponKeywordDescriptions.TryGetValue(raw, out var exact))
            {
                desc = exact;
            }
            else
            {
                foreach (var (key, value) in WeaponKeywordDescriptions)
                {
                    if (raw.StartsWith(key, StringComparison.OrdinalIgnoreCase))
                    {
                        desc = value;
                        break;
                    }
                }
            }
            entries.Add((raw, desc));
        }
        return entries;
    }

    private (string ExtraInvuln, string ExtraFnp) GetExtraDefensiveAuras(UnitEntry unit)
    {
        string invuln = "";
        string fnp = "";
        foreach (var leader in unit.AttachedLeaders)
        {
            if (IsKilled(leader)) continue;
            foreach (var ability in leader.Abilities)
            {
                if (!IsAddedToUnit(ability)) continue;
                if (!IsAddedToUnitVisible(ability)) continue;
                var parsed = ParseLeaderDefensiveAura(ability);
                if (parsed is null) continue;
                var (type, value) = parsed.Value;
                if (type == DefensiveAuraType.Invulnerable)
                    invuln = BetterFnp(invuln, value);
                else
                    fnp = BetterFnp(fnp, value);
            }
        }
        return (invuln, fnp);
    }

    // ≥ 4 phases checked → "always active" group (shown regardless of phase filter)
    private bool IsAlwaysActive(AbilityEntry a)
    {
        if (!abilityConfigs.TryGetValue(AbilityKey(a), out var c)) return false;
        int count = (c.Command ? 1 : 0) + (c.Move ? 1 : 0) + (c.Shoot ? 1 : 0)
                  + (c.Charge ? 1 : 0) + (c.Fight ? 1 : 0);
        return count >= 4;
    }

    private bool IsStratAlwaysActive(Stratagem s)
    {
        if (!stratagemConfigs.TryGetValue(s.Name, out var c)) return false;
        if (!c.MyTurn || !c.EnemyTurn) return false;
        int count = (c.Command ? 1 : 0) + (c.Move ? 1 : 0) + (c.Shoot ? 1 : 0)
                  + (c.Charge ? 1 : 0) + (c.Fight ? 1 : 0);
        return count >= 4;
    }

    private bool IsConfiguredForTurn(AbilityEntry a, TurnFilter turn) =>
        !abilityConfigs.TryGetValue(AbilityKey(a), out var c) ||
        (turn == TurnFilter.MyTurn ? c.MyTurn : c.EnemyTurn);

    private bool IsConfiguredForPhase(AbilityEntry a, GamePhase phase)
    {
        if (!abilityConfigs.TryGetValue(AbilityKey(a), out var c)) return true;
        return phase switch
        {
            GamePhase.Command => c.Command,
            GamePhase.Move    => c.Move,
            GamePhase.Shoot   => c.Shoot,
            GamePhase.Charge  => c.Charge,
            GamePhase.Fight   => c.Fight,
            _                 => true
        };
    }

    private void InitAbilityConfigs()
    {
        if (army is null) return;
        foreach (var unit in army.Units)
        {
            foreach (var ability in unit.Abilities)
            {
                var key = AbilityKey(ability);
                if (abilityConfigs.ContainsKey(key)) continue;
                abilityConfigs[key] = new AbilitySetupEntry();
            }
        }
    }

    private async Task SaveAbilityConfigs()
    {
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "ability-configs",
                JsonSerializer.Serialize(abilityConfigs));
        }
        catch { }
    }

