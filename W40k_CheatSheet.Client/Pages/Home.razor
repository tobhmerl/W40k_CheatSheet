    // Check if an "added to unit" ability is visible given current turn/phase filters
    private bool IsAddedToUnitVisible(AbilityEntry a)
    {
        if (IsHiddenAbility(a)) return false;
        if (activeTurn is not null && !IsConfiguredForTurn(a, activeTurn.Value)) return false;
        if (activePhase is not null && !IsAlwaysActive(a) && !IsConfiguredForPhase(a, activePhase.Value)) return false;
        return true;
    }

    private enum WeaponTarget { Both, Ranged, Melee }

    private static (string Keyword, WeaponTarget Target)? ParseLeaderWeaponAbility(AbilityEntry a)
    {
        var desc = a.Description;
        if (!desc.Contains("while this model is leading", StringComparison.OrdinalIgnoreCase) &&
            !desc.Contains("while leading", StringComparison.OrdinalIgnoreCase))
            return null;

        var kwMatch = System.Text.RegularExpressions.Regex.Match(desc, @"\[([A-Z][A-Z\s\d\+]+)\]");
        if (!kwMatch.Success) return null;

        var keyword = kwMatch.Groups[1].Value.Trim();
        var target = WeaponTarget.Both;
        if (desc.Contains("melee weapons", StringComparison.OrdinalIgnoreCase))
            target = WeaponTarget.Melee;
        else if (desc.Contains("ranged weapons", StringComparison.OrdinalIgnoreCase))
            target = WeaponTarget.Ranged;

        return (keyword, target);
    }

    private enum DefensiveAuraType { Invulnerable, FeelNoPain }

    private static (DefensiveAuraType Type, string Value)? ParseLeaderDefensiveAura(AbilityEntry a)
    {
        var desc = a.Description;
        if (!desc.Contains("while this model is leading", StringComparison.OrdinalIgnoreCase) &&
            !desc.Contains("while leading", StringComparison.OrdinalIgnoreCase))
            return null;

        var invulnMatch = System.Text.RegularExpressions.Regex.Match(desc, @"(\d)\+\s*invulnerable\s+save", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (invulnMatch.Success)
            return (DefensiveAuraType.Invulnerable, invulnMatch.Groups[1].Value + "+");

        var fnpMatch = System.Text.RegularExpressions.Regex.Match(desc, @"feel\s+no\s+pain\s+(\d)\+", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (fnpMatch.Success)
            return (DefensiveAuraType.FeelNoPain, fnpMatch.Groups[1].Value + "+");

        return null;
    }

    private static bool IsLeaderAuraDescription(string desc) =>
        desc.Contains("while this model is leading", StringComparison.OrdinalIgnoreCase) ||
        desc.Contains("while leading", StringComparison.OrdinalIgnoreCase) ||
        desc.Contains("while the bearer is leading", StringComparison.OrdinalIgnoreCase) ||
        desc.Contains("is leading this unit", StringComparison.OrdinalIgnoreCase);

    private static string? ParseBearerKeyword(AbilityEntry a)
    {
        var desc = a.Description;
        if (IsLeaderAuraDescription(desc)) return null;
        var match = System.Text.RegularExpressions.Regex.Match(desc,
            @"(?:bearer|model|unit)\s+has\s+the\s+(\w+(?:\s\w+)*?)\s+ability",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (match.Success)
            return match.Groups[1].Value.Trim().ToUpperInvariant();
        return null;
    }

    private static bool CanAddToUnit(AbilityEntry a) =>
        ParseLeaderWeaponAbility(a) is not null || ParseLeaderDefensiveAura(a) is not null || ParseLeaderUnitKeyword(a) is not null || ParseLeaderCritModifier(a) is not null || ParseBearerKeyword(a) is not null || IsLeaderAuraDescription(a.Description);

    private static (string Threshold, WeaponTarget Target)? ParseLeaderCritModifier(AbilityEntry a)
    {
        var desc = a.Description;
        if (!desc.Contains("while this model is leading", StringComparison.OrdinalIgnoreCase) &&
            !desc.Contains("while leading", StringComparison.OrdinalIgnoreCase) &&
            !desc.Contains("while the bearer is leading", StringComparison.OrdinalIgnoreCase))
            return null;

        var match = System.Text.RegularExpressions.Regex.Match(desc,
            @"(?:Hit\s+roll\s+of\s+|scores?\s+a\s+Critical\s+Hit\s+on\s+a?\s*)(\d)\+.*?Critical\s+Hit|Critical\s+Hit.*?(?:Hit\s+roll\s+of\s+|on\s+a?\s*)(\d)\+",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (!match.Success) return null;

        var threshold = (match.Groups[1].Success ? match.Groups[1].Value : match.Groups[2].Value) + "+";

        var target = WeaponTarget.Both;
        if (desc.Contains("melee attack", StringComparison.OrdinalIgnoreCase) ||
            desc.Contains("melee weapon", StringComparison.OrdinalIgnoreCase))
            target = WeaponTarget.Melee;
        else if (desc.Contains("ranged attack", StringComparison.OrdinalIgnoreCase) ||
                 desc.Contains("ranged weapon", StringComparison.OrdinalIgnoreCase))
            target = WeaponTarget.Ranged;

        return (threshold, target);
    }

    private string GetExtraCritModifier(UnitEntry unit, bool isMelee)
    {
        foreach (var leader in unit.AttachedLeaders)
        {
            if (IsKilled(leader)) continue;
            foreach (var ability in leader.Abilities)
            {
                if (!IsAddedToUnit(ability)) continue;
                if (!IsAddedToUnitVisible(ability)) continue;
                var parsed = ParseLeaderCritModifier(ability);
                if (parsed is null) continue;
                var (threshold, target) = parsed.Value;
                if (target == WeaponTarget.Both ||
                    (target == WeaponTarget.Melee && isMelee) ||
                    (target == WeaponTarget.Ranged && !isMelee))
                    return threshold;
            }
        }
        return "";
    }

    private bool IsDetachmentRuleReflectedInStats
    {
        get
        {
            if (army is null || string.IsNullOrEmpty(army.DetachmentRule)) return false;

            // Hit bonus detachments (e.g., Awakened Dynasty)
            if (!string.IsNullOrEmpty(army.Detachment) &&
                army.Detachment.Contains("Awakened Dynasty", StringComparison.OrdinalIgnoreCase))
                return true;

            var rule = army.DetachmentRule;

            // Generic hit-roll bonus pattern
            if (rule.Contains("add 1 to", StringComparison.OrdinalIgnoreCase) &&
                rule.Contains("hit roll", StringComparison.OrdinalIgnoreCase))
                return true;

            // Wound-roll bonus pattern
            if (rule.Contains("add 1 to", StringComparison.OrdinalIgnoreCase) &&
                rule.Contains("wound roll", StringComparison.OrdinalIgnoreCase))
                return true;

            // Keyword-granting pattern (e.g., "have the [KEYWORD] ability")
            if (rule.Contains("have the", StringComparison.OrdinalIgnoreCase) &&
                rule.Contains("ability", StringComparison.OrdinalIgnoreCase))
                return true;

            return false;
        }
    }

    private bool UnitHasDetachmentHitBonus(UnitEntry unit)
    {
        if (army is null) return false;

        bool ruleApplies = false;

        // Match by detachment name
        if (!string.IsNullOrEmpty(army.Detachment) &&
            army.Detachment.Contains("Awakened Dynasty", StringComparison.OrdinalIgnoreCase))
            ruleApplies = true;

        // Match by rule text (flexible: "add 1 to the Hit roll" / "add 1 to Hit rolls" etc.)
        if (!ruleApplies && !string.IsNullOrEmpty(army.DetachmentRule) &&
            army.DetachmentRule.Contains("add 1 to", StringComparison.OrdinalIgnoreCase) &&
            army.DetachmentRule.Contains("hit roll", StringComparison.OrdinalIgnoreCase) &&
            army.DetachmentRule.Contains("character", StringComparison.OrdinalIgnoreCase))
            ruleApplies = true;

        if (!ruleApplies) return false;

        return unit.AttachedLeaders.Any(l =>
            !IsKilled(l) &&
            l.Keywords.Any(k => k.Equals("Character", StringComparison.OrdinalIgnoreCase)));
    }

    private static string ImproveSkill(string skill)
    {
        if (string.IsNullOrEmpty(skill)) return skill;
        var match = System.Text.RegularExpressions.Regex.Match(skill, @"^(\d)\+$");
        if (!match.Success) return skill;
        var value = int.Parse(match.Groups[1].Value);
        var improved = Math.Max(2, value - 1);
        return $"{improved}+";
    }

    private static string? ParseLeaderUnitKeyword(AbilityEntry a)
    {
        var desc = a.Description;
        if (!desc.Contains("while this model is leading", StringComparison.OrdinalIgnoreCase) &&
            !desc.Contains("while leading", StringComparison.OrdinalIgnoreCase) &&
            !desc.Contains("while the bearer is leading", StringComparison.OrdinalIgnoreCase))
            return null;

        var match = System.Text.RegularExpressions.Regex.Match(desc,
            @"have the (\w+(?:\s\w+)*?) ability",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (match.Success)
            return match.Groups[1].Value.Trim().ToUpperInvariant();

        return null;
    }

    private string GetExtraUnitKeywords(UnitEntry unit)
    {
        var extras = new List<string>();
        void ScanAbilities(IEnumerable<AbilityEntry> abilities)
        {
            foreach (var ability in abilities)
            {
                if (!IsAddedToUnit(ability)) continue;
                if (!IsAddedToUnitVisible(ability)) continue;
                var keyword = ParseLeaderUnitKeyword(ability) ?? ParseBearerKeyword(ability);
                if (keyword is not null)
                {
                    if (!extras.Contains(keyword))
                        extras.Add(keyword);
                }
                else if (ParseLeaderWeaponAbility(ability) is null &&
                         ParseLeaderDefensiveAura(ability) is null &&
                         ParseLeaderCritModifier(ability) is null)
                {
                    if (!extras.Contains(ability.Name))
                        extras.Add(ability.Name);
                }
            }
        }
        ScanAbilities(unit.Abilities);
        foreach (var leader in unit.AttachedLeaders)
        {
            if (IsKilled(leader)) continue;
            ScanAbilities(leader.Abilities);
        }
        return extras.Count > 0 ? string.Join(" : ", extras.Select(e => $"[ {e} ]")) : "";
    }

    private List<(string Label, string Description)> GetExtraUnitAbilities(UnitEntry unit)
    {
        var result = new List<(string Label, string Description)>();
        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        void ScanAbilities(IEnumerable<AbilityEntry> abilities)
        {
            foreach (var ability in abilities)
            {
                if (!IsAddedToUnit(ability)) continue;
                if (!IsAddedToUnitVisible(ability)) continue;
                var keyword = ParseLeaderUnitKeyword(ability) ?? ParseBearerKeyword(ability);
                if (keyword is not null)
                {
                    if (seen.Add(keyword))
                        result.Add((keyword, ability.Description));
                }
                else if (ParseLeaderWeaponAbility(ability) is null &&
                         ParseLeaderDefensiveAura(ability) is null &&
                         ParseLeaderCritModifier(ability) is null)
                {
                    if (seen.Add(ability.Name))
                        result.Add((ability.Name, ability.Description));
                }
            }
        }
        ScanAbilities(unit.Abilities);
        foreach (var leader in unit.AttachedLeaders)
        {
            if (IsKilled(leader)) continue;
            ScanAbilities(leader.Abilities);
        }
        return result;
    }

    private string GetExtraWeaponKeywords(UnitEntry unit, bool isMelee)
    {
        var extras = new List<string>();
        foreach (var leader in unit.AttachedLeaders)
        {
            if (IsKilled(leader)) continue;
            foreach (var ability in leader.Abilities)
            {
                if (!IsAddedToUnit(ability)) continue;
                if (!IsAddedToUnitVisible(ability)) continue;
                var parsed = ParseLeaderWeaponAbility(ability);
                if (parsed is null) continue;
                var (kw, target) = parsed.Value;
                if (target == WeaponTarget.Both ||
                    (target == WeaponTarget.Melee && isMelee) ||
                    (target == WeaponTarget.Ranged && !isMelee))
                {
                    if (!extras.Contains(kw))
                        extras.Add(kw);
                }
            }
        }
        return extras.Count > 0 ? string.Join(", ", extras) : "";
    }

    private void ShowBuffSource(string label, string source, string keywordDesc)
    {
        if (buffSourcePopup is var (l, _, _) && l == label)
            buffSourcePopup = null;
        else
            buffSourcePopup = (label, source, keywordDesc);
