    private async Task SaveToStorage()
    {
        if (army is null || rawJson is null) return;
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "roster-json", rawJson);

            var state = new RosterState
            {
                UnitOrder = army.Units.Select(u => u.Name).ToList(),
                Attachments = army.Units
                    .SelectMany(u => u.AttachedLeaders.Select(l => new AttachmentInfo { Leader = l.Name, Host = u.Name }))
                    .ToList()
            };
            await JS.InvokeVoidAsync("localStorage.setItem", "roster-state",
                JsonSerializer.Serialize(state));
        }
        catch { /* localStorage quota or unavailable */ }
    }

    private async Task LoadFromStorage()
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", "roster-json");
            if (string.IsNullOrEmpty(json)) return;

            rawJson = json;
            army = parser.Parse(json);
            activeDetachmentEffects = await DetachmentEffects.GetEffectsForDetachment(army.Detachment);

            var stateJson = await JS.InvokeAsync<string?>("localStorage.getItem", "roster-state");
            if (!string.IsNullOrEmpty(stateJson))
            {
                var state = JsonSerializer.Deserialize<RosterState>(stateJson);
                if (state is not null)
                    ApplyState(state);
            }

            var configJson = await JS.InvokeAsync<string?>("localStorage.getItem", "ability-configs");
            if (!string.IsNullOrEmpty(configJson))
            {
                var saved = JsonSerializer.Deserialize<Dictionary<string, AbilitySetupEntry>>(configJson);
                if (saved is not null)
                {
                    foreach (var (k, v) in saved)
                        abilityConfigs[k] = v;
                    setupConfirmed = true;
                }
            }

            var stratConfigJson = await JS.InvokeAsync<string?>("localStorage.getItem", "stratagem-configs");
            if (!string.IsNullOrEmpty(stratConfigJson))
            {
                var savedStrats = JsonSerializer.Deserialize<Dictionary<string, StratagemSetupEntry>>(stratConfigJson);
                if (savedStrats is not null)
                {
                    foreach (var (k, v) in savedStrats)
                        stratagemConfigs[k] = v;
                    stratagemSetupConfirmed = true;
                }
            }
            else
            {
                stratagemSetupConfirmed = setupConfirmed;
            }

            var detConfigJson = await JS.InvokeAsync<string?>("localStorage.getItem", "detachment-config");
            if (!string.IsNullOrEmpty(detConfigJson))
            {
                var savedDet = JsonSerializer.Deserialize<DetachmentSetupEntry>(detConfigJson);
                if (savedDet is not null)
                    detachmentConfig = savedDet;
            }

            var detEffectsJson = await JS.InvokeAsync<string?>("localStorage.getItem", "detachment-effect-configs-v2");
            if (!string.IsNullOrEmpty(detEffectsJson))
            {
                var savedDe = JsonSerializer.Deserialize<Dictionary<string, DetachmentEffectSetupEntry>>(detEffectsJson);
                if (savedDe is not null)
                {
                    detachmentEffectConfigs.Clear();
                    foreach (var (k, v) in savedDe)
                        detachmentEffectConfigs[k] = v;
                }
            }

            var armyRulesJson = await JS.InvokeAsync<string?>("localStorage.getItem", "army-rule-configs-v2");
            if (!string.IsNullOrEmpty(armyRulesJson))
            {
                var savedAr = JsonSerializer.Deserialize<Dictionary<string, ArmyRuleSetupEntry>>(armyRulesJson);
                if (savedAr is not null)
                {
                    armyRuleConfigs.Clear();
                    foreach (var (k, v) in savedAr)
                        armyRuleConfigs[k] = v;
                }
            }

            InitStratagemConfigs();
            InitAbilityConfigs();
            expandedUnits.Clear();
            stratHiddenUnits.Clear();
            armyIsSaved = army is not null && savedArmies.Any(s => s.Name == army.Name);
        }
        catch { /* corrupt data or storage unavailable */ }
    }

    private void ApplyState(RosterState state)
    {
        if (army is null) return;

        if (state.UnitOrder.Count > 0)
        {
            var remaining = new List<UnitEntry>(army.Units);
            var ordered = new List<UnitEntry>();

            foreach (var name in state.UnitOrder)
            {
                var match = remaining.FirstOrDefault(u => u.Name == name);
                if (match is not null)
                {
                    ordered.Add(match);
                    remaining.Remove(match);
                }
            }

            ordered.AddRange(remaining);
            army.Units = ordered;
        }

        foreach (var att in state.Attachments)
        {
            var leader = army.Units.FirstOrDefault(u => u.Name == att.Leader && u.IsLeader);
            var host = army.Units.FirstOrDefault(u => u.Name == att.Host && u != leader);
            if (leader is not null && host is not null && !host.AttachedLeaders.Contains(leader))
                host.AttachedLeaders.Add(leader);
        }
    }

