    /// <summary>
    /// One-shot wipe of v2.3 setup configs so the v2.4 explicit-only model starts from a clean slate.
    /// Runs once per browser; sets a marker key when done.
    /// </summary>
    private async Task MigrateToV24Async()
    {
        try
        {
            const string marker = "migration-v2.4b-applied";
            var done = await JS.InvokeAsync<string?>("localStorage.getItem", marker);
            if (!string.IsNullOrEmpty(done)) return;

            await JS.InvokeVoidAsync("localStorage.removeItem", "ability-configs");
            await JS.InvokeVoidAsync("localStorage.removeItem", "stratagem-configs");
            await JS.InvokeVoidAsync("localStorage.removeItem", "detachment-config");
            await JS.InvokeVoidAsync("localStorage.removeItem", "detachment-effect-configs-v2");
            await JS.InvokeVoidAsync("localStorage.removeItem", "army-rule-configs-v2");
            // Wipe stale custom detachment-effects from localStorage (admin overrides)
            await JS.InvokeVoidAsync("localStorage.removeItem", "detachment-effects-custom");

            await JS.InvokeVoidAsync("localStorage.setItem", marker, "1");
        }
        catch { /* storage unavailable */ }
    }

    private static string DescribeDetachmentEffect(DetachmentEffect e)
    {
        if (!string.IsNullOrEmpty(e.DisplayLabel)) return e.DisplayLabel;
        var sign = e.Modifier > 0 ? "+" : "";
        var stat = e.Stat switch
        {
            "bs" => "BS",
            "ws" => "WS",
            "attacks" => "Attacks",
            "strength" => "Strength",
            "ap" => "AP",
            "damage" => "Damage",
            "toughness" => "Toughness",
            "save" => "Save",
            _ => e.Stat
        };
        var weapon = e.WeaponType switch
        {
            "melee" => " (melee)",
            "ranged" => " (ranged)",
            _ => ""
        };
        var cond = e.Condition switch
        {
            "always" => "",
            "has_leader_character" => " — when led by a Character",
            "charged" => " — when charged this turn",
            "battle_shocked_and_charged" => " — when battle-shocked and charged",
            _ => $" — {e.Condition}"
        };
        return $"{sign}{e.Modifier} {stat}{weapon}{cond}";
    }

    // ── Saved armies ─────────────────────────────────────────────────────────

    private async Task LoadSavedArmiesIndex()
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", "saved-armies-index");
            if (!string.IsNullOrEmpty(json))
                savedArmies = JsonSerializer.Deserialize<List<SavedArmyMeta>>(json) ?? [];
        }
        catch { savedArmies = []; }
    }

    private async Task SaveCurrentArmy()
    {
        if (army is null || rawJson is null) return;

        bool wasAlreadySaved = armyIsSaved;
        var name = army.Name;
        var state = new RosterState
        {
            UnitOrder = army.Units.Select(u => u.Name).ToList(),
            Attachments = army.Units
                .SelectMany(u => u.AttachedLeaders.Select(l => new AttachmentInfo { Leader = l.Name, Host = u.Name }))
                .ToList()
        };

        var data = new SavedArmyData
        {
            RawJson = rawJson,
            State = state,
            AbilityConfigs = new Dictionary<string, AbilitySetupEntry>(abilityConfigs),
            StratagemConfigs = new Dictionary<string, StratagemSetupEntry>(stratagemConfigs),
            DetachmentConfig = detachmentConfig,
            DetachmentEffectConfigs = new Dictionary<string, DetachmentEffectSetupEntry>(detachmentEffectConfigs),
            ArmyRuleConfigs = new Dictionary<string, ArmyRuleSetupEntry>(armyRuleConfigs)
        };

        if (Cloud.IsLoggedIn)
        {
            await SaveToCloud();
            await Cloud.SaveUserConfigsAsync(
                JsonSerializer.Serialize(abilityConfigs),
                JsonSerializer.Serialize(stratagemConfigs));
            await RefreshCloudRosters();
            armyIsSaved = true;
        }
        else
        {
            await JS.InvokeVoidAsync("localStorage.setItem", $"saved-army:{name}", JsonSerializer.Serialize(data));

            savedArmies.RemoveAll(a => a.Name == name);
            savedArmies.Insert(0, new SavedArmyMeta
            {
                Name = name,
                Faction = army.Faction ?? "",
                Detachment = army.Detachment ?? "",
                Points = army.TotalPoints
            });
            await JS.InvokeVoidAsync("localStorage.setItem", "saved-armies-index", JsonSerializer.Serialize(savedArmies));
            armyIsSaved = true;
        }

        // Show checkmark on save button for 1.5s
        saveTick = true;
        StateHasChanged();
        saveTickCts?.Cancel();
        saveTickCts = new CancellationTokenSource();
        _ = DismissSaveTickAsync(saveTickCts.Token);
    }

    private async Task DismissSaveTickAsync(CancellationToken ct)
    {
        try
        {
            await Task.Delay(1500, ct);
            saveTick = false;
            StateHasChanged();
        }
        catch (TaskCanceledException) { }
    }

    private async Task LoadSavedArmy(string name)
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", $"saved-army:{name}");
            if (string.IsNullOrEmpty(json)) return;

            var data = JsonSerializer.Deserialize<SavedArmyData>(json);
            if (data is null) return;

            rawJson = data.RawJson;
            army = parser.Parse(rawJson);
            activeDetachmentEffects = await DetachmentEffects.GetEffectsForDetachment(army.Detachment);

            if (data.State is not null)
                ApplyState(data.State);

            abilityConfigs.Clear();
            foreach (var (k, v) in data.AbilityConfigs)
                abilityConfigs[k] = v;

            stratagemConfigs.Clear();
            foreach (var (k, v) in data.StratagemConfigs)
                stratagemConfigs[k] = v;

            detachmentConfig = data.DetachmentConfig ?? new DetachmentSetupEntry();

            detachmentEffectConfigs.Clear();
            foreach (var (k, v) in data.DetachmentEffectConfigs)
                detachmentEffectConfigs[k] = v;

            armyRuleConfigs.Clear();
            foreach (var (k, v) in data.ArmyRuleConfigs)
                armyRuleConfigs[k] = v;

            InitAbilityConfigs();
            InitStratagemConfigs();

            setupConfirmed = true;
            stratagemSetupConfirmed = true;
            expandedUnits.Clear();
            stratHiddenUnits.Clear();
            killedUnits.Clear();
            playMode = false;
            errorMessage = null;
            armyIsSaved = true;

            await SaveToStorage();
            await SaveAbilityConfigs();
            await SaveStratagemConfigs();
            await SaveDetachmentConfig();
        }
        catch { errorMessage = "Failed to load saved army."; }
    }

    private async Task DeleteSavedArmy(string name)
    {
        savedArmies.RemoveAll(a => a.Name == name);
        await JS.InvokeVoidAsync("localStorage.removeItem", $"saved-army:{name}");
        await JS.InvokeVoidAsync("localStorage.setItem", "saved-armies-index", JsonSerializer.Serialize(savedArmies));
    }

    // ── Cloud sync methods ──────────────────────────────────────────────────

    private async Task PrefillFromCloudConfigs()
    {
        try
        {
            var (cloudAbilities, cloudStratagems) = await Cloud.LoadUserConfigsAsync();

            if (!string.IsNullOrEmpty(cloudAbilities))
            {
                var saved = JsonSerializer.Deserialize<Dictionary<string, AbilitySetupEntry>>(cloudAbilities);
                if (saved is not null)
                {
                    foreach (var (key, value) in saved)
                    {
                        if (abilityConfigs.ContainsKey(key))
                            abilityConfigs[key] = value;
                    }
                }
            }

            if (!string.IsNullOrEmpty(cloudStratagems))
            {
                var saved = JsonSerializer.Deserialize<Dictionary<string, StratagemSetupEntry>>(cloudStratagems);
                if (saved is not null)
                {
                    foreach (var (key, value) in saved)
                    {
                        if (stratagemConfigs.ContainsKey(key))
                            stratagemConfigs[key] = value;
                    }
                }
            }
        }
        catch { }
    }

    private async Task OnAuthChanged()
    {
        if (Cloud.IsLoggedIn)
            await RefreshCloudRosters();
        else
            cloudRosters.Clear();
    }

    private async Task RefreshCloudRosters()
    {
        cloudRosters = await Cloud.ListRostersAsync();
    }

    private async Task LoadCloudArmy(Guid id)
    {
        try
        {
            var dataJson = await Cloud.LoadRosterDataAsync(id);
            if (string.IsNullOrEmpty(dataJson)) { errorMessage = "Failed to load cloud army."; return; }

            var data = JsonSerializer.Deserialize<SavedArmyData>(dataJson);
            if (data is null) return;

            rawJson = data.RawJson;
            army = parser.Parse(rawJson);
            activeDetachmentEffects = await DetachmentEffects.GetEffectsForDetachment(army.Detachment);

            if (data.State is not null)
                ApplyState(data.State);

            abilityConfigs.Clear();
            foreach (var (k, v) in data.AbilityConfigs)
                abilityConfigs[k] = v;

            stratagemConfigs.Clear();
            foreach (var (k, v) in data.StratagemConfigs)
                stratagemConfigs[k] = v;

            detachmentConfig = data.DetachmentConfig ?? new DetachmentSetupEntry();

            detachmentEffectConfigs.Clear();
            foreach (var (k, v) in data.DetachmentEffectConfigs)
                detachmentEffectConfigs[k] = v;

            armyRuleConfigs.Clear();
            foreach (var (k, v) in data.ArmyRuleConfigs)
                armyRuleConfigs[k] = v;

            InitAbilityConfigs();
            InitStratagemConfigs();

            setupConfirmed = true;
            stratagemSetupConfirmed = true;
            expandedUnits.Clear();
            stratHiddenUnits.Clear();
            killedUnits.Clear();
            playMode = false;
            errorMessage = null;
            armyIsSaved = true;
            currentCloudRosterId = id;

            await SaveToStorage();
            await SaveAbilityConfigs();
            await SaveStratagemConfigs();
            await SaveDetachmentConfig();
        }
        catch { errorMessage = "Failed to load cloud army."; }
    }

    private async Task DeleteCloudArmy(Guid id)
    {
        await Cloud.DeleteRosterAsync(id);
        await RefreshCloudRosters();
    }

    private async Task SaveToCloud()
    {
        if (army is null || rawJson is null || !Cloud.IsLoggedIn) return;
        var state = new RosterState
        {
            UnitOrder = army.Units.Select(u => u.Name).ToList(),
            Attachments = army.Units
                .SelectMany(u => u.AttachedLeaders.Select(l => new AttachmentInfo { Leader = l.Name, Host = u.Name }))
                .ToList()
        };
        var data = new SavedArmyData
        {
            RawJson = rawJson,
            State = state,
            AbilityConfigs = new Dictionary<string, AbilitySetupEntry>(abilityConfigs),
            StratagemConfigs = new Dictionary<string, StratagemSetupEntry>(stratagemConfigs),
            DetachmentConfig = detachmentConfig
        };
        var dataJson = JsonSerializer.Serialize(data);
        var savedId = await Cloud.SaveRosterAsync(currentCloudRosterId, army.Name, army.Faction ?? "", army.Detachment ?? "", army.TotalPoints, dataJson);
        if (savedId is not null)
            currentCloudRosterId = savedId;
    }
