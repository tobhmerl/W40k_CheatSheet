    private List<(StatLine Stat, string InvulnSave, string FeelNoPain, UnitEntry Owner)> GetAllStatLines(UnitEntry unit)
    {
        var unitWideFnp = unit.FeelNoPain;
        var unitWideInvuln = unit.InvulnerableSave;

        var result = unit.StatLines.Select(s => (s, unitWideInvuln, unitWideFnp, unit)).ToList();
        foreach (var leader in unit.AttachedLeaders)
        {
            var leaderFnp = BetterFnp(unitWideFnp, leader.FeelNoPain);
            var leaderInvuln = BetterFnp(unitWideInvuln, leader.InvulnerableSave);
            result.AddRange(leader.StatLines.Select(s => (s, leaderInvuln, leaderFnp, leader)));
        }
        return result;
    }

    private static string BetterFnp(string a, string b)
    {
        if (string.IsNullOrEmpty(a)) return b ?? "";
        if (string.IsNullOrEmpty(b)) return a;
        return string.Compare(a, b, StringComparison.Ordinal) <= 0 ? a : b;
    }

    private static string ShortRange(string range) =>
        string.Equals(range, "Melee", StringComparison.OrdinalIgnoreCase) ? "M" : range;

    private static string ShortStatName(string name)
    {
        var s = name;
        // Strip common prefixes
        s = s.Replace("Canoptek ", "", StringComparison.OrdinalIgnoreCase);
        // Strip "the <Title>" suffixes: "Imotekh the Stormlord" → "Imotekh"
        var theIdx = s.IndexOf(" the ", StringComparison.OrdinalIgnoreCase);
        if (theIdx > 0) s = s[..theIdx];
        // 3+ words → initials: "Lokhust Heavy Destroyer" → "LHD"
        var words = s.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (words.Length >= 3)
            s = string.Concat(words.Select(w => char.ToUpperInvariant(w[0])));
        return s;
    }

    private int GetModelCount(UnitEntry owner)
    {
        if (!modelCounts.TryGetValue(owner, out var count))
        {
            count = owner.ModelCount;
            modelCounts[owner] = count;
        }
        return count;
    }

    private void AdjustModelCount(UnitEntry owner, int delta)
    {
        var current = GetModelCount(owner);
        var next = Math.Clamp(current + delta, 0, owner.ModelCount);
        if (next != current)
        {
            var mixedWeapons = GetMixedLoadoutWeapons(owner, delta);
            if (mixedWeapons.Count >= 2)
            {
                weaponRemovePopup = (owner, delta);
                return;
            }
            if (mixedWeapons.Count == 1)
                weaponModelCounts[mixedWeapons[0]] = GetEffectiveWeaponModels(mixedWeapons[0]) + delta;
        }
        modelCounts[owner] = next;
        if (next == 0 && !IsKilled(owner))
        {
            var host = army?.Units
                .Where(u => u.AttachedLeaders.Contains(owner))
                .FirstOrDefault();
            if (host is not null)
                KillAttachedUnit(host, owner);
            else
                KillUnit(owner);
        }
    }

    private void ConfirmWeaponModelRemoval(WeaponProfile weapon)
    {
        if (weaponRemovePopup is not { } wrp) return;
        var owner = wrp.Unit;
        var delta = wrp.Delta;

        weaponModelCounts[weapon] = Math.Clamp(GetEffectiveWeaponModels(weapon) + delta, 0, weapon.ModelsEquipped);

        var current = GetModelCount(owner);
        var next = Math.Clamp(current + delta, 0, owner.ModelCount);
        modelCounts[owner] = next;
        if (next == 0 && !IsKilled(owner))
        {
            var host = army?.Units
                .Where(u => u.AttachedLeaders.Contains(owner))
                .FirstOrDefault();
            if (host is not null)
                KillAttachedUnit(host, owner);
            else
                KillUnit(owner);
        }
        weaponRemovePopup = null;
    }

    private List<WeaponProfile> GetMixedLoadoutWeapons(UnitEntry owner, int delta)
    {
        var allWeapons = owner.RangedWeapons.Concat(owner.MeleeWeapons);
        if (delta < 0)
            return allWeapons
                .Where(w => w.ModelsEquipped > 0 && w.ModelsEquipped < owner.ModelCount && GetEffectiveWeaponModels(w) > 0)
                .ToList();
        return allWeapons
            .Where(w => w.ModelsEquipped > 0 && w.ModelsEquipped < owner.ModelCount && GetEffectiveWeaponModels(w) < w.ModelsEquipped)
            .ToList();
    }

    private int GetEffectiveWeaponModels(WeaponProfile weapon) =>
        weaponModelCounts.TryGetValue(weapon, out var count) ? count : weapon.ModelsEquipped;

    private int GetWeaponEffectiveModels(UnitEntry cardUnit, WeaponProfile weapon)
    {
        UnitEntry? owner = null;
        if (cardUnit.RangedWeapons.Any(w => ReferenceEquals(w, weapon)) ||
            cardUnit.MeleeWeapons.Any(w => ReferenceEquals(w, weapon)))
            owner = cardUnit;
        else
        {
            foreach (var leader in cardUnit.AttachedLeaders)
            {
                if (leader.RangedWeapons.Any(w => ReferenceEquals(w, weapon)) ||
                    leader.MeleeWeapons.Any(w => ReferenceEquals(w, weapon)))
                { owner = leader; break; }
            }
        }
        if (owner is null) return weapon.ModelsEquipped;
        if (weaponModelCounts.TryGetValue(weapon, out var wmc))
            return wmc;
        if (owner.ModelCount > 1 && weapon.ModelsEquipped >= owner.ModelCount)
            return GetModelCount(owner);
        return weapon.ModelsEquipped;
    }

    private static string FormatTotalAttacks(int models, string attacks)
    {
