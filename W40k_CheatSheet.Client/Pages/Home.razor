    private string GetHitBonusSource(UnitEntry unit)
    {
        if (army is not null && UnitHasDetachmentHitBonus(unit))
            return army.Detachment ?? "Detachment";
        return "";
    }

    private (string InvulnSource, string FnpSource) GetExtraDefensiveAuraSources(UnitEntry unit)
    {
        string invulnSrc = "";
        string fnpSrc = "";
        foreach (var leader in unit.AttachedLeaders)
        {
            if (IsKilled(leader)) continue;
            foreach (var ability in leader.Abilities)
            {
                if (!IsAddedToUnit(ability)) continue;
                if (!IsAddedToUnitVisible(ability)) continue;
                var parsed = ParseLeaderDefensiveAura(ability);
                if (parsed is null) continue;
                var (type, _) = parsed.Value;
                if (type == DefensiveAuraType.Invulnerable && string.IsNullOrEmpty(invulnSrc))
                    invulnSrc = $"{leader.Name} — {ability.Name}";
                else if (type == DefensiveAuraType.FeelNoPain && string.IsNullOrEmpty(fnpSrc))
                    fnpSrc = $"{leader.Name} — {ability.Name}";
            }
        }
        return (invulnSrc, fnpSrc);
    }

    private static string LookupKeywordDescription(string keyword)
    {
        if (WeaponKeywordDescriptions.TryGetValue(keyword, out var exact))
            return exact;
        foreach (var (key, value) in WeaponKeywordDescriptions)
        {
            if (keyword.StartsWith(key, StringComparison.OrdinalIgnoreCase))
                return value;
        }
        return "";
    }

    private static string CombineKeywords(string baseKw, string extra)
    {
        if (string.IsNullOrEmpty(baseKw)) return extra;
        if (string.IsNullOrEmpty(extra)) return baseKw;
        return baseKw + ", " + extra;
    }

