        a.Description.Contains("once per battle", StringComparison.OrdinalIgnoreCase);

    private static bool IsOncePerBattle(Stratagem s) =>
        s.Restriction.Contains("once per battle", StringComparison.OrdinalIgnoreCase) ||
        s.FullRestriction.Contains("once per battle", StringComparison.OrdinalIgnoreCase) ||
        s.Effect.Contains("once per battle", StringComparison.OrdinalIgnoreCase) ||
        s.FullEffect.Contains("once per battle", StringComparison.OrdinalIgnoreCase);

    private async Task OnceAbilityPointerDown(AbilityEntry ability)
    {
        if (!playMode || !IsOncePerBattle(ability)) return;
        onceTriggered = false;
        onceCts?.Cancel();
        onceCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(1500, onceCts.Token);
            onceTriggered = true;
            if (!usedAbilities.Remove(ability))
                usedAbilities.Add(ability);
            StateHasChanged();
        }
        catch (TaskCanceledException) { }
    }

