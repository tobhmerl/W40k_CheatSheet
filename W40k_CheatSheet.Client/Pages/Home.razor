@page "/"
@using W40k_CheatSheet.Client.Models
@using W40k_CheatSheet.Client.Services
@using System.Text.Json
@inject IJSRuntime JS

<PageTitle>W40k Roster</PageTitle>

<div class="roster-app">
    @if (!loaded)
    {
        <div class="import-section">
            <h1>⚔️ W40k CheatSheet</h1>
            <p>Loading…</p>
        </div>
    }
    else if (army is null)
    {
        <div class="import-section">
            <h1>⚔️ W40k CheatSheet</h1>
            <p>Import your army roster JSON to view unit stats.</p>
            <label class="import-btn">
                📁 Import Roster JSON
                <InputFile OnChange="HandleFileSelected" accept=".json" style="display:none" />
            </label>
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="error-msg">@errorMessage</div>
            }
        </div>
    }
    else
    {
        <div class="roster-header">
            <h1>@army.Name</h1>
            <div class="turn-buttons">
                <button class="turn-btn my-turn @(activeTurn == TurnFilter.MyTurn ? "active" : "")" @onclick="() => ToggleTurn(TurnFilter.MyTurn)">My turn</button>
                <button class="turn-btn enemy-turn @(activeTurn == TurnFilter.EnemyTurn ? "active" : "")" @onclick="() => ToggleTurn(TurnFilter.EnemyTurn)">Enemy turn</button>
            </div>
            <div class="phase-buttons">
                <button class="phase-btn @(activePhase == GamePhase.Command ? "active" : "")" @onclick="() => TogglePhase(GamePhase.Command)">Command</button>
                <button class="phase-btn @(activePhase == GamePhase.Move ? "active" : "")" @onclick="() => TogglePhase(GamePhase.Move)">Move</button>
                <button class="phase-btn @(activePhase == GamePhase.Shoot ? "active" : "")" @onclick="() => TogglePhase(GamePhase.Shoot)">Shoot</button>
                <button class="phase-btn @(activePhase == GamePhase.Charge ? "active" : "")" @onclick="() => TogglePhase(GamePhase.Charge)">Charge</button>
                <button class="phase-btn @(activePhase == GamePhase.Fight ? "active" : "")" @onclick="() => TogglePhase(GamePhase.Fight)">Fight</button>
            </div>
            @if (!string.IsNullOrEmpty(army.DetachmentRule))
            {
                <div class="detachment-rule">
                    <strong>@army.Detachment:</strong> @army.DetachmentRule
                </div>
            }
        </div>

        <div class="abilities-panel">
            <div class="abilities-panel-header" @onclick="() => abilitiesPanelOpen = !abilitiesPanelOpen">
                <span>📜 Abilities Overview</span>
                <span class="abilities-panel-controls">
                    <button class="show-all-btn @(showAllAbilities ? "active" : "")" @onclick="() => showAllAbilities = !showAllAbilities" @onclick:stopPropagation="true">@(showAllAbilities ? "Hide stats" : "Show all")</button>
                    <span class="collapse-icon">@(abilitiesPanelOpen ? "▾" : "▸")</span>
                </span>
            </div>
            @if (abilitiesPanelOpen)
            {
                <div class="abilities-panel-body">
                    @* ── Phase-specific abilities ── *@
                    @foreach (var entry in PanelUnits)
                    {
                        var phaseAbilities = entry.Abilities.Where(a => a.Phases != GamePhase.All).ToList();
                        var phaseFiltered = activePhase is not null
                            ? phaseAbilities.Where(a => a.Phases.HasFlag(activePhase.Value)).ToList()
                            : phaseAbilities;
                        if (activeTurn is not null)
                            phaseFiltered = phaseFiltered.Where(a => IsAbilityAvailableOnTurn(a.Description, activeTurn.Value)).ToList();
                        if (!showAllAbilities)
                            phaseFiltered = phaseFiltered.Where(a => !IsStatReflectedAbility(a, entry.Unit)).ToList();
                        if (phaseFiltered.Count == 0) { continue; }

                        var isOtherFocused = (focusedStatOwner is not null && focusedCard != entry.Unit) ||
                                             (focusedUnit is not null && focusedUnit != entry.Unit);
                        if (isOtherFocused) { continue; }

                        <div class="abilities-panel-unit">
                            <div class="abilities-panel-unit-name">@entry.Unit.Name</div>
                            @foreach (var ability in phaseFiltered)
                            {
                                <div class="abilities-panel-item @(focusedAbility == ability ? "zoomed" : "")" @onclick="() => ToggleFocusAbility(ability)" @onclick:stopPropagation="true">
                                    <strong>@ability.Name:</strong> @ability.Description
                                </div>
                            }
                        </div>
                    }

                    @* ── General abilities (no specific phase) ── *@
                    @if (PanelUnits.Any(e => e.Abilities.Any(a => a.Phases == GamePhase.All && (activeTurn is null || IsAbilityAvailableOnTurn(a.Description, activeTurn.Value)) && (showAllAbilities || !IsStatReflectedAbility(a, e.Unit)))))
                    {
                        <div class="abilities-panel-divider-row">
                            <span class="abilities-panel-divider-text">General Abilities</span>
                        </div>
                        @foreach (var entry in PanelUnits)
                        {
                            var generalAbilities = entry.Abilities.Where(a => a.Phases == GamePhase.All).ToList();
                            if (activeTurn is not null)
                                generalAbilities = generalAbilities.Where(a => IsAbilityAvailableOnTurn(a.Description, activeTurn.Value)).ToList();
                            if (!showAllAbilities)
                                generalAbilities = generalAbilities.Where(a => !IsStatReflectedAbility(a, entry.Unit)).ToList();
                            if (generalAbilities.Count == 0) { continue; }

                            var isOtherFocused = (focusedStatOwner is not null && focusedCard != entry.Unit) ||
                                                 (focusedUnit is not null && focusedUnit != entry.Unit);
                            if (isOtherFocused) { continue; }

                            <div class="abilities-panel-unit">
                                <div class="abilities-panel-unit-name">@entry.Unit.Name</div>
                                @foreach (var ability in generalAbilities)
                                {
                                    <div class="abilities-panel-item @(focusedAbility == ability ? "zoomed" : "")" @onclick="() => ToggleFocusAbility(ability)" @onclick:stopPropagation="true">
                                        <strong>@ability.Name:</strong> @ability.Description
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            }
        </div>

        <div class="stratagems-panel">
            <div class="stratagems-panel-header" @onclick="() => stratagemsPanelOpen = !stratagemsPanelOpen">
                <span>🎯 Stratagems</span>
                <span class="collapse-icon">@(stratagemsPanelOpen ? "▾" : "▸")</span>
            </div>
            @if (stratagemsPanelOpen)
            {
                <div class="stratagems-panel-body">
                    @foreach (var strat in FilteredStratagems)
                    {
                        var canUse = CanFocusedUnitUse(strat);
                        if (HasUnitFocus && !canUse) { continue; }
                        <div class="strat-item @(focusedStratagem == strat ? "zoomed" : "")"
                             @onclick="() => ToggleFocusStratagem(strat)" @onclick:stopPropagation="true">
                            <div class="strat-header @GetStratTurnClass(strat)">
                                <span class="strat-name">@strat.Name <span class="strat-phases">@GetPhaseLabels(strat.Phases)</span></span>
                                <span class="strat-cost">@strat.Cost</span>
                            </div>
                            <div class="strat-category">@strat.Category</div>
                            @if (focusedStratagem == strat)
                            {
                                <div class="strat-details @(stratDetailsZoomed ? "zoomed" : "")" @onclick="() => stratDetailsZoomed = !stratDetailsZoomed" @onclick:stopPropagation="true">
                                    <div class="strat-field"><span class="strat-label">When:</span> @strat.When</div>
                                    <div class="strat-field"><span class="strat-label">Target:</span> @strat.Target</div>
                                    <div class="strat-field"><span class="strat-label">Effect:</span> @strat.Effect</div>
                                    @if (!string.IsNullOrEmpty(strat.Restriction))
                                    {
                                        <div class="strat-field"><span class="strat-label restriction">Restriction:</span> @strat.Restriction</div>
                                    }
                                </div>
                            }
                            @if (strat.RequiredKeywords.Count > 0 && focusedStratagem != strat)
                            {
                                <div class="strat-keywords">
                                    @foreach (var kw in strat.RequiredKeywords)
                                    {
                                        <span class="strat-kw-badge">@kw.ToUpperInvariant()</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        @if (selectedLeader is not null)
        {
            <div class="attach-hint">
                Tap a unit to attach <strong>@selectedLeader.Name</strong> ·
                <span class="cancel-link" @onclick="CancelSelection">Cancel</span>
            </div>
        }

        @if (movingUnit is not null)
        {
            <div class="move-hint">
                Tap a unit to move <strong>@movingUnit.Name</strong> there ·
                <span class="cancel-link" @onclick="() => movingUnit = null">Cancel</span>
            </div>
        }

        <div class="unit-grid">
            @{
                bool hasGrouped = DisplayUnits.Any(u => !IsKilled(u) && u.AttachedLeaders.Count > 0);
                bool breakInserted = false;
                bool killedDividerInserted = false;
            }
            @foreach (var unit in DisplayUnits)
            {
                var stats = GetAllStatLines(unit);
                var ranged = GetAllRangedWeapons(unit);
                var melee = GetAllMeleeWeapons(unit);
                var enhancements = GetAllEnhancements(unit);
                var keywords = GetAllKeywords(unit);
                var totalPts = GetTotalPoints(unit);
                var hasSpecialSave = stats.Any(s => !string.IsNullOrEmpty(s.InvulnSave) || !string.IsNullOrEmpty(s.FeelNoPain));
                var isWarlord = unit.IsWarlord || unit.AttachedLeaders.Any(l => l.IsWarlord);
                var collapsed = IsCollapsed(unit);

                @if (hasGrouped && !breakInserted && !IsKilled(unit) && unit.AttachedLeaders.Count == 0)
                {
                    breakInserted = true;
                    <div class="column-break"></div>
                }

                @if (playMode && !killedDividerInserted && IsKilled(unit))
                {
                    killedDividerInserted = true;
                    <div class="killed-divider">
                        <span class="killed-divider-text">☠ Destroyed</span>
                    </div>
                }

                <div class="unit-card @CardClass(unit)"
                     draggable="true"
                     @ondragstart="() => DragStart(unit)"
                     @ondragend="DragEnd"
                     @ondragenter="() => DragEnter(unit)"
                     @ondragover:preventDefault
                     @ondrop="() => Drop(unit)">

                    <div class="unit-header"
                         @onclick="e => HandleHeaderClick(unit, e)"
                         @onpointerdown="() => HeaderPointerDown(unit)"
                         @onpointerup="HeaderPointerUp"
                         @onpointerleave="HeaderPointerUp"
                         @oncontextmenu:preventDefault>
                        <div class="unit-name">
                            @unit.Name
                            @if (isWarlord)
                            {
                                <span class="warlord-badge">⭐</span>
                            }
                        </div>
                        <div class="header-right">
                            <button class="move-handle" @onclick="() => StartMove(unit)" @onclick:stopPropagation="true">☰</button>
                            <span class="unit-points">@totalPts pts</span>
                            @if (!playMode)
                            {
                                <span class="collapse-icon">@(collapsed ? "▸" : "▾")</span>
                            }
                            @if (playMode && !IsKilled(unit))
                            {
                                <button class="kill-btn" @onclick="() => KillUnit(unit)" @onclick:stopPropagation="true">☠</button>
                            }
                        </div>
                    </div>

                    @foreach (var leader in unit.AttachedLeaders)
                    {
                        <div class="attached-leader @(IsKilled(leader) ? "killed" : "")">
                            <span>+ @leader.Name @(leader.IsWarlord ? "⭐" : "") (@leader.Points pts)</span>
                            @if (playMode && !IsKilled(leader))
                            {
                                <button class="kill-btn" @onclick="() => KillAttachedUnit(unit, leader)" @onclick:stopPropagation="true">☠</button>
                            }
                            else if (!playMode)
                            {
                                <button class="detach-btn" @onclick="() => DetachLeader(unit, leader)" @onclick:stopPropagation="true">✕</button>
                            }
                        </div>
                    }

                    @if (!collapsed)
                    {
                        <div class="unit-body">
                            @if (keywords.Count > 0)
                            {
                                <div class="unit-keywords">
                                    @foreach (var kw in keywords)
                                    {
                                        <span class="keyword">@kw</span>
                                    }
                                </div>
                            }

                            @if (enhancements.Count > 0)
                            {
                                <div class="unit-enhancements">
                                    @foreach (var enh in enhancements)
                                    {
                                        <span class="enhancement">🔮 @enh</span>
                                    }
                                </div>
                            }

                            @if (stats.Count > 0)
                            {
                                <div class="table-wrapper">
                                    <table class="stats-table">
                                        <thead>
                                            <tr>
                                                <th></th><th>M</th><th>T</th><th>SV</th><th>W</th><th>LD</th><th>OC</th>
                                                @if (hasSpecialSave) { <th>🛡️</th> }
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var s in stats)
                                            {
                                                <tr class="stat-row @(focusedStatOwner == s.Owner ? "focused" : "")" @onclick="() => ToggleFocusStatOwner(s.Owner, unit)" @onclick:stopPropagation="true">
                                                    <td class="name-cell">@s.Stat.Name</td>
                                                    <td>@s.Stat.M</td><td>@s.Stat.T</td><td>@s.Stat.SV</td>
                                                    <td>@s.Stat.W</td><td>@s.Stat.LD</td><td>@s.Stat.OC</td>
                                                    @if (hasSpecialSave)
                                                    {
                                                        <td>
                                                            @if (!string.IsNullOrEmpty(s.InvulnSave)) { <span class="invuln">@s.InvulnSave</span> }
                                                            @if (!string.IsNullOrEmpty(s.InvulnSave) && !string.IsNullOrEmpty(s.FeelNoPain)) { <span class="save-sep">|</span> }
                                                            @if (!string.IsNullOrEmpty(s.FeelNoPain)) { <span class="fnp">@(s.FeelNoPain.Replace("+", "++"))</span> }
                                                            @if (string.IsNullOrEmpty(s.InvulnSave) && string.IsNullOrEmpty(s.FeelNoPain)) { <span>-</span> }
                                                        </td>
                                                    }
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }

                            @if (ranged.Count > 0)
                            {
                                <h4 class="section-title">🎯 Ranged Weapons</h4>
                                <div class="table-wrapper">
                                    <table class="weapons-table">
                                        <thead>
                                            <tr><th>Weapon</th><th>Rng</th><th>A</th><th>BS</th><th>S</th><th>AP</th><th>D</th><th>Keywords</th></tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var w in ranged)
                                            {
                                                <tr class="weapon-row @(focusedWeapon == w || (focusedCard == unit && IsWeaponOwnedByFocused(w)) ? "zoomed" : "") @(focusedCard == unit && focusedStatOwner is not null && !IsWeaponOwnedByFocused(w) ? "dimmed" : "")" @onclick="() => ToggleFocusWeapon(w)" @onclick:stopPropagation="true">
                                                    <td class="name-cell">@w.Name</td>
                                                    <td>@w.Range</td><td>@w.A</td><td>@w.Skill</td>
                                                    <td>@w.S</td><td>@w.AP</td><td>@w.D</td>
                                                    <td class="kw-cell">@w.Keywords</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }

                            @if (melee.Count > 0)
                            {
                                <h4 class="section-title">⚔️ Melee Weapons</h4>
                                <div class="table-wrapper">
                                    <table class="weapons-table">
                                        <thead>
                                            <tr><th>Weapon</th><th>Rng</th><th>A</th><th>WS</th><th>S</th><th>AP</th><th>D</th><th>Keywords</th></tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var w in melee)
                                            {
                                                <tr class="weapon-row @(focusedWeapon == w || (focusedCard == unit && IsWeaponOwnedByFocused(w)) ? "zoomed" : "") @(focusedCard == unit && focusedStatOwner is not null && !IsWeaponOwnedByFocused(w) ? "dimmed" : "")" @onclick="() => ToggleFocusWeapon(w)" @onclick:stopPropagation="true">
                                                    <td class="name-cell">@w.Name</td>
                                                    <td>@w.Range</td><td>@w.A</td><td>@w.Skill</td>
                                                    <td>@w.S</td><td>@w.AP</td><td>@w.D</td>
                                                    <td class="kw-cell">@w.Keywords</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }

                            @if (unit.IsLeader && unit.AttachedLeaders.Count == 0)
                            {
                                <button class="attach-link" @onclick="() => StartAttach(unit)" @onclick:stopPropagation="true">
                                    🔗 Attach to unit
                                </button>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <hr class="footer-divider" />

        <div class="score-tracker">
            <div class="score-total-row">
                <span class="score-total">@(defenderPrimary + defenderSecondary)</span>
                <span class="score-total-label">Total</span>
                <span class="score-total">@(aggressorPrimary + aggressorSecondary)</span>
            </div>
            <div class="score-section">
                <div class="score-section-label">Primary</div>
                <div class="score-row">
                    <div class="score-player">
                        <div class="score-label">🛡️ Defender</div>
                        <div class="score-controls">
                            <button class="score-btn" @onclick="() => defenderPrimary = Math.Max(0, defenderPrimary - 1)">−</button>
                            <span class="score-value">@defenderPrimary</span>
                            <button class="score-btn" @onclick="() => defenderPrimary++">+</button>
                        </div>
                    </div>
                    <div class="score-divider"></div>
                    <div class="score-player">
                        <div class="score-label">⚔️ Aggressor</div>
                        <div class="score-controls">
                            <button class="score-btn" @onclick="() => aggressorPrimary = Math.Max(0, aggressorPrimary - 1)">−</button>
                            <span class="score-value">@aggressorPrimary</span>
                            <button class="score-btn" @onclick="() => aggressorPrimary++">+</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="score-section">
                <div class="score-section-label">Secondary</div>
                <div class="score-row">
                    <div class="score-player">
                        <div class="score-controls">
                            <button class="score-btn" @onclick="() => defenderSecondary = Math.Max(0, defenderSecondary - 1)">−</button>
                            <span class="score-value">@defenderSecondary</span>
                            <button class="score-btn" @onclick="() => defenderSecondary++">+</button>
                        </div>
                    </div>
                    <div class="score-divider"></div>
                    <div class="score-player">
                        <div class="score-controls">
                            <button class="score-btn" @onclick="() => aggressorSecondary = Math.Max(0, aggressorSecondary - 1)">−</button>
                            <span class="score-value">@aggressorSecondary</span>
                            <button class="score-btn" @onclick="() => aggressorSecondary++">+</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="roster-footer">
            <hr class="footer-divider" />
            <div class="roster-actions">
                <button class="play-btn @(playMode ? "active" : "")" @onclick="TogglePlayMode">@(playMode ? "⚔️ Live" : "⚔️ Play mode")</button>
                <label class="import-btn small">
                    📁 Re-import
                    <InputFile OnChange="HandleFileSelected" accept=".json" style="display:none" />
                </label>
                <button class="clear-btn" @onclick="ClearRoster">🗑️ Clear</button>
            </div>
            <div class="roster-meta">
                @if (!string.IsNullOrEmpty(army.Faction))
                {
                    <span class="meta-badge faction">@army.Faction</span>
                }
                @if (!string.IsNullOrEmpty(army.Detachment))
                {
                    <span class="meta-badge detachment">@army.Detachment</span>
                }
                <span class="meta-badge points">@army.TotalPoints / @army.PointLimit pts</span>
            </div>
        </div>
    }
    <div class="version-tag" @onclick="() => showChangelog = true">v1.4</div>

    @if (showChangelog)
    {
        <div class="changelog-overlay" @onclick="() => showChangelog = false">
            <div class="changelog-modal" @onclick:stopPropagation="true">
                <div class="changelog-header">
                    <span>📋 Changelog</span>
                    <button class="changelog-close" @onclick="() => showChangelog = false">✕</button>
                </div>
                <div class="changelog-body">
                    <div class="changelog-version">v1.4 — 2026-03-14</div>
                    <ul class="changelog-list">
                        <li>Added Play mode (⚔️) — toggle in footer to enter live game tracking</li>
                        <li>Kill units with ☠ button on each card and attached leader row</li>
                        <li>Killed units move below a “☠ Destroyed” divider, greyed out with strike-through</li>
                        <li>Killing a bodyguard splits the group — surviving leaders become standalone</li>
                        <li>Abilities of killed units hidden from the Abilities panel</li>
                        <li>“While leading” abilities auto-hidden when bodyguard is destroyed</li>
                        <li>Exiting Play mode resets all kills</li>
                        <li>Simplified all stratagem text to concise shorthand (ER, MW, ≤6″, etc.)</li>
                        <li>Abilities panel: stat-reflected abilities (FNP, invuln) hidden by default</li>
                        <li>Added “Show all” / “Hide stats” toggle in Abilities panel header</li>
                        <li>Stratagem details now zoom as a whole block instead of per-field</li>
                    </ul>
                    <div class="changelog-version">v1.3 — 2026-03-14</div>
                    <ul class="changelog-list">
                        <li>Hardcoded stratagem turn colors (blue/red/green/gradients) for accurate display</li>
                        <li>Stratagem headers now show applicable phases (Cmd, Mov, Sht, Chg, Fgt)</li>
                        <li>Stratagem text fields (When, Target, Effect, Restriction) are now click-to-zoom</li>
                        <li>Added red→blue gradient for enemy-first mixed stratagems (e.g. Undying Legions)</li>
                        <li>Fixed Protocol of the Undying Legions: no longer shows in My turn + Shoot</li>
                        <li>Per-turn phase filtering for stratagems with mixed turn/phase availability</li>
                        <li>Colored stratagems now sort before green (any phase) stratagems</li>
                        <li>Unit grid: grouped units (with leaders) in left column, standalone in right column</li>
                        <li>Added tap-to-move reorder for mobile (☰ handle on each unit card)</li>
                        <li>Clickable changelog popup on version tag</li>
                    </ul>
                    <div class="changelog-version">v1.2 — 2026-03-14</div>
                    <ul class="changelog-list">
                        <li>Added "My turn" / "Enemy turn" filter buttons</li>
                        <li>Stratagem headers color-coded by turn (blue = yours, red = enemy, green = both)</li>
                        <li>Abilities panel now filters by turn</li>
                        <li>Removed duplicate abilities section from unit cards</li>
                        <li>Added pipe separator between invuln save and feel-no-pain in shield column</li>
                    </ul>
                    <div class="changelog-version">v1.1 — 2026-03-13</div>
                    <ul class="changelog-list">
                        <li>Added stratagems panel with Core and Detachment stratagems</li>
                        <li>Added abilities overview panel with phase filtering</li>
                        <li>Added detachment rule display</li>
                        <li>Added scoped weapon highlight when focusing a stat row</li>
                        <li>Added feel-no-pain parsing and display</li>
                        <li>Added weapon zoom on click</li>
                        <li>Added stat-row focus to filter weapons by owner</li>
                        <li>Added score tracker for primary and secondary objectives</li>
                        <li>Added version tag</li>
                    </ul>
                    <div class="changelog-version">v1.0 — 2026-03-10</div>
                    <ul class="changelog-list">
                        <li>Initial release — import BattleScribe roster JSON</li>
                        <li>Unit cards with stats, weapons, keywords, and enhancements</li>
                        <li>Leader attachment via drag-and-drop or tap</li>
                        <li>Collapsible unit cards</li>
                        <li>Phase filter buttons</li>
                        <li>Local storage persistence</li>
                        <li>Deployed as standalone Blazor WASM on GitHub Pages</li>
                    </ul>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private ArmyRoster? army;
    private string? errorMessage;
    private string? rawJson;
    private bool loaded;
    private readonly RosterParserService parser = new();
    private UnitEntry? draggedUnit;
    private UnitEntry? dragOverUnit;
    private UnitEntry? selectedLeader;
    private UnitEntry? movingUnit;
    private AbilityEntry? focusedAbility;
    private WeaponProfile? focusedWeapon;
    private UnitEntry? focusedStatOwner;
    private UnitEntry? focusedCard;
    private UnitEntry? focusedUnit;
    private CancellationTokenSource? longPressCts;
    private bool longPressTriggered;
    private GamePhase? activePhase;
    private TurnFilter? activeTurn;
    private bool abilitiesPanelOpen = true;
    private bool showAllAbilities;
    private bool stratagemsPanelOpen = true;
    private Stratagem? focusedStratagem;
    private bool stratDetailsZoomed;
    private bool showChangelog;
    private bool playMode;
    private readonly HashSet<UnitEntry> killedUnits = [];
    private int defenderPrimary;
    private int aggressorPrimary;
    private int defenderSecondary;
    private int aggressorSecondary;
    private readonly HashSet<UnitEntry> collapsedUnits = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadFromStorage();
            loaded = true;
            StateHasChanged();
        }
    }

    private IEnumerable<UnitEntry> DisplayUnits
    {
        get
        {
            if (army is null) return [];
            var attached = army.Units
                .SelectMany(u => u.AttachedLeaders)
                .ToHashSet();
            var visible = army.Units.Where(u => !attached.Contains(u)).ToList();
            var alive = visible.Where(u => !IsKilled(u));
            var dead = visible.Where(u => IsKilled(u));
            var grouped = alive.Where(u => u.AttachedLeaders.Count > 0);
            var standalone = alive.Where(u => u.AttachedLeaders.Count == 0);
            return grouped.Concat(standalone).Concat(dead);
        }
    }

    private bool IsKilled(UnitEntry unit) => killedUnits.Contains(unit);

    private bool IsCollapsed(UnitEntry unit) => collapsedUnits.Contains(unit);

    private record struct PanelUnitEntry(UnitEntry Unit, List<AbilityEntry> Abilities);

    private List<PanelUnitEntry> PanelUnits =>
        DisplayUnits
            .Where(u => !IsKilled(u))
            .Select(u => new PanelUnitEntry(u, GetFilteredAbilities(u)))
            .ToList();

    private List<AbilityEntry> GetFilteredAbilities(UnitEntry unit)
    {
        var abilities = GetAllAbilities(unit);
        if (!playMode) return abilities;
        return abilities.Where(a =>
        {
            if (a.Description.Contains("while this model is leading", StringComparison.OrdinalIgnoreCase) ||
                a.Description.Contains("while leading", StringComparison.OrdinalIgnoreCase))
            {
                var leaderOwner = unit.AttachedLeaders.FirstOrDefault(l =>
                    l.Abilities.Any(la => la.Name == a.Name));
                if (leaderOwner is not null)
                {
                    bool bodyguardDead = IsKilled(unit);
                    if (bodyguardDead) return false;
                }
            }
            return true;
        }).ToList();
    }

    private void TogglePlayMode()
    {
        playMode = !playMode;
        if (!playMode)
            killedUnits.Clear();
    }

    private void KillUnit(UnitEntry unit)
    {
        killedUnits.Add(unit);
        if (unit.AttachedLeaders.Count > 0)
        {
            foreach (var leader in unit.AttachedLeaders.ToList())
            {
                if (!IsKilled(leader))
                    unit.AttachedLeaders.Remove(leader);
            }
        }
        collapsedUnits.Add(unit);
    }

    private void KillAttachedUnit(UnitEntry host, UnitEntry leader)
    {
        killedUnits.Add(leader);
        host.AttachedLeaders.Remove(leader);
    }

    private void ToggleCollapse(UnitEntry unit)
    {
        if (!collapsedUnits.Remove(unit))
            collapsedUnits.Add(unit);
    }

    private string CardClass(UnitEntry unit)
    {
        var css = "";
        if (unit.IsLeader && unit.AttachedLeaders.Count == 0)
            css += " leader-card";
        if (unit.AttachedLeaders.Count > 0)
            css += " combined-card";
        if (IsCollapsed(unit))
            css += " collapsed";
        if (draggedUnit == unit)
            css += " dragging";
        if (dragOverUnit == unit && draggedUnit is not null && draggedUnit != unit)
            css += " drag-over";
        if (selectedLeader == unit)
            css += " selected";
        if (selectedLeader is not null && !unit.IsLeader && unit != selectedLeader)
            css += " attach-target";
        if (focusedUnit == unit)
            css += " focused-unit";
        if (movingUnit == unit)
            css += " moving";
        if (movingUnit is not null && movingUnit != unit)
            css += " move-target";
        if (IsKilled(unit))
            css += " killed";
        return css.TrimStart();
    }

    private void StartMove(UnitEntry unit)
    {
        movingUnit = movingUnit == unit ? null : unit;
        selectedLeader = null;
    }

    private void DragStart(UnitEntry unit) => draggedUnit = unit;

    private void DragEnter(UnitEntry unit)
    {
        if (draggedUnit is not null && draggedUnit != unit)
            dragOverUnit = unit;
    }

    private void DragEnd()
    {
        draggedUnit = null;
        dragOverUnit = null;
    }

    private async Task Drop(UnitEntry target)
    {
        if (draggedUnit is null || draggedUnit == target || army is null)
            return;

        var units = army.Units;
        var fromIndex = units.IndexOf(draggedUnit);
        var toIndex = units.IndexOf(target);
        if (fromIndex >= 0 && toIndex >= 0)
        {
            units.RemoveAt(fromIndex);
            units.Insert(toIndex, draggedUnit);
        }

        draggedUnit = null;
        dragOverUnit = null;
        await SaveToStorage();
    }

    private async Task HandleHeaderClick(UnitEntry unit, MouseEventArgs e)
    {
        if (longPressTriggered)
        {
            longPressTriggered = false;
            return;
        }

        if (movingUnit is not null)
        {
            if (movingUnit != unit && army is not null)
            {
                var units = army.Units;
                var fromIndex = units.IndexOf(movingUnit);
                var toIndex = units.IndexOf(unit);
                if (fromIndex >= 0 && toIndex >= 0)
                {
                    units.RemoveAt(fromIndex);
                    units.Insert(toIndex, movingUnit);
                }
                await SaveToStorage();
            }
            movingUnit = null;
            return;
        }

        if (selectedLeader is not null)
        {
            if (!unit.IsLeader)
            {
                foreach (var u in army!.Units)
                    u.AttachedLeaders.Remove(selectedLeader);
                unit.AttachedLeaders.Add(selectedLeader);
            }
            selectedLeader = null;
            await SaveToStorage();
            return;
        }

        if (e.ShiftKey)
        {
            focusedUnit = focusedUnit == unit ? null : unit;
            focusedStatOwner = null;
            focusedCard = null;
            return;
        }

        ToggleCollapse(unit);
    }

    private async Task HeaderPointerDown(UnitEntry unit)
    {
        longPressTriggered = false;
        longPressCts?.Cancel();
        longPressCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(500, longPressCts.Token);
            longPressTriggered = true;
            focusedUnit = focusedUnit == unit ? null : unit;
            focusedStatOwner = null;
            focusedCard = null;
        }
        catch (TaskCanceledException) { }
    }

    private void HeaderPointerUp()
    {
        longPressCts?.Cancel();
    }

    private void StartAttach(UnitEntry leader)
    {
        selectedLeader = selectedLeader == leader ? null : leader;
    }

    private void CancelSelection() => selectedLeader = null;

    private void TogglePhase(GamePhase phase)
    {
        activePhase = activePhase == phase ? null : phase;
    }

    private enum TurnFilter { MyTurn, EnemyTurn }

    private void ToggleTurn(TurnFilter turn)
    {
        activeTurn = activeTurn == turn ? null : turn;
    }

    private void ToggleFocusAbility(AbilityEntry ability)
    {
        focusedAbility = focusedAbility == ability ? null : ability;
    }

    private void ToggleFocusStratagem(Stratagem strat)
    {
        focusedStratagem = focusedStratagem == strat ? null : strat;
        stratDetailsZoomed = false;
    }

    private List<Stratagem> FilteredStratagems
    {
        get
        {
            var detachment = army?.Detachment ?? "";
            var available = CoreStratagems.All
                .Where(s => string.IsNullOrEmpty(s.Detachment) ||
                            s.Detachment.Equals(detachment, StringComparison.OrdinalIgnoreCase));

            if (activeTurn is not null)
                available = available.Where(s => IsAvailableForTurn(s.TurnColor, activeTurn.Value));

            if (activePhase is not null)
            {
                available = available.Where(s =>
                {
                    var phases = s.Phases;
                    if (activeTurn is not null)
                    {
                        phases = activeTurn.Value == TurnFilter.MyTurn
                            ? (s.MyTurnPhases ?? s.Phases)
                            : (s.EnemyTurnPhases ?? s.Phases);
                    }
                    return phases.HasFlag(activePhase.Value);
                });
            }

            return available
                .OrderBy(s => s.TurnColor == StratagemTurn.Green ? 1 : 0)
                .ToList();
        }
    }

    private static bool IsAvailableForTurn(StratagemTurn color, TurnFilter turn) => turn switch
    {
        TurnFilter.MyTurn => color is StratagemTurn.Green or StratagemTurn.Blue or StratagemTurn.BlueRed or StratagemTurn.RedBlue,
        TurnFilter.EnemyTurn => color is StratagemTurn.Green or StratagemTurn.Red or StratagemTurn.BlueRed or StratagemTurn.RedBlue,
        _ => true
    };

    private static string GetStratTurnClass(Stratagem strat) => strat.TurnColor switch
    {
        StratagemTurn.Blue => "turn-myturn",
        StratagemTurn.Red => "turn-enemyturn",
        StratagemTurn.BlueRed => "turn-bluered",
        StratagemTurn.RedBlue => "turn-redblue",
        _ => "turn-both"
    };

    private static string GetPhaseLabels(GamePhase phases)
    {
        if (phases == GamePhase.All) return "Any";
        var labels = new List<string>();
        if (phases.HasFlag(GamePhase.Command)) labels.Add("Cmd");
        if (phases.HasFlag(GamePhase.Move)) labels.Add("Mov");
        if (phases.HasFlag(GamePhase.Shoot)) labels.Add("Sht");
        if (phases.HasFlag(GamePhase.Charge)) labels.Add("Chg");
        if (phases.HasFlag(GamePhase.Fight)) labels.Add("Fgt");
        return string.Join(" · ", labels);
    }

    private static bool IsAbilityAvailableOnTurn(string description, TurnFilter turn)
    {
        bool mentionsEnemy = description.Contains("opponent", StringComparison.OrdinalIgnoreCase) ||
                             description.Contains("enemy", StringComparison.OrdinalIgnoreCase);

        var stripped = description.Replace("your opponent", "", StringComparison.OrdinalIgnoreCase);
        bool mentionsYour = stripped.Contains("your", StringComparison.OrdinalIgnoreCase);

        if (!mentionsYour && !mentionsEnemy) return true;

        return turn switch
        {
            TurnFilter.MyTurn => mentionsYour,
            TurnFilter.EnemyTurn => mentionsEnemy,
            _ => true
        };
    }

    private static bool IsStatReflectedAbility(AbilityEntry ability, UnitEntry unit)
    {
        var name = ability.Name;
        var desc = ability.Description;

        bool isFnp = name.Contains("Feel No Pain", StringComparison.OrdinalIgnoreCase) ||
                     desc.Contains("Feel No Pain", StringComparison.OrdinalIgnoreCase);
        if (isFnp && HasFnpInStats(unit))
            return true;

        bool isInvuln = name.Contains("Invulnerable", StringComparison.OrdinalIgnoreCase) ||
                        desc.Contains("invulnerable save", StringComparison.OrdinalIgnoreCase);
        if (isInvuln && HasInvulnInStats(unit))
            return true;

        return false;
    }

    private static bool HasFnpInStats(UnitEntry unit)
    {
        if (!string.IsNullOrEmpty(unit.FeelNoPain)) return true;
        return unit.AttachedLeaders.Any(l =>
            !string.IsNullOrEmpty(l.FeelNoPain) || !string.IsNullOrEmpty(l.FeelNoPainAura));
    }

    private static bool HasInvulnInStats(UnitEntry unit)
    {
        if (!string.IsNullOrEmpty(unit.InvulnerableSave)) return true;
        return unit.AttachedLeaders.Any(l => !string.IsNullOrEmpty(l.InvulnerableSave));
    }

    private bool HasUnitFocus => focusedUnit is not null || focusedStatOwner is not null;

    private bool CanFocusedUnitUse(Stratagem strat)
    {
        if (strat.RequiredKeywords.Count == 0) return true;
        if (!HasUnitFocus) return true;

        var unitKeywords = focusedUnit is not null
            ? GetAllKeywords(focusedUnit)
            : focusedCard is not null
                ? GetAllKeywords(focusedCard)
                : focusedStatOwner!.Keywords;

        return strat.RequiredKeywords.Any(rk =>
            unitKeywords.Any(uk => string.Equals(uk, rk, StringComparison.OrdinalIgnoreCase)));
    }

    private void ToggleFocusWeapon(WeaponProfile weapon)
    {
        focusedWeapon = focusedWeapon == weapon ? null : weapon;
    }

    private void ToggleFocusStatOwner(UnitEntry owner, UnitEntry card)
    {
        focusedUnit = null;
        if (focusedStatOwner == owner)
        {
            focusedStatOwner = null;
            focusedCard = null;
        }
        else
        {
            focusedStatOwner = owner;
            focusedCard = card;
        }
    }

    private bool IsWeaponOwnedByFocused(WeaponProfile weapon) =>
        focusedStatOwner is not null &&
        (focusedStatOwner.RangedWeapons.Any(w => w.Name == weapon.Name) ||
         focusedStatOwner.MeleeWeapons.Any(w => w.Name == weapon.Name));

    private async Task DetachLeader(UnitEntry unit, UnitEntry leader)
    {
        unit.AttachedLeaders.Remove(leader);
        await SaveToStorage();
    }

    private List<(StatLine Stat, string InvulnSave, string FeelNoPain, UnitEntry Owner)> GetAllStatLines(UnitEntry unit)
    {
        var unitWideFnp = unit.FeelNoPain;
        foreach (var leader in unit.AttachedLeaders)
        {
            if (!string.IsNullOrEmpty(leader.FeelNoPainAura))
                unitWideFnp = BetterFnp(unitWideFnp, leader.FeelNoPainAura);
        }

        var result = unit.StatLines.Select(s => (s, unit.InvulnerableSave, unitWideFnp, unit)).ToList();
        foreach (var leader in unit.AttachedLeaders)
        {
            var leaderFnp = BetterFnp(unitWideFnp, leader.FeelNoPain);
            result.AddRange(leader.StatLines.Select(s => (s, leader.InvulnerableSave, leaderFnp, leader)));
        }
        return result;
    }

    private static string BetterFnp(string a, string b)
    {
        if (string.IsNullOrEmpty(a)) return b ?? "";
        if (string.IsNullOrEmpty(b)) return a;
        return string.Compare(a, b, StringComparison.Ordinal) <= 0 ? a : b;
    }

    private static List<WeaponProfile> GetAllRangedWeapons(UnitEntry unit) =>
        unit.RangedWeapons
            .Concat(unit.AttachedLeaders.SelectMany(l => l.RangedWeapons))
            .DistinctBy(w => w.Name).ToList();

    private static List<WeaponProfile> GetAllMeleeWeapons(UnitEntry unit) =>
        unit.MeleeWeapons
            .Concat(unit.AttachedLeaders.SelectMany(l => l.MeleeWeapons))
            .DistinctBy(w => w.Name).ToList();

    private static List<AbilityEntry> GetAllAbilities(UnitEntry unit) =>
        unit.Abilities
            .Concat(unit.AttachedLeaders.SelectMany(l => l.Abilities))
            .DistinctBy(a => a.Name).ToList();

    private static List<string> GetAllEnhancements(UnitEntry unit) =>
        unit.Enhancements
            .Concat(unit.AttachedLeaders.SelectMany(l => l.Enhancements))
            .Distinct().ToList();

    private static List<string> GetAllKeywords(UnitEntry unit) =>
        unit.Keywords
            .Concat(unit.AttachedLeaders.SelectMany(l => l.Keywords))
            .Distinct().ToList();

    private static int GetTotalPoints(UnitEntry unit) =>
        unit.Points + unit.AttachedLeaders.Sum(l => l.Points);

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        errorMessage = null;
        selectedLeader = null;
        draggedUnit = null;
        dragOverUnit = null;
        collapsedUnits.Clear();
        try
        {
            var file = e.File;
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var reader = new StreamReader(stream);
            rawJson = await reader.ReadToEndAsync();
            army = parser.Parse(rawJson);
            await SaveToStorage();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error importing file: {ex.Message}";
            army = null;
        }
    }

    private async Task ClearRoster()
    {
        army = null;
        rawJson = null;
        errorMessage = null;
        selectedLeader = null;
        collapsedUnits.Clear();
        await JS.InvokeVoidAsync("localStorage.removeItem", "roster-json");
        await JS.InvokeVoidAsync("localStorage.removeItem", "roster-state");
    }

    private async Task SaveToStorage()
    {
        if (army is null || rawJson is null) return;
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "roster-json", rawJson);

            var state = new RosterState
            {
                UnitOrder = army.Units.Select(u => u.Name).ToList(),
                Attachments = army.Units
                    .SelectMany(u => u.AttachedLeaders.Select(l => new AttachmentInfo { Leader = l.Name, Host = u.Name }))
                    .ToList()
            };
            await JS.InvokeVoidAsync("localStorage.setItem", "roster-state",
                JsonSerializer.Serialize(state));
        }
        catch { /* localStorage quota or unavailable */ }
    }

    private async Task LoadFromStorage()
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", "roster-json");
            if (string.IsNullOrEmpty(json)) return;

            rawJson = json;
            army = parser.Parse(json);

            var stateJson = await JS.InvokeAsync<string?>("localStorage.getItem", "roster-state");
            if (!string.IsNullOrEmpty(stateJson))
            {
                var state = JsonSerializer.Deserialize<RosterState>(stateJson);
                if (state is not null)
                    ApplyState(state);
            }
        }
        catch { /* corrupt data or storage unavailable */ }
    }

    private void ApplyState(RosterState state)
    {
        if (army is null) return;

        if (state.UnitOrder.Count > 0)
        {
            var remaining = new List<UnitEntry>(army.Units);
            var ordered = new List<UnitEntry>();

            foreach (var name in state.UnitOrder)
            {
                var match = remaining.FirstOrDefault(u => u.Name == name);
                if (match is not null)
                {
                    ordered.Add(match);
                    remaining.Remove(match);
                }
            }

            ordered.AddRange(remaining);
            army.Units = ordered;
        }

        foreach (var att in state.Attachments)
        {
            var leader = army.Units.FirstOrDefault(u => u.Name == att.Leader && u.IsLeader);
            var host = army.Units.FirstOrDefault(u => u.Name == att.Host && u != leader);
            if (leader is not null && host is not null && !host.AttachedLeaders.Contains(leader))
                host.AttachedLeaders.Add(leader);
        }
    }

    private class RosterState
    {
        public List<string> UnitOrder { get; set; } = [];
        public List<AttachmentInfo> Attachments { get; set; } = [];
    }

    private class AttachmentInfo
    {
        public string Leader { get; set; } = "";
        public string Host { get; set; } = "";
    }
}
