            .ToList();

    private List<AbilityEntry> GetFilteredAbilities(UnitEntry unit)
    {
        var abilities = GetAllAbilities(unit)
            .Where(a => !IsSetupOnlyAbility(a))
            .Where(a => !IsAddedToUnit(a))
            .ToList();
        if (!playMode) return abilities;
        return abilities.Where(a =>
        {
            if (a.Description.Contains("while this model is leading", StringComparison.OrdinalIgnoreCase) ||
                a.Description.Contains("while leading", StringComparison.OrdinalIgnoreCase))
            {
                var leaderOwner = unit.AttachedLeaders.FirstOrDefault(l =>
                    l.Abilities.Any(la => la.Name == a.Name));
                if (leaderOwner is not null)
                {
                    bool bodyguardDead = IsKilled(unit);
                    if (bodyguardDead) return false;
                }
            }
            return true;
        }).ToList();
    }

    private List<AbilityEntry> GetCardAbilities(UnitEntry unit)
    {
        var all = GetFilteredAbilities(unit)
            .Where(a => !IsHiddenAbility(a))
            .Where(a => !IsAlwaysActive(a))
            .Where(a => !IsStatReflectedAbility(a, unit))
            .ToList();

        if (activeTurn is not null)
            all = all.Where(a => IsConfiguredForTurn(a, activeTurn.Value)).ToList();

        if (activePhase is not null)
            all = all.Where(a => IsConfiguredForPhase(a, activePhase.Value)).ToList();

        return all;
    }

    private List<AbilityEntry> GetCardAlwaysActiveAbilities(UnitEntry unit)
    {
        return GetAllAbilities(unit)
            .Where(a => !IsSetupOnlyAbility(a))
            .Where(a => IsAlwaysActive(a))
            .Where(a => !IsHiddenAbility(a))
            .Where(a => !(IsAddedToUnit(a) && CanAddToUnit(a)))
            .Where(a => !IsStatReflectedAbility(a, unit))
            .ToList();
    }

    private List<Stratagem> GetCardAlwaysActiveStratagems(UnitEntry unit)
    {
        var detachment = army?.Detachment ?? "";
        var unitKeywords = GetAllKeywords(unit);

        return CoreStratagems.All
            .Where(s => string.IsNullOrEmpty(s.Detachment) ||
                        s.Detachment.Equals(detachment, StringComparison.OrdinalIgnoreCase))
            .Where(s => !IsDisabledStratagem(s))
            .Where(s => s.RequiredKeywords.Count == 0 ||
                        s.RequiredKeywords.Any(rk =>
                            unitKeywords.Any(uk => uk.Contains(rk, StringComparison.OrdinalIgnoreCase))))
            .Where(s => IsStratAlwaysActive(s))
            .OrderBy(s => TurnColorOrder(s.TurnColor))
            .ThenBy(s => s.Name)
            .ToList();
    }

    private List<Stratagem> GetCardStratagems(UnitEntry unit)
    {
        var detachment = army?.Detachment ?? "";
        var unitKeywords = GetAllKeywords(unit);

        var available = CoreStratagems.All
            .Where(s => string.IsNullOrEmpty(s.Detachment) ||
                        s.Detachment.Equals(detachment, StringComparison.OrdinalIgnoreCase))
            .Where(s => !IsDisabledStratagem(s))
            .Where(s => s.RequiredKeywords.Count == 0 ||
                        s.RequiredKeywords.Any(rk =>
                            unitKeywords.Any(uk => uk.Contains(rk, StringComparison.OrdinalIgnoreCase))))
            .Where(s => !IsStratAlwaysActive(s));

