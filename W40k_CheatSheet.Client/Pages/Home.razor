    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        errorMessage = null;
        selectedLeader = null;
        draggedUnit = null;
        dragOverUnit = null;
        expandedUnits.Clear();
        stratHiddenUnits.Clear();
        rangedExpandedUnits.Clear();
        meleeExpandedUnits.Clear();
        try
        {
            var file = e.File;
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var reader = new StreamReader(stream);
            rawJson = await reader.ReadToEndAsync();
            army = parser.Parse(rawJson);
            activeDetachmentEffects = await DetachmentEffects.GetEffectsForDetachment(army.Detachment);
            abilityConfigs.Clear();
            // Preserve core stratagem configs (no detachment) across imports
            var coreStratNames = CoreStratagems.All
                .Where(s => string.IsNullOrEmpty(s.Detachment))
                .Select(s => s.Name)
                .ToHashSet();
            var preservedCoreStrats = stratagemConfigs
                .Where(kv => coreStratNames.Contains(kv.Key))
                .ToDictionary(kv => kv.Key, kv => kv.Value);
            stratagemConfigs.Clear();
            foreach (var (k, v) in preservedCoreStrats)
                stratagemConfigs[k] = v;
            detachmentConfig = new DetachmentSetupEntry();
            detachmentEffectConfigs.Clear();
            armyRuleConfigs.Clear();
            InitAbilityConfigs();
            InitStratagemConfigs();
            if (Cloud.IsLoggedIn)
                await PrefillFromCloudConfigs();
            setupConfirmed = true;
            stratagemSetupConfirmed = true;
            abilitiesPanelOpen = false;
            stratagemsPanelOpen = false;
            armyIsSaved = false;
            currentCloudRosterId = null;
            await SaveToStorage();
            await SaveAbilityConfigs();
            await SaveStratagemConfigs();
            await SaveDetachmentEffectConfigs();
            await SaveArmyRuleConfigs();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error importing file: {ex.Message}";
            army = null;
        }
    }

