@* Welcome / import hero card — extracted from Pages/Home.razor.
   Shown when no army is loaded. Renders the faction picker, the import button,
   and the cloud + local saved-armies lists filtered by the selected faction.

   CSS lives in wwwroot/css/components/welcome-hero.css (global, no isolation
   required since the markup classes are referenced from theme overrides too). *@

@using W40k_CheatSheet.Client.Models
@using W40k_CheatSheet.Client.Services
@inject CloudRosterService Cloud

<div class="import-section">
    @if (WelcomeBg is null)
    {
        <div class="welcome-card" style="background: #111;">
            <div class="welcome-overlay"></div>
            <div class="welcome-content">
                <h1>Segmentum Ultima</h1>
                <p>Select your faction to begin.</p>
                <div class="welcome-faction-toggle">
                    <img src="images/select_necrons.png" alt="Necrons" class="faction-select-img" @onclick="@(() => SetWelcomeBg("necrons"))" />
                    <img src="images/select_blood_angels.png" alt="Blood Angels" class="faction-select-img" @onclick="@(() => SetWelcomeBg("blood_angels"))" />
                    <img src="images/select_dark_angels.png" alt="Dark Angels" class="faction-select-img" @onclick="@(() => SetWelcomeBg("dark_angels"))" />
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="welcome-faction-toggle mini">
            <img src="images/select_necrons.png" alt="Necrons" class="faction-select-img @(WelcomeBg == "necrons" ? "active" : "")" @onclick="@(() => SetWelcomeBg("necrons"))" />
            <img src="images/select_blood_angels.png" alt="Blood Angels" class="faction-select-img @(WelcomeBg == "blood_angels" ? "active" : "")" @onclick="@(() => SetWelcomeBg("blood_angels"))" />
            <img src="images/select_dark_angels.png" alt="Dark Angels" class="faction-select-img @(WelcomeBg == "dark_angels" ? "active" : "")" @onclick="@(() => SetWelcomeBg("dark_angels"))" />
        </div>
        <div class="welcome-card" style="background: url('images/bg_@(WelcomeBg).jpg') no-repeat center/cover;">
            <div class="welcome-overlay"></div>
            <div class="welcome-content">
                <h1>Segmentum Ultima</h1>
                <p>Import your army roster JSON to view unit stats.</p>
                <label class="import-btn">
                    <img src="images/import_button_@(WelcomeBg).png" alt="Import Roster (JSON)" />
                    <InputFile OnChange="OnFileSelected" accept=".json" style="display:none" />
                </label>
                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="error-msg">@ErrorMessage</div>
                }
            </div>
        </div>
    }

    @* ── Cloud Armies (shown when logged in, filtered by selected faction) ── *@
    @if (Cloud.IsLoggedIn && CloudRosters.Any(cr => FactionMatches(cr.Faction)))
    {
        <div class="saved-armies">
            <h3>☁️ Saved Armies</h3>
            @foreach (var cr in CloudRosters.Where(cr => FactionMatches(cr.Faction)))
            {
                <div class="saved-army-row">
                    <div class="saved-army-info" @onclick="() => OnLoadCloudArmy.InvokeAsync(cr.Id)">
                        <span class="saved-army-name">@cr.Name</span>
                        <span class="saved-army-meta">@cr.Faction · @cr.Detachment · @cr.Points pts</span>
                    </div>
                    <button class="saved-army-delete" @onclick="() => OnDeleteCloudArmy.InvokeAsync(cr.Id)" @onclick:stopPropagation="true">🗑</button>
                </div>
            }
        </div>
    }

    @* ── Local armies (only shown when NOT logged in, filtered by selected faction) ── *@
    @if (!Cloud.IsLoggedIn && SavedArmies.Any(sa => FactionMatches(sa.Faction)))
    {
        <div class="saved-armies">
            <h3>📦 Saved Armies (Local)</h3>
            @foreach (var sa in SavedArmies.Where(sa => FactionMatches(sa.Faction)))
            {
                <div class="saved-army-row">
                    <div class="saved-army-info" @onclick="() => OnLoadSavedArmy.InvokeAsync(sa.Name)">
                        <span class="saved-army-name">@sa.Name</span>
                        <span class="saved-army-meta">@sa.Faction · @sa.Detachment · @sa.Points pts</span>
                    </div>
                    <button class="saved-army-delete" @onclick="() => OnDeleteSavedArmy.InvokeAsync(sa.Name)" @onclick:stopPropagation="true">🗑</button>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public string? WelcomeBg { get; set; }
    [Parameter] public EventCallback<string?> WelcomeBgChanged { get; set; }

    [Parameter] public string? ErrorMessage { get; set; }

    [Parameter] public IReadOnlyList<SavedArmyMeta> SavedArmies { get; set; } = [];
    [Parameter] public IReadOnlyList<CloudRosterService.CloudRosterMeta> CloudRosters { get; set; } = [];

    [Parameter] public EventCallback<InputFileChangeEventArgs> OnFileSelected { get; set; }
    [Parameter] public EventCallback<string> OnLoadSavedArmy { get; set; }
    [Parameter] public EventCallback<string> OnDeleteSavedArmy { get; set; }
    [Parameter] public EventCallback<Guid> OnLoadCloudArmy { get; set; }
    [Parameter] public EventCallback<Guid> OnDeleteCloudArmy { get; set; }

    private Task SetWelcomeBg(string bg) => WelcomeBgChanged.InvokeAsync(bg);

    private bool FactionMatches(string faction) => WelcomeBg switch
    {
        "necrons"      => faction.Contains("Necron",      StringComparison.OrdinalIgnoreCase),
        "blood_angels" => faction.Contains("Blood Angel", StringComparison.OrdinalIgnoreCase),
        "dark_angels"  => faction.Contains("Dark Angel",  StringComparison.OrdinalIgnoreCase),
        _              => false
    };
}
